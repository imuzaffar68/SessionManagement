<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<add name="SessionManagementDB"
			 connectionString="Data Source=localhost\SQLEXPRESS;Initial Catalog=ClientServerSessionDB;Integrated Security=True;"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
	<appSettings>
		<!--
		  ╔══════════════════════════════════════════════════════════════╗
		  ║  DEPLOYMENT GUIDE — SessionServer                           ║
		  ╚══════════════════════════════════════════════════════════════╝

		  ── ListenAddress ───────────────────────────────────────────────
		  DO NOT CHANGE — keep "localhost" on every environment.
		  Net.TCP automatically binds port 8001 on ALL network interfaces
		  of this machine regardless of what hostname is written here.
		  Remote clients reach the server via the server's real LAN IP;
		  this value is only used internally for WCF endpoint naming.
		  (Never use "+" — System.Uri rejects it and the server crashes.)

		  ── ServerPort ──────────────────────────────────────────────────
		  Change only if port 8001 is already taken by another service.
		  If you change it here you MUST also change ServerPort in:
		    • SessionClient/App.config   (key="ServerPort")
		    • SessionAdmin/App.config    (key="ServerPort")
		  And open the new port in Windows Firewall:
		    netsh advfirewall firewall add rule name="SessionService" ^
		          dir=in action=allow protocol=TCP localport=<NEW_PORT>
		-->
		<add key="ListenAddress"      value="localhost"/>
		<add key="ServerPort"         value="8001"/>
		<!-- Login images older than this many days are deleted on server startup. Set 0 to disable. -->
		<add key="ImageRetentionDays" value="90"/>
		<!-- System log rows older than this many days are purged on server startup. Set 0 to disable. -->
		<add key="LogRetentionDays"   value="180"/>
	</appSettings>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<!--
	  serviceDebug in XML config is overridden by code in Program.cs.
	  IncludeExceptionDetailInFaults is guarded by #if DEBUG in code — never true in Release builds.
	-->
	<system.serviceModel>
		<behaviors>
			<serviceBehaviors>
				<behavior>
					<serviceDebug includeExceptionDetailInFaults="false" />
				</behavior>
			</serviceBehaviors>
		</behaviors>
	</system.serviceModel>
</configuration>