<Window x:Class="SessionClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Management - Client" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <TextBlock Text="Client Session Management System" 
                       Foreground="White" 
                       FontSize="24" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <!-- Login Screen -->
            <StackPanel x:Name="LoginPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <TextBlock Text="User Login" FontSize="28" FontWeight="Bold" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <TextBlock Text="Username:" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Height="35" FontSize="14" Padding="10,5"/>

                <TextBlock Text="Password:" FontSize="14" Margin="0,20,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" FontSize="14" Padding="10,5"/>

                <TextBlock x:Name="lblLoginError" 
                          Foreground="Red" 
                          FontSize="12" 
                          Margin="0,10,0,0" 
                          Visibility="Collapsed"/>

                <Button x:Name="btnLogin" 
                       Content="Login" 
                       Height="40" 
                       Margin="0,30,0,0" 
                       Background="#3498DB" 
                       Foreground="White" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Click="btnLogin_Click"/>
            </StackPanel>

            <!-- Duration Selection Screen -->
            <StackPanel x:Name="DurationPanel" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Width="400"
                       Visibility="Collapsed">
                <TextBlock Text="Select Session Duration" 
                          FontSize="28" 
                          FontWeight="Bold" 
                          Margin="0,0,0,30" 
                          HorizontalAlignment="Center"/>

                <TextBlock Text="Choose Duration (minutes):" FontSize="14" Margin="0,0,0,10"/>

                <ComboBox x:Name="cboDuration" Height="35" FontSize="14" SelectedIndex="0">
                    <ComboBoxItem Content="15 minutes"/>
                    <ComboBoxItem Content="30 minutes"/>
                    <ComboBoxItem Content="60 minutes"/>
                    <ComboBoxItem Content="120 minutes"/>
                    <ComboBoxItem Content="Custom"/>
                </ComboBox>

                <StackPanel x:Name="CustomDurationPanel" Margin="0,10,0,0" Visibility="Collapsed">
                    <TextBlock Text="Enter custom duration (minutes):" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCustomDuration" Height="35" FontSize="14" Padding="10,5"/>
                </StackPanel>

                <Button x:Name="btnStartSession" 
                       Content="Start Session" 
                       Height="40" 
                       Margin="0,30,0,10" 
                       Background="#27AE60" 
                       Foreground="White" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Click="btnStartSession_Click"/>

                <Button x:Name="btnCancelDuration" 
                       Content="Cancel" 
                       Height="35" 
                       Background="#95A5A6" 
                       Foreground="White" 
                       FontSize="14"
                       Click="btnCancelDuration_Click"/>
            </StackPanel>

            <!-- Active Session Screen -->
            <Grid x:Name="SessionPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#ECF0F1" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Active Session" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="User:" FontSize="12" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="lblSessionUser" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Session Duration:" FontSize="12" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="lblSessionDuration" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="2" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Time Remaining" 
                                  FontSize="18" 
                                  HorizontalAlignment="Center" 
                                  Margin="0,0,0,20"/>
                        <TextBlock x:Name="lblTimeRemaining" 
                                  Text="00:00:00" 
                                  FontSize="72" 
                                  FontWeight="Bold" 
                                  HorizontalAlignment="Center"
                                  Foreground="#2C3E50"/>

                        <ProgressBar x:Name="progressBar" 
                                    Height="20" 
                                    Margin="0,30,0,0" 
                                    Minimum="0" 
                                    Maximum="100"/>
                    </StackPanel>
                </Border>

                <Button Grid.Row="2" 
                       x:Name="btnEndSession" 
                       Content="End Session" 
                       Height="45" 
                       Margin="0,20,0,0" 
                       Background="#E74C3C" 
                       Foreground="White" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Click="btnEndSession_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>