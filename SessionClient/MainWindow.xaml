<Window x:Class="SessionClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Management - Client" Height="520" Width="820"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <TextBlock Text="Client Session Management System"
                       Foreground="White" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">

            <!-- ── LOGIN PANEL ─────────────────────────────── -->
            <StackPanel x:Name="LoginPanel" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Width="380">
                <TextBlock Text="User Login" FontSize="26" FontWeight="Bold"
                           Margin="0,0,0,24" HorizontalAlignment="Center"/>

                <TextBlock Text="Username:" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="txtUsername" Height="34" FontSize="13" Padding="8,4"/>

                <TextBlock Text="Password:" FontSize="13" Margin="0,16,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="txtPassword" Grid.Column="0"
                                 Height="34" FontSize="13" Padding="8,4"/>
                    <TextBox    x:Name="txtPasswordPlain" Grid.Column="0"
                                Height="34" FontSize="13" Padding="8,4"
                                Visibility="Collapsed"/>
                    <Button x:Name="btnShowPassword" Grid.Column="1"
                            Content="👁" FontSize="15"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#3498DB" Margin="4,0,0,0"
                            Click="btnShowPassword_Click"/>
                </Grid>

                <TextBlock x:Name="lblLoginError" Foreground="Red" FontSize="11"
                           Margin="0,8,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                <Button x:Name="btnLogin" Content="Login" Height="38"
                        Margin="0,24,0,0" Background="#3498DB" Foreground="White"
                        FontSize="15" FontWeight="Bold" Click="btnLogin_Click"/>
            </StackPanel>

            <!-- ── DURATION PANEL ──────────────────────────── -->
            <StackPanel x:Name="DurationPanel" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Width="380"
                        Visibility="Collapsed">
                <TextBlock Text="Select Session Duration" FontSize="24" FontWeight="Bold"
                           Margin="0,0,0,24" HorizontalAlignment="Center"/>

                <TextBlock Text="Duration:" FontSize="13" Margin="0,0,0,8"/>
                <ComboBox x:Name="cboDuration" Height="34" FontSize="13"
                          SelectedIndex="0"
                          SelectionChanged="cboDuration_SelectionChanged">
                    <ComboBoxItem Content="15 minutes"/>
                    <ComboBoxItem Content="30 minutes"/>
                    <ComboBoxItem Content="60 minutes"/>
                    <ComboBoxItem Content="120 minutes"/>
                    <ComboBoxItem Content="Custom"/>
                </ComboBox>

                <StackPanel x:Name="CustomDurationPanel" Margin="0,10,0,0"
                            Visibility="Collapsed">
                    <TextBlock Text="Enter minutes:" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtCustomDuration" Height="34"
                             FontSize="13" Padding="8,4"/>
                </StackPanel>

                <Button x:Name="btnStartSession" Content="Start Session"
                        Height="38" Margin="0,24,0,8"
                        Background="#27AE60" Foreground="White"
                        FontSize="15" FontWeight="Bold"
                        Click="btnStartSession_Click"/>
                <Button x:Name="btnCancelDuration" Content="Cancel"
                        Height="32" Background="#95A5A6" Foreground="White"
                        FontSize="13" Click="btnCancelDuration_Click"/>
            </StackPanel>

            <!-- ── SESSION PANEL ───────────────────────────── -->
            <Grid x:Name="SessionPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Info bar -->
                <Border Grid.Row="0" Background="#ECF0F1" Padding="16"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="User" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="lblSessionUser" FontSize="15"
                                       FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Duration" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="lblSessionDuration" FontSize="15"
                                       FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Current Billing" FontSize="11" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="lblCurrentBilling" Text="$0.00"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#E67E22"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Timer -->
                <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="1"
                        Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Time Remaining" FontSize="16"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock x:Name="lblTimeRemaining" Text="00:00:00"
                                   FontSize="68" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="DarkSlateBlue"/>
                        <ProgressBar x:Name="progressBar" Height="18"
                                     Margin="0,24,0,0" Minimum="0" Maximum="100"
                                     Value="100"/>
                    </StackPanel>
                </Border>

                <!-- End button -->
                <Button Grid.Row="2" x:Name="btnEndSession"
                        Content="End Session" Height="42" Margin="0,16,0,0"
                        Background="#E74C3C" Foreground="White"
                        FontSize="15" FontWeight="Bold"
                        Click="btnEndSession_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
