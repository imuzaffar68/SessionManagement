<Window x:Class="SessionClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Management"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="True"
        AllowsTransparency="False"
        Background="#1A252F">

    <!--
    ═══════════════════════════════════════════════════════════════════════
    RESTRICTION DESIGN (aligned with project statement + SRS)
    ═══════════════════════════════════════════════════════════════════════

    Project statement: "Users must log in using valid credentials to
    ACCESS THE SYSTEM" — in an internet café, "the system" = the PC.

    SRS Assumption: "Client application may remain in foreground before
    session start and after session end to restrict misuse."

    FR-09: "lock/logout the client user" after session ends.

    Implementation:
      BEFORE session (Login + Duration screens):
        • WindowStyle="None"  → no title bar, no close/minimize/maximize
        • WindowState="Maximized" + Topmost="True" → covers full screen
        • Cannot be minimized, moved, or closed without admin permission
        → User CANNOT access the desktop or any application without paying

      DURING active session:
        • WindowStyle="SingleBorderWindow" → normal window with title bar
        • WindowState="Normal" → standard size, user can work freely
        • Topmost="False" → user can Alt-Tab to browser, apps
        → User has full access to PC for the duration they paid for

      AFTER session ends:
        • Immediately restores to Maximized + WindowStyle=None + Topmost
        • Covers the screen before user can do anything
        → Prevents free use after session expires
    ═══════════════════════════════════════════════════════════════════════
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar — visible on login/duration screens, hidden during session -->
        <Border x:Name="HeaderBar" Grid.Row="0" Background="#2C3E50" Padding="20,14">
            <Grid>
                <TextBlock Text="Internet Café — Session Management System"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <!-- Status indicator shown to admin for identification -->
                <TextBlock x:Name="lblMachineCode"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#95A5A6" FontSize="12"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">

            <!-- ══ LOGIN PANEL ══════════════════════════════════════ -->
            <Grid x:Name="LoginPanel" Background="#1A252F">
                <Border Background="#2C3E50" CornerRadius="10" Padding="48"
                        Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="🖥" FontSize="48" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="User Login" FontSize="28" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,0,0,28"/>

                        <TextBlock Text="Username" Foreground="#BDC3C7" FontSize="13"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtUsername" Height="38" FontSize="14"
                                 Padding="10,4" Background="#34495E" Foreground="White"
                                 BorderBrush="#5D6D7E" BorderThickness="1"/>

                        <TextBlock Text="Password" Foreground="#BDC3C7" FontSize="13"
                                   Margin="0,16,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="txtPassword" Grid.Column="0"
                                         Height="38" FontSize="14" Padding="10,4"
                                         Background="#34495E" Foreground="White"
                                         BorderBrush="#5D6D7E" BorderThickness="1"/>
                            <TextBox x:Name="txtPasswordPlain" Grid.Column="0"
                                     Height="38" FontSize="14" Padding="10,4"
                                     Background="#34495E" Foreground="White"
                                     BorderBrush="#5D6D7E" BorderThickness="1"
                                     Visibility="Collapsed"/>
                            <Button x:Name="btnShowPassword" Grid.Column="1"
                                    Content="👁" FontSize="16"
                                    Background="#34495E" BorderBrush="#5D6D7E"
                                    Foreground="#BDC3C7" Margin="4,0,0,0"
                                    Click="btnShowPassword_Click"/>
                        </Grid>

                        <Border x:Name="pnlLoginError" Background="#2E1515"
                                BorderBrush="#E74C3C" BorderThickness="1"
                                CornerRadius="4" Padding="10,8"
                                Margin="0,14,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="lblLoginError" Foreground="#E74C3C"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <Button x:Name="btnLogin" Content="LOGIN"
                                Height="42" Margin="0,24,0,0"
                                Background="#3498DB" Foreground="White"
                                FontSize="15" FontWeight="Bold"
                                BorderThickness="0"
                                Click="btnLogin_Click"/>

                        <TextBlock x:Name="lblLoginStatus" Foreground="#7F8C8D"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Margin="0,14,0,0" Text="Connecting to server…"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ DURATION PANEL ══════════════════════════════════ -->
            <Grid x:Name="DurationPanel" Background="#1A252F" Visibility="Collapsed">
                <Border Background="#2C3E50" CornerRadius="10" Padding="48"
                        Width="460" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="⏱" FontSize="48" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Select Session Duration"
                                   FontSize="24" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="lblWelcome" Text="Welcome"
                                   FontSize="14" Foreground="#3498DB"
                                   HorizontalAlignment="Center" Margin="0,0,0,28"/>

                        <TextBlock Text="Duration:" Foreground="#BDC3C7"
                                   FontSize="13" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cboDuration" Height="38" FontSize="14"
                                  SelectedIndex="2"
                                  SelectionChanged="cboDuration_SelectionChanged">
                            <ComboBoxItem Content="15 minutes"/>
                            <ComboBoxItem Content="30 minutes"/>
                            <ComboBoxItem Content="60 minutes"/>
                            <ComboBoxItem Content="120 minutes"/>
                            <ComboBoxItem Content="Custom…"/>
                        </ComboBox>

                        <StackPanel x:Name="CustomDurationPanel"
                                    Margin="0,12,0,0" Visibility="Collapsed">
                            <TextBlock Text="Enter minutes (15 – 480):"
                                       Foreground="#BDC3C7" FontSize="13" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtCustomDuration" Height="38"
                                     FontSize="14" Padding="10,4"
                                     Background="#34495E" Foreground="White"
                                     BorderBrush="#5D6D7E" BorderThickness="1"/>
                        </StackPanel>

                        <Button x:Name="btnStartSession" Content="START SESSION"
                                Height="42" Margin="0,24,0,10"
                                Background="#27AE60" Foreground="White"
                                FontSize="15" FontWeight="Bold" BorderThickness="0"
                                Click="btnStartSession_Click"/>
                        <Button x:Name="btnCancelDuration" Content="← Back to Login"
                                Height="34" Background="Transparent"
                                Foreground="#7F8C8D" FontSize="12"
                                BorderThickness="0"
                                Click="btnCancelDuration_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ SESSION PANEL ════════════════════════════════════ -->
            <!--
                During an active session the window becomes a normal
                compact window (not full-screen) so the user can use
                the PC they paid for. It sits in the taskbar as a
                persistent timer reminder.
            -->
            <Grid x:Name="SessionPanel" Visibility="Collapsed"
                  Background="#F5F6FA">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Info bar -->
                <Border Grid.Row="0" Background="#2C3E50" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="USER" FontSize="10"
                                       Foreground="#95A5A6"/>
                            <TextBlock x:Name="lblSessionUser" FontSize="14"
                                       FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="DURATION" FontSize="10"
                                       Foreground="#95A5A6"/>
                            <TextBlock x:Name="lblSessionDuration" FontSize="14"
                                       FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock Text="BILLING" FontSize="10"
                                       Foreground="#95A5A6"/>
                            <TextBlock x:Name="lblCurrentBilling" Text="$0.00"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#F39C12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Timer -->
                <Border Grid.Row="1" Padding="24" Background="#F5F6FA">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Time Remaining" FontSize="15"
                                   HorizontalAlignment="Center"
                                   Foreground="#7F8C8D" Margin="0,0,0,12"/>
                        <TextBlock x:Name="lblTimeRemaining" Text="00:00:00"
                                   FontSize="60" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2C3E50"/>
                        <ProgressBar x:Name="progressBar" Height="14"
                                     Margin="0,20,0,0" Minimum="0" Maximum="100"
                                     Value="100" Foreground="#27AE60"/>
                        <TextBlock x:Name="lblWarning" Text=""
                                   FontSize="13" HorizontalAlignment="Center"
                                   Foreground="#E74C3C" Margin="0,10,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- End Session button -->
                <Button Grid.Row="2" x:Name="btnEndSession"
                        Content="End Session" Height="44" Margin="16"
                        Background="#E74C3C" Foreground="White"
                        FontSize="14" FontWeight="Bold" BorderThickness="0"
                        Click="btnEndSession_Click"/>
                        <Button x:Name="btnMinimizeTimer" Content="_" Width="32" Height="32"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,0,8,0" Click="btnMinimizeTimer_Click"
                                ToolTip="Minimize to floating timer"/>
            </Grid>

        </Grid>
    </Grid>
</Window>
