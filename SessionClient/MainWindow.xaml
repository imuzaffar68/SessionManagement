<Window x:Class="SessionClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Management"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="True"
        AllowsTransparency="False"
        Background="#1A252F">

    <!--
    ═══════════════════════════════════════════════════════════════════════
    RESTRICTION DESIGN  (matches project statement + SRS)
    ═══════════════════════════════════════════════════════════════════════

    BEFORE session  (Login + Duration screens):
      • WindowStyle="None"  → no title bar, no OS chrome
      • WindowState="Maximized" + Topmost="True" → full-screen lock
      • Keyboard hook blocks Alt+Tab / Win / Ctrl+Esc / Alt+F4
      → User CANNOT reach the desktop without paying

    DURING active session:
      • WindowStyle="SingleBorderWindow" → normal title bar
      • WindowState="Normal", fixed 420×320 compact size
      • Topmost="False", hook removed → full desktop access
      • Window sits top-right as a always-visible session timer
      → User can Alt-Tab to browser and any application freely

    AFTER session ends:
      • LockScreen() is the first line of ResetToLogin() — synchronous
      • Full-screen lock restored before any UI changes
      → No gap where desktop is accessible for free

    EnableKioskMode=false in App.config → dev mode: normal window,
    no hook, can be Alt-Tabbed during development.
    ═══════════════════════════════════════════════════════════════════════
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header (shown on login/duration screens only) ──────────── -->
        <Border x:Name="HeaderBar" Grid.Row="0" Background="#2C3E50" Padding="20,14">
            <Grid>
                <TextBlock Text="Internet Café — Session Management System"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="lblMachineCode"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#95A5A6" FontSize="12"/>
                <!-- Connection Status Indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0">
                    <Ellipse x:Name="ellipseConnectionStatus" Width="14" Height="14" Fill="Red" Stroke="Black" StrokeThickness="1" Margin="0,0,8,0"/>
                    <TextBlock x:Name="lblConnectionStatus" Text="Disconnected" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    <Button x:Name="btnConnect" Content="Connect" Height="20" Width="60" Margin="8,0,0,0" Visibility="Collapsed" Click="btnConnect_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">

            <!-- ══ LOGIN PANEL ══════════════════════════════════════════ -->
            <Grid x:Name="LoginPanel" Background="#1A252F">
                <Border Background="#2C3E50" CornerRadius="10" Padding="48"
                        Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="🖥" FontSize="48" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="User Login" FontSize="28" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,0,0,28"/>

                        <TextBlock Text="Username" Foreground="#BDC3C7" FontSize="13"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtUsername" Height="38" FontSize="14"
                                 Padding="10,4" Background="#34495E" Foreground="White"
                                 BorderBrush="#5D6D7E" BorderThickness="1"/>

                        <TextBlock Text="Password" Foreground="#BDC3C7" FontSize="13"
                                   Margin="0,16,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="txtPassword" Grid.Column="0"
                                         Height="38" FontSize="14" Padding="10,4"
                                         Background="#34495E" Foreground="White"
                                         BorderBrush="#5D6D7E" BorderThickness="1"/>
                            <TextBox x:Name="txtPasswordPlain" Grid.Column="0"
                                     Height="38" FontSize="14" Padding="10,4"
                                     Background="#34495E" Foreground="White"
                                     BorderBrush="#5D6D7E" BorderThickness="1"
                                     Visibility="Collapsed"/>
                            <Button x:Name="btnShowPassword" Grid.Column="1"
                                    Content="👁" FontSize="16"
                                    Background="#34495E" BorderBrush="#5D6D7E"
                                    Foreground="#BDC3C7" Margin="4,0,0,0"
                                    Click="btnShowPassword_Click"/>
                        </Grid>

                        <Border x:Name="pnlLoginError" Background="#2E1515"
                                BorderBrush="#E74C3C" BorderThickness="1"
                                CornerRadius="4" Padding="10,8"
                                Margin="0,14,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="lblLoginError" Foreground="#E74C3C"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <Button x:Name="btnLogin" Content="LOGIN"
                                Height="42" Margin="0,24,0,0"
                                Background="#3498DB" Foreground="White"
                                FontSize="15" FontWeight="Bold" BorderThickness="0"
                                Click="btnLogin_Click"/>

                        <TextBlock x:Name="lblLoginStatus" Foreground="#7F8C8D"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Margin="0,14,0,0" Text="Connecting to server…"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ DURATION PANEL ════════════════════════════════════════ -->
            <Grid x:Name="DurationPanel" Background="#1A252F" Visibility="Collapsed">
                <Border Background="#2C3E50" CornerRadius="10" Padding="48"
                        Width="460" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="⏱" FontSize="48" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Select Session Duration"
                                   FontSize="24" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="lblWelcome" Text="Welcome"
                                   FontSize="14" Foreground="#3498DB"
                                   HorizontalAlignment="Center" Margin="0,0,0,28"/>

                        <TextBlock Text="Duration:" Foreground="#BDC3C7"
                                   FontSize="13" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cboDuration" Height="38" FontSize="14"
                                  SelectedIndex="2"
                                  SelectionChanged="cboDuration_SelectionChanged">
                            <ComboBoxItem Content="15 minutes"/>
                            <ComboBoxItem Content="30 minutes"/>
                            <ComboBoxItem Content="60 minutes"/>
                            <ComboBoxItem Content="120 minutes"/>
                            <ComboBoxItem Content="Custom…"/>
                        </ComboBox>

                        <StackPanel x:Name="CustomDurationPanel"
                                    Margin="0,12,0,0" Visibility="Collapsed">
                            <TextBlock Text="Enter minutes (15 – 480):"
                                       Foreground="#BDC3C7" FontSize="13" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtCustomDuration" Height="38"
                                     FontSize="14" Padding="10,4"
                                     Background="#34495E" Foreground="White"
                                     BorderBrush="#5D6D7E" BorderThickness="1"/>
                        </StackPanel>

                        <Button x:Name="btnStartSession" Content="START SESSION"
                                Height="42" Margin="0,24,0,10"
                                Background="#27AE60" Foreground="White"
                                FontSize="15" FontWeight="Bold" BorderThickness="0"
                                Click="btnStartSession_Click"/>
                        <Button x:Name="btnCancelDuration" Content="← Back to Login"
                                Height="34" Background="Transparent"
                                Foreground="#7F8C8D" FontSize="12"
                                BorderThickness="0"
                                Click="btnCancelDuration_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ SESSION PANEL ═════════════════════════════════════════
                 Shown inside a compact 420×320 normal window during session.
                 The window is NO LONGER full-screen when this panel is visible.
                 UnlockScreen() resizes the window SYNCHRONOUSLY before this
                 panel is shown, so layout is always correct.
            ════════════════════════════════════════════════════════════ -->
            <Grid x:Name="SessionPanel" Visibility="Collapsed" Background="#F5F6FA">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- info bar: user / duration / billing -->
                    <RowDefinition Height="*"/>
                    <!-- countdown timer -->
                    <RowDefinition Height="Auto"/>
                    <!-- action buttons -->
                </Grid.RowDefinitions>

                <!-- Row 0: session info bar -->
                <Border Grid.Row="0" Background="#2C3E50" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="USER" FontSize="9" Foreground="#95A5A6"/>
                            <TextBlock x:Name="lblSessionUser" FontSize="13"
                                       FontWeight="Bold" Foreground="White"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="DURATION" FontSize="9" Foreground="#95A5A6"/>
                            <TextBlock x:Name="lblSessionDuration" FontSize="13"
                                       FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock Text="BILLING" FontSize="9" Foreground="#95A5A6"/>
                            <TextBlock x:Name="lblCurrentBilling" Text="$0.00"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#F39C12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 1: countdown timer display -->
                <Border Grid.Row="1" Padding="16,12" Background="#F5F6FA">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Time Remaining" FontSize="13"
                                   HorizontalAlignment="Center"
                                   Foreground="#7F8C8D" Margin="0,0,0,8"/>
                        <TextBlock x:Name="lblTimeRemaining" Text="00:00:00"
                                   FontSize="48" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2C3E50"/>
                        <ProgressBar x:Name="progressBar" Height="10"
                                     Margin="0,12,0,0" Minimum="0" Maximum="100"
                                     Value="100" Foreground="#27AE60"/>
                        <TextBlock x:Name="lblWarning" Text=""
                                   FontSize="12" HorizontalAlignment="Center"
                                   Foreground="#E74C3C" Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Row 2: action buttons — BOTH buttons inside this row correctly -->
                <Grid Grid.Row="2" Margin="12,0,12,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- End Session — primary red button -->
                    <Button Grid.Column="0" x:Name="btnEndSession"
                            Content="End Session" Height="40"
                            Background="#E74C3C" Foreground="White"
                            FontSize="13" FontWeight="Bold" BorderThickness="0"
                            Click="btnEndSession_Click"/>

                    <!-- Minimize timer — secondary compact button -->
                    <!-- Clicking this minimizes the window to taskbar.         -->
                    <!-- The timer keeps running; user can restore from taskbar. -->
                    <Button Grid.Column="2" x:Name="btnMinimizeTimer"
                            Content="—" Width="40" Height="40"
                            Background="#7F8C8D" Foreground="White"
                            FontSize="16" FontWeight="Bold" BorderThickness="0"
                            ToolTip="Minimize to taskbar — timer keeps running"
                            Click="btnMinimizeTimer_Click"/>
                </Grid>

            </Grid>

        </Grid>
    </Grid>
</Window>
