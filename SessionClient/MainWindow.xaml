<Window x:Class="SessionClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetCafé Session"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="True"
        AllowsTransparency="False"
        Background="#0A0E1A">


    <Grid>
        <!-- Ambient background glow -->
        <Ellipse Width="800" Height="800" HorizontalAlignment="Center"
                 VerticalAlignment="Center" Margin="0,-200,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0A1828" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ══════════════════════════════════════════════════════════
             LOGIN PANEL
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="LoginPanel">

            <!-- Header Bar (kiosk title) -->
            <Border x:Name="HeaderBar" Height="58" VerticalAlignment="Top"
                    Background="#13161F" BorderBrush="#1E2433" BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="8" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="⚡" FontSize="13" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="NetCafé" FontSize="15" FontWeight="Bold"
                                   Foreground="#F1F5F9" FontFamily="Segoe UI"/>
                        <TextBlock Text=" — Session Management"
                                   FontSize="13" Foreground="#475569"
                                   FontFamily="Segoe UI" VerticalAlignment="Bottom"
                                   Margin="0,0,0,1"/>
                    </StackPanel>

                    <!-- Machine code & connection -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="ellipseConnectionStatus" Width="8" Height="8"
                                 Fill="OrangeRed" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="lblConnectionStatus" Text="Connecting…"
                                   FontSize="11" Foreground="#64748B" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="btnConnect" Content="↺ Reconnect" Height="26" Width="90"
                                Margin="10,0,0,0" FontSize="11" Visibility="Collapsed"
                                Style="{StaticResource ClientBtnGhost}" Padding="0,0"
                                Click="btnConnect_Click"/>
                        <TextBlock x:Name="lblMachineCode" Text="Machine: CL001"
                                   FontSize="11" Foreground="#475569" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Login Card -->
            <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#171B26" BorderBrush="#2D3748" BorderThickness="1"
                    CornerRadius="20" Padding="40">
                <StackPanel>
                    <!-- Logo -->
                    <Border Width="68" Height="68" CornerRadius="20"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1D3461" Offset="0"/>
                                <GradientStop Color="#4F8EF7" Offset="0.5"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🖥" FontSize="34" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Welcome Back" FontSize="26" FontWeight="Bold"
                               Foreground="#F1F5F9" HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Sign in to start your session"
                               FontSize="13" Foreground="#475569"
                               HorizontalAlignment="Center" Margin="0,6,0,32"
                               FontFamily="Segoe UI"/>

                    <!-- Username -->
                    <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" FontFamily="Segoe UI" Margin="0,0,0,7"/>
                    <TextBox x:Name="txtUsername" Style="{StaticResource ClientInput}"
                             Height="48" Margin="0,0,0,16"/>

                    <!-- Password -->
                    <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" FontFamily="Segoe UI" Margin="0,0,0,7"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="txtPassword" Grid.Column="0"
                                     Style="{StaticResource ClientPassword}" Height="48"/>
                        <TextBox x:Name="txtPasswordPlain" Grid.Column="0"
                                 Style="{StaticResource ClientInput}" Height="48"
                                 Visibility="Collapsed"/>
                        <Button x:Name="btnShowPassword" Grid.Column="1"
                                Content="👁" Style="{StaticResource ShowPasswordBtn}"
                                Height="48" Margin="4,0,0,0"
                                Click="btnShowPassword_Click"/>
                    </Grid>

                    <!-- Error -->
                    <Border x:Name="pnlLoginError" Background="#1A0505" CornerRadius="10"
                            BorderBrush="#7F1D1D" BorderThickness="1"
                            Padding="14,10" Margin="0,10,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ " Foreground="#F87171" FontSize="14"
                                       FontFamily="Segoe UI"/>
                            <TextBlock x:Name="lblLoginError" Foreground="#FCA5A5"
                                       FontSize="12" TextWrapping="Wrap"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Login Button -->
                    <Button x:Name="btnLogin" Content="Sign In →"
                            Style="{StaticResource ClientBtnPrimary}"
                            Height="52" Margin="0,24,0,0" FontSize="16"
                            Padding="0,0" Click="btnLogin_Click"/>

                    <!-- Status -->
                    <TextBlock x:Name="lblLoginStatus"
                               FontSize="12" Foreground="#475569"
                               HorizontalAlignment="Center" Margin="0,16,0,0"
                               FontFamily="Segoe UI"
                               Text="Connecting to server…" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             DURATION SELECTION PANEL
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="DurationPanel" Background="#0A0E1A" Visibility="Collapsed">

            <!-- Ambient glow -->
            <Ellipse Width="600" Height="600" HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#0D1F3C" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border Width="480" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#171B26" BorderBrush="#2D3748" BorderThickness="1"
                    CornerRadius="20" Padding="40">
                <StackPanel>
                    <Border Width="80" Height="80" CornerRadius="40"
                            HorizontalAlignment="Center" Margin="0,0,0,20"
                            Background="#1E2433" BorderBrush="#2D3748" BorderThickness="2"
                            ClipToBounds="True">
                        <Grid>
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#064E3B" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="0.5"/>
                                        <GradientStop Color="#34D399" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="lblDurationInitial" Text="?" FontSize="32"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White" FontWeight="Bold"/>
                            <Image x:Name="imgDurationAvatar" Stretch="UniformToFill"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Choose Duration" FontSize="26" FontWeight="Bold"
                               Foreground="#F1F5F9" HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="lblWelcome" Text="Welcome!"
                               FontSize="14" Foreground="#4F8EF7"
                               HorizontalAlignment="Center" Margin="0,6,0,32"
                               FontFamily="Segoe UI"/>

                    <TextBlock Text="SESSION DURATION" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                    <!-- Duration presets grid -->
                    <UniformGrid Columns="2" Margin="0,0,0,12">
                        <Button x:Name="btnDur15" Content="1 min" Height="52"
                                Margin="0,0,6,6"
                                Background="#1E2433" Foreground="#94A3B8"
                                BorderBrush="#2D3748" BorderThickness="1"
                                FontFamily="Segoe UI" FontSize="14"
                                Cursor="Hand" Click="btnDurationPreset_Click" Tag="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="r" Property="Background" Value="#1D3461"/>
                                            <Setter TargetName="r" Property="BorderBrush" Value="#4F8EF7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnDur30" Content="30 min" Height="52"
                                Margin="6,0,0,6"
                                Background="#1E2433" Foreground="#94A3B8"
                                BorderBrush="#2D3748" BorderThickness="1"
                                FontFamily="Segoe UI" FontSize="14"
                                Cursor="Hand" Click="btnDurationPreset_Click" Tag="30">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="r" Property="Background" Value="#1D3461"/>
                                            <Setter TargetName="r" Property="BorderBrush" Value="#4F8EF7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnDur60" Content="60 min  ★" Height="52"
                                Margin="0,0,6,6"
                                BorderBrush="#4F8EF7" BorderThickness="1"
                                FontFamily="Segoe UI" FontSize="14"
                                Cursor="Hand" Click="btnDurationPreset_Click" Tag="60">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1D3461" Offset="0"/>
                                    <GradientStop Color="#172854" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Foreground>
                                <SolidColorBrush Color="#60A5FA"/>
                            </Button.Foreground>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnDur120" Content="120 min" Height="52"
                                Margin="6,0,0,6"
                                Background="#1E2433" Foreground="#94A3B8"
                                BorderBrush="#2D3748" BorderThickness="1"
                                FontFamily="Segoe UI" FontSize="14"
                                Cursor="Hand" Click="btnDurationPreset_Click" Tag="120">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="r" Property="Background" Value="#1D3461"/>
                                            <Setter TargetName="r" Property="BorderBrush" Value="#4F8EF7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </UniformGrid>

                    <!-- Hidden ComboBox for legacy code compatibility -->
                    <ComboBox x:Name="cboDuration" Visibility="Collapsed" SelectedIndex="2">
                        <ComboBoxItem Content="15 minutes"/>
                        <ComboBoxItem Content="30 minutes"/>
                        <ComboBoxItem Content="60 minutes"/>
                        <ComboBoxItem Content="120 minutes"/>
                        <ComboBoxItem Content="Custom…"/>
                    </ComboBox>

                    <!-- Custom duration toggle button -->
                    <Button x:Name="btnDurCustom" Content="Custom duration…" Height="40"
                            Margin="0,0,0,12"
                            Background="#1E2433" Foreground="#94A3B8"
                            BorderBrush="#2D3748" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="13"
                            Cursor="Hand" Click="btnDurCustom_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#1D3461"/>
                                        <Setter TargetName="r" Property="BorderBrush" Value="#4F8EF7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Cost estimate label (updates dynamically) -->
                    <TextBlock x:Name="lblCostEstimate"
                               FontSize="12" Foreground="#4F8EF7"
                               HorizontalAlignment="Center" FontFamily="Segoe UI"
                               Margin="0,0,0,8" Visibility="Collapsed"/>

                    <!-- Custom duration -->
                    <StackPanel x:Name="CustomDurationPanel" Visibility="Collapsed"
                                Margin="0,0,0,12">
                        <TextBlock Text="CUSTOM MINUTES (1 – 480)" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#475569" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtCustomDuration" Style="{StaticResource ClientInput}"
                                 Height="48" TextChanged="txtCustomDuration_TextChanged"/>
                    </StackPanel>

                    <Button x:Name="btnStartSession" Content="▶  Start Session"
                            Style="{StaticResource ClientBtnGreen}"
                            Height="52" Margin="0,12,0,8" FontSize="16"
                            Padding="0,0" Click="btnStartSession_Click"/>
                    <Button x:Name="btnCancelDuration" Content="← Back to Login"
                            Style="{StaticResource ClientBtnGhost}"
                            Height="40" FontSize="13" Padding="0,0"
                            Click="btnCancelDuration_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             SESSION PANEL — compact floating timer
             This panel is shown inside a small normal window
             after UnlockScreen() resizes it.
        ══════════════════════════════════════════════════════════ -->
        <Border x:Name="SessionPanel" Visibility="Collapsed"
                Background="#171B26"
                BorderBrush="#2D3748" BorderThickness="1">
        <Grid>

            <!-- Custom title bar — matches admin app header style exactly -->
            <Border x:Name="sessionDragHandle" Height="38" VerticalAlignment="Top"
                    Background="#0D0F17"
                    BorderBrush="#2D3748" BorderThickness="0,0,0,1"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="sessionDragHandle_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <!-- Left: status indicator + label -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#34D399"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Session Active" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#64748B" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: avatar + username + minimize button -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Width="22" Height="22" CornerRadius="11" Margin="0,0,6,0"
                                Background="#1E2433" ClipToBounds="True">
                            <Grid>
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#064E3B" Offset="0"/>
                                            <GradientStop Color="#1D3461" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock x:Name="lblSessionInitial" Text="?" FontSize="10"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White"/>
                                <Image x:Name="imgSessionAvatar" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="lblSessionUser" Text="—" FontSize="11"
                                   Foreground="#94A3B8" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="100"
                                   Margin="0,0,6,0"/>
                        <!-- Minimize to floating timer — inside title bar, admin-style -->
                        <Button x:Name="btnMinimizeToFloat"
                                Content="—" Width="32" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#475569" FontSize="14" Cursor="Hand"
                                ToolTip="Minimise to floating timer"
                                Click="btnMinimizeTimer_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="r" Property="Background" Value="#1E2433"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Timer + info -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,38,0,0">

                <!-- Circular progress visual -->
                <Border Width="160" Height="160" HorizontalAlignment="Center"
                        Margin="0,0,0,0">
                    <Grid>
                        <!-- Background ring -->
                        <Ellipse Width="160" Height="160" Stroke="#1E2433" StrokeThickness="10"/>
                        <!-- Timer text -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="lblTimeRemaining" Text="00:00:00"
                                       FontSize="28" FontWeight="Bold" Foreground="#4F8EF7"
                                       FontFamily="Segoe UI Mono"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="remaining" FontSize="10" Foreground="#475569"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Stats row -->
                <Grid Margin="12,12,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="DURATION" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#475569" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblSessionDuration" Text="—"
                                   FontSize="13" FontWeight="Bold" Foreground="#94A3B8"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="BILLING" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#475569" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblCurrentBilling" Text="$0.00"
                                   FontSize="13" FontWeight="Bold" Foreground="#FBBF24"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Progress bar -->
                <ProgressBar x:Name="progressBar" Height="4" Margin="12,10,12,0"
                             Minimum="0" Maximum="100" Value="100"
                             Background="#1E2433" Foreground="#4F8EF7"
                             BorderThickness="0"/>

                <!-- Warning -->
                <TextBlock x:Name="lblWarning" Text="" FontSize="11"
                           HorizontalAlignment="Center" Foreground="#F87171"
                           FontFamily="Segoe UI" Margin="0,8,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Action button at bottom — full width now that minimize lives in the title bar -->
            <Button x:Name="btnEndSession"
                    VerticalAlignment="Bottom" Margin="12,0,12,12"
                    Content="⬛  End Session"
                    Style="{StaticResource ClientBtnRed}"
                    Height="38" FontSize="13" Padding="0,0"
                    Click="btnEndSession_Click"/>

            <!-- Keep the old name so code-behind still compiles -->
            <Button x:Name="btnMinimizeTimer" Visibility="Collapsed"
                    Click="btnMinimizeTimer_Click"/>
        </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             SUMMARY PANEL — shown after every session end
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="SummaryPanel" Background="#0A0E1A" Visibility="Collapsed">

            <!-- Ambient glow -->
            <Ellipse Width="600" Height="600" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#0D2A1F" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border Width="480" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#171B26" BorderBrush="#2D3748" BorderThickness="1"
                    CornerRadius="20" Padding="40">
                <StackPanel>

                    <!-- Icon -->
                    <Border Width="68" Height="68" CornerRadius="20"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#064E3B" Offset="0"/>
                                <GradientStop Color="#059669" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="✓" FontSize="34" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title + subtitle -->
                    <TextBlock Text="Session Complete" FontSize="26" FontWeight="Bold"
                               Foreground="#F1F5F9" HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="lblSummarySubtitle"
                               FontSize="13" Foreground="#475569"
                               HorizontalAlignment="Center" Margin="0,6,0,28"
                               FontFamily="Segoe UI" TextWrapping="Wrap"
                               MaxWidth="380" TextAlignment="Center"/>

                    <!-- Details card -->
                    <Border Background="#0F1117" CornerRadius="12"
                            Padding="20,16" Margin="0,0,0,12">
                        <StackPanel>

                            <!-- User row -->
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="USER" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#475569" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblSummaryUser"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#F1F5F9"
                                           FontFamily="Segoe UI" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Machine row -->
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="MACHINE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#475569" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblSummaryMachine"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#F1F5F9"
                                           FontFamily="Segoe UI" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Duration row -->
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="DURATION USED" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#475569" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblSummaryDuration"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#F1F5F9"
                                           FontFamily="Segoe UI" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Separator -->
                            <Border BorderBrush="#1E2433" BorderThickness="0,1,0,0" Margin="0,0,0,12"/>

                            <!-- Amount row -->
                            <Grid>
                                <TextBlock Text="AMOUNT CHARGED" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#475569" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblSummaryAmount"
                                           FontSize="20" FontWeight="Bold" Foreground="#FBBF24"
                                           FontFamily="Segoe UI" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Pay at counter notice -->
                            <Border Background="#1C1A0E" CornerRadius="8" Padding="12,10" Margin="0,14,0,0"
                                    BorderBrush="#854D0E" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="💰" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock FontSize="12" FontFamily="Segoe UI" TextWrapping="Wrap"
                                               HorizontalAlignment="Center">
                                        <Run Text="Please pay at the counter" FontWeight="SemiBold" Foreground="#FDE68A"/>
                                        <Run Text=" before leaving." Foreground="#A16207"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- End reason pill -->
                    <Border Background="#0F1117" CornerRadius="10"
                            Padding="14,10" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="END REASON  " FontSize="10" FontWeight="SemiBold"
                                       Foreground="#475569" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblSummaryReason"
                                       FontSize="12" Foreground="#94A3B8"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Back to login -->
                    <Button x:Name="btnSummaryClose" Content="Back to Login →"
                            Style="{StaticResource ClientBtnPrimary}"
                            Height="52" FontSize="16" Padding="0,0"
                            Click="btnSummaryClose_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             CONNECTING OVERLAY — shown while btnConnect async connect is in progress.
             Rendered last so it appears above all panels (including kiosk Topmost window).
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="ConnectingOverlay" Visibility="Collapsed" Background="#B2000000">
            <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1"
                    CornerRadius="14" Width="300" Height="120"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="32" ShadowDepth="0" Opacity="0.8"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,16">
                    <TextBlock Text="Reconnecting to server…"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Foreground="#F1F5F9" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <ProgressBar IsIndeterminate="True" Height="4"
                                 Background="#1E2433" Foreground="#34D399"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
