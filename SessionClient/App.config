<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<!-- Connection Strings -->
	<connectionStrings>
		<!-- SQL Server Connection String -->
		<add name="SessionManagementDB"
			 connectionString="Data Source=localhost\SQLEXPRESS;Initial Catalog=ClientServerSessionDB;Integrated Security=True;Connect Timeout=30;Encrypt=False;TrustServerCertificate=True"
			 providerName="System.Data.SqlClient"/>

		<!-- Alternative with SQL Authentication -->
		<!--
    <add name="SessionManagementDB" 
         connectionString="Data Source=SERVER_NAME;Initial Catalog=SessionManagementDB;User ID=sa;Password=YOUR_PASSWORD;Connect Timeout=30;Encrypt=False;TrustServerCertificate=True" 
         providerName="System.Data.SqlClient"/>
    -->
	</connectionStrings>

	<!-- Application Settings -->
	<appSettings>
		<!-- Client Application Settings -->
		<add key="ClientCode" value="CL001"/>
		<add key="ClientMachineName" value="CLIENT-PC-01"/>
		<add key="ServerAddress" value="localhost"/>
		<add key="ServerPort" value="8001"/>

		<!-- Session Settings -->
		<add key="DefaultSessionDuration" value="60"/>
		<add key="MinSessionDuration" value="15"/>
		<add key="MaxSessionDuration" value="480"/>
		<add key="TimeWarningThreshold" value="5"/>

		<!-- Image Capture Settings -->
		<add key="EnableImageCapture" value="true"/>
		<add key="ImageQuality" value="85"/>
		<add key="ImageFormat" value="Jpeg"/>
		<add key="ImageMaxWidth" value="640"/>
		<add key="ImageMaxHeight" value="480"/>
		<add key="ImageStoragePath" value=".\Images\"/>

		<!-- Security Settings -->
		<add key="EnableProxyDetection" value="true"/>
		<add key="ProxyCheckInterval" value="60"/>
		<add key="MaxLoginAttempts" value="3"/>
		<add key="LockoutDuration" value="300"/>

		<!-- Billing Settings -->
		<add key="DefaultBillingRate" value="0.05"/>
		<add key="BillingCurrency" value="USD"/>

		<!-- UI Settings -->
		<add key="RefreshInterval" value="5"/>
		<add key="ShowDebugInfo" value="false"/>
		<add key="Language" value="en-US"/>

		<!-- Logging Settings -->
		<add key="EnableLogging" value="true"/>
		<add key="LogLevel" value="Info"/>
		<add key="LogPath" value=".\Logs\"/>
	</appSettings>

	<!-- WCF Service Configuration -->
	<system.serviceModel>

		<!-- CLIENT CONFIGURATION -->
		<client>
			<!-- Session Service Endpoint for Client -->
			<endpoint address="net.tcp://localhost:8001/SessionService"
					  binding="netTcpBinding"
					  bindingConfiguration="DuplexBinding"
					  contract="SessionManagement.WCF.ISessionService"
					  name="SessionServiceEndpoint">
				<identity>
					<dns value="localhost"/>
				</identity>
			</endpoint>
		</client>

		<!-- SERVER CONFIGURATION -->
		<services>
			<!-- Session Service -->
			<service name="SessionManagement.WCF.SessionService"
					 behaviorConfiguration="SessionServiceBehavior">

				<!-- TCP Endpoint (Recommended for LAN) -->
				<endpoint address="net.tcp://localhost:8080/SessionService"
						  binding="netTcpBinding"
						  bindingConfiguration="DuplexBinding"
						  contract="SessionManagement.WCF.ISessionService"/>

				<!-- MEX Endpoint for Metadata Exchange -->
				<endpoint address="mex"
						  binding="mexTcpBinding"
						  contract="IMetadataExchange"/>

				<!-- Base Address -->
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:8080/"/>
					</baseAddresses>
				</host>
			</service>
		</services>

		<!-- BINDINGS -->
		<bindings>
			<!-- NetTcpBinding for Duplex Communication -->
			<netTcpBinding>
				<binding name="DuplexBinding"
						 maxReceivedMessageSize="2147483647"
						 maxBufferSize="2147483647"
						 receiveTimeout="00:20:00"
						 sendTimeout="00:20:00"
						 openTimeout="00:05:00"
						 closeTimeout="00:01:00">

					<readerQuotas maxDepth="32"
								  maxStringContentLength="2147483647"
								  maxArrayLength="2147483647"
								  maxBytesPerRead="2147483647"
								  maxNameTableCharCount="2147483647"/>

					<security mode="None"/>

					<!-- ReliableSession disabled for duplex callbacks -->
					<reliableSession enabled="false"/>
				</binding>
			</netTcpBinding>
		</bindings>

		<!-- BEHAVIORS -->
		<behaviors>
			<serviceBehaviors>
				<behavior name="SessionServiceBehavior">
					<!-- Enable metadata exchange -->
					<serviceMetadata/>

					<!-- Service Debug -->
					<serviceDebug includeExceptionDetailInFaults="true"/>

					<!-- Service Throttling -->
					<serviceThrottling maxConcurrentCalls="100"
									 maxConcurrentInstances="100"
									 maxConcurrentSessions="100"/>
				</behavior>
			</serviceBehaviors>
		</behaviors>

	</system.serviceModel>

	<!-- Startup Configuration -->
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
	</startup>

	<!-- System.Diagnostics for Logging -->
	<system.diagnostics>
		<sources>
			<source name="System.ServiceModel"
					switchValue="Information, ActivityTracing"
					propagateActivity="true">
				<listeners>
					<add name="traceListener"
						 type="System.Diagnostics.XmlWriterTraceListener"
						 initializeData=".\Logs\WCFTrace.svclog"/>
				</listeners>
			</source>
		</sources>
	</system.diagnostics>

	<!-- Runtime Configuration -->
	<runtime>
		<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
			<!-- Add assembly redirects if needed -->
		</assemblyBinding>
	</runtime>

</configuration>

<!--
===============================================================================
CONFIGURATION NOTES:
===============================================================================

1. CONNECTION STRING SETUP:
   - Replace SERVER_NAME with your SQL Server instance name
   - Use "localhost" or "." for local SQL Server
   - Use "SERVER_NAME\INSTANCE_NAME" for named instances
   - For SQL Authentication, uncomment the alternative connection string

2. CLIENT CODE:
   - Each client machine should have a unique ClientCode (CL001, CL002, etc.)
   - Update ClientMachineName to match the actual machine name

3. WCF ENDPOINT CONFIGURATION:
   - Default address: net.tcp://localhost:8080/SessionService
   - For network deployment, replace localhost with server IP address
   - Ensure port 8080 is open in firewall

4. SECURITY:
   - Current configuration uses security mode="None" for development
   - For production, enable Transport security with Windows authentication
   - Consider using SSL/TLS certificates for encryption

5. IMAGE STORAGE:
   - ImageStoragePath: relative path for storing captured images
   - Ensure the application has write permissions to this directory

6. PERFORMANCE TUNING:
   - Adjust maxReceivedMessageSize for large image transfers
   - Modify RefreshInterval based on network performance
   - Configure ServiceThrottling based on expected load

7. LOGGING:
   - WCF trace logs are stored in .\Logs\WCFTrace.svclog
   - Use Microsoft Service Trace Viewer to analyze logs
   - Disable detailed logging in production for performance

8. DEPLOYMENT CHECKLIST:
   ☐ Update connection string with production database
   ☐ Configure unique ClientCode for each machine
   ☐ Update ServerAddress with actual server IP
   ☐ Enable WCF Transport security
   ☐ Configure firewall rules for WCF port
   ☐ Create image and log directories
   ☐ Set appropriate file system permissions
   ☐ Test connectivity between client and server
   ☐ Disable debug logging in production

9. ALTERNATIVE BINDINGS:
   - BasicHttpBinding: Use for web service compatibility
   - WSHttpBinding: Use for advanced WS-* features
   - NetTcpBinding: Recommended for LAN (fastest performance)

10. TROUBLESHOOTING:
    - Connection errors: Check firewall and port availability
    - Authentication errors: Verify credentials and security mode
    - Large image transfer issues: Increase maxReceivedMessageSize
    - Timeout errors: Increase receiveTimeout and sendTimeout
    - Callback channel errors: Ensure DuplexBinding is configured

===============================================================================
-->