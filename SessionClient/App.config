<?xml version="1.0" encoding="utf-8" ?>
<!--
  ============================================================
  App.config for SessionClient  (copy identical file to SessionAdmin)
  Key changes from original:
    1. ServerPort   = 8001      (was 8080 — caused "cannot connect")
    2. reliableSession enabled="false"  (required for duplex callbacks)
    3. Initial Catalog = ClientServerSessionDB  (was SessionManagementDB)
    4. Image/log paths created on first run via Directory.CreateDirectory
  ============================================================
-->
<configuration>

  <!-- ── Database ─────────────────────────────────────────── -->
  <connectionStrings>
    <add name="SessionManagementDB"
         connectionString="Data Source=localhost\SQLEXPRESS;Initial Catalog=ClientServerSessionDB;Integrated Security=True;Connect Timeout=30;Encrypt=False;TrustServerCertificate=True"
         providerName="System.Data.SqlClient"/>
    <!-- SQL auth alternative:
    <add name="SessionManagementDB"
         connectionString="Data Source=localhost\SQLEXPRESS;Initial Catalog=ClientServerSessionDB;User ID=sa;Password=YOUR_PASSWORD;Connect Timeout=30;Encrypt=False;TrustServerCertificate=True"
         providerName="System.Data.SqlClient"/> -->
  </connectionStrings>

  <!-- ── Application settings ─────────────────────────────── -->
  <appSettings>
    <!-- Unique per machine: change for each client PC -->
    <add key="ClientCode"        value="CL001"/>
    <add key="ClientMachineName" value="CLIENT-PC-01"/>

    <!-- Server location -->
    <add key="ServerAddress"     value="localhost"/>
    <add key="ServerPort"        value="8001"/>

    <!-- Session limits (minutes) -->
    <add key="DefaultSessionDuration" value="60"/>
    <add key="MinSessionDuration"     value="15"/>
    <add key="MaxSessionDuration"     value="480"/>
    <add key="TimeWarningThreshold"   value="5"/>

    <!-- Webcam -->
    <add key="EnableImageCapture" value="true"/>
    <add key="ImageQuality"       value="85"/>
    <add key="ImageFormat"        value="Jpeg"/>
    <add key="ImageMaxWidth"      value="640"/>
    <add key="ImageMaxHeight"     value="480"/>
    <add key="ImageStoragePath"   value=".\Images\"/>

    <!-- Security (FR-12) -->
    <add key="EnableProxyDetection" value="true"/>
    <add key="ProxyCheckInterval"   value="60"/>
    <add key="MaxLoginAttempts"     value="3"/>
    <add key="LockoutDuration"      value="300"/>

    <!-- Billing display -->
    <add key="DefaultBillingRate" value="0.50"/>
    <add key="BillingCurrency"    value="USD"/>

    <!-- UI -->
    <add key="RefreshInterval" value="5"/>
    <add key="ShowDebugInfo"   value="false"/>
    <add key="Language"        value="en-US"/>

    <!-- Logging -->
    <add key="EnableLogging" value="true"/>
    <add key="LogLevel"      value="Info"/>
    <add key="LogPath"       value=".\Logs\"/>
	<add key="EnableKioskMode" value="false"/>
  </appSettings>

  <!-- ── WCF ──────────────────────────────────────────────── -->
  <system.serviceModel>

    <client>
      <endpoint name="SessionServiceEndpoint"
                address="net.tcp://localhost:8001/SessionService"
                binding="netTcpBinding"
                bindingConfiguration="DuplexBinding"
                contract="SessionManagement.WCF.ISessionService">
        <identity>
          <dns value="localhost"/>
        </identity>
      </endpoint>
    </client>

    <bindings>
      <netTcpBinding>
        <binding name="DuplexBinding"
                 maxReceivedMessageSize="20971520"
                 maxBufferSize="20971520"
                 receiveTimeout="00:20:00"
                 sendTimeout="00:20:00"
                 openTimeout="00:01:00"
                 closeTimeout="00:00:30">

          <readerQuotas maxDepth="32"
                        maxStringContentLength="20971520"
                        maxArrayLength="20971520"
                        maxBytesPerRead="20971520"
                        maxNameTableCharCount="16384"/>

          <!-- SecurityMode.None for development -->
          <security mode="None"/>

          <!--
            IMPORTANT: reliableSession MUST be false for duplex callbacks.
            When enabled=true the channel requires WS-ReliableMessaging which
            conflicts with the duplex session contract and causes
            "CreateSequence" errors on connect.
          -->
          <reliableSession enabled="false"/>
        </binding>
      </netTcpBinding>
    </bindings>

    <behaviors>
      <endpointBehaviors>
        <behavior name="ClientBehavior">
          <dataContractSerializer maxItemsInObjectGraph="2147483647"/>
        </behavior>
      </endpointBehaviors>
    </behaviors>

  </system.serviceModel>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
  </startup>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- Assembly redirects added automatically by NuGet restore -->
    </assemblyBinding>
  </runtime>

</configuration>
