<?xml version="1.0" encoding="utf-8" ?>
<!--
  ============================================================
  App.config for SessionClient  (copy identical file to SessionAdmin)
  Key changes from original:
    1. ServerPort   = 8001      (was 8080 — caused "cannot connect")
    2. reliableSession enabled="false"  (required for duplex callbacks)
    3. Initial Catalog = ClientServerSessionDB  (was SessionManagementDB)
    4. Image/log paths created on first run via Directory.CreateDirectory
  ============================================================
-->
<configuration>

  <!--
    NOTE: SessionClient has NO database code. All data access goes through the
    WCF service (SessionServer). There is no <connectionStrings> block here
    because this app never opens a SQL connection directly.
  -->

  <!-- ── Application settings ─────────────────────────────── -->
  <appSettings>
    <!--
      ╔══════════════════════════════════════════════════════════════════╗
      ║  MACHINE IDENTITY — SET ONCE PER PC DURING INSTALLATION         ║
      ╠══════════════════════════════════════════════════════════════════╣
      ║                                                                  ║
      ║  ClientCode  ──────────────────────────────────────────────────  ║
      ║    DO NOT change this value.  Leave it as "CL001" (the          ║
      ║    sentinel).  ResolveClientCode() in MainWindow.xaml.cs        ║
      ║    detects the sentinel and auto-derives the code as:           ║
      ║        "CL-" + MAC address  (e.g. "CL-A1B2C3D4E5F6")           ║
      ║    using the first wired-Ethernet NIC, then WiFi, then any      ║
      ║    other Up adapter.  This guarantees a globally unique,        ║
      ║    hardware-stable code for every machine with zero manual       ║
      ║    configuration.                                                ║
      ║    Only override this key if you need to force a specific code  ║
      ║    (e.g. for a VM that has no real NIC).                        ║
      ║                                                                  ║
      ║  ClientMachineName  ─────────────────────────────────────────── ║
      ║    Human-readable display name shown in the admin Clients tab.  ║
      ║    E.g. "Computer 01".  Set by the Inno Setup installer wizard. ║
      ║    Admin can rename this later from the SessionAdmin panel       ║
      ║    (Edit button) without reinstalling.                          ║
      ║                                                                  ║
      ║  ClientLocation  ───────────────────────────────────────────── ║
      ║    Physical seat / row of the machine inside the café.          ║
      ║    E.g. "Row A – Seat 1".  Set by the Inno Setup installer.    ║
      ║    Admin can update this later from the SessionAdmin panel       ║
      ║    (Edit button) without reinstalling.                          ║
      ║                                                                  ║
      ║  INNO SETUP SCRIPT REFERENCE:                                    ║
      ║    The installer wizard page must collect TWO values only:       ║
      ║      1. Machine Name  → writes ClientMachineName                 ║
      ║      2. Location      → writes ClientLocation                    ║
      ║    ClientCode must NOT be touched by the installer.              ║
      ║                                                                  ║
      ║    Example Inno Setup [Code] snippet:                            ║
      ║      // Do NOT write ClientCode — leave the sentinel "CL001"    ║
      ║      SetIniValue(ExpandConstant('{app}\SessionClient.exe.config'),║
      ║                  'appSettings', 'ClientMachineName',            ║
      ║                  MachineNamePage.Values[0]);                    ║
      ║      SetIniValue(ExpandConstant('{app}\SessionClient.exe.config'),║
      ║                  'appSettings', 'ClientLocation',               ║
      ║                  LocationPage.Values[0]);                       ║
      ║                                                                  ║
      ║  WHY NOT RUNTIME DIALOG?                                         ║
      ║    Collecting name/location at install time (admin is present)   ║
      ║    guarantees they are never blank when the app first runs and   ║
      ║    avoids any first-run detection logic inside the application.  ║
      ╚══════════════════════════════════════════════════════════════════╝
    -->
    <!-- Sentinel value — DO NOT change. ClientCode is auto-derived as "CL-<MAC>" by ResolveClientCode(). -->
    <add key="ClientCode"        value="CL001"/>
    <!-- Set by Inno Setup installer wizard — admin can rename later from SessionAdmin Edit button -->
    <add key="ClientMachineName" value="Computer 01"/>
    <!-- Set by Inno Setup installer wizard — admin can update later from SessionAdmin Edit button -->
    <add key="ClientLocation"    value="Row A – Seat 1"/>

    <!--
      ╔══════════════════════════════════════════════════════════════╗
      ║  DEPLOYMENT GUIDE — SessionClient                           ║
      ╚══════════════════════════════════════════════════════════════╝

      ── ServerAddress ────────────────────────────────────────────
      DEVELOPMENT  : leave as "localhost"  (server runs on same PC)
      PRODUCTION   : change to the server PC's LAN IP address
                     e.g. value="192.168.1.10"
      This is the ONLY value you need to change on each client PC
      when deploying to a real café network.

      ── ServerPort ───────────────────────────────────────────────
      Must match ServerPort in SessionServer/App.config.
      Only change if you changed the server port (default 8001).
    -->
	<add key="ServerAddress"     value="192.168.100.6"/>
    <add key="ServerPort"        value="8001"/>

    <!-- Session limits (minutes) -->
    <add key="DefaultSessionDuration" value="60"/>
    <add key="MinSessionDuration"     value="1"/>
    <add key="MaxSessionDuration"     value="480"/>
    <add key="TimeWarningThreshold"   value="5"/>

    <!-- Webcam -->
    <add key="EnableImageCapture" value="true"/>
    <add key="ImageQuality"       value="85"/>
    <add key="ImageFormat"        value="Jpeg"/>
    <add key="ImageMaxWidth"      value="640"/>
    <add key="ImageMaxHeight"     value="480"/>
    <add key="ImageStoragePath"   value=".\Images\"/>

    <!-- Security (FR-12) -->
    <add key="EnableProxyDetection" value="true"/>
    <add key="ProxyCheckInterval"   value="60"/>
    <add key="MaxLoginAttempts"     value="3"/>
    <add key="LockoutDuration"      value="300"/>

    <!-- Billing display -->
    <add key="DefaultBillingRate" value="0.50"/>
    <add key="BillingCurrency"    value="USD"/>

    <!-- UI -->
    <add key="RefreshInterval" value="5"/>
    <add key="ShowDebugInfo"   value="false"/>
    <add key="Language"        value="en-US"/>

    <!-- Logging -->
    <add key="EnableLogging" value="true"/>
    <add key="LogLevel"      value="Info"/>
    <add key="LogPath"       value=".\Logs\"/>

    <!-- Kiosk mode: true = lock down the OS (hide taskbar, block Alt+F4).
         Set false only on trusted machines where users need normal desktop access. -->
    <add key="EnableKioskMode" value="false"/>

    <!-- Display name shown in Windows toast notifications for this app. -->
    <add key="AppDisplayName" value="NetCafé Session Client"/>
  </appSettings>

  <!-- ── WCF ──────────────────────────────────────────────── -->
  <system.serviceModel>

    <client>
      <!--
        Address here is a FALLBACK only.
        SessionServiceClient.Connect() overrides it at runtime using
        the ServerAddress / ServerPort appSettings above.
        To point this client at a different server PC, change ServerAddress.
        SecurityMode=None means the <identity><dns> element is not enforced.
      -->
      <endpoint name="SessionServiceEndpoint"
                address="net.tcp://localhost:8001/SessionService"
                binding="netTcpBinding"
                bindingConfiguration="DuplexBinding"
                contract="SessionManagement.WCF.ISessionService">
        <identity>
          <dns value="localhost"/>
        </identity>
      </endpoint>
    </client>

    <bindings>
      <netTcpBinding>
        <binding name="DuplexBinding"
                 maxReceivedMessageSize="20971520"
                 maxBufferSize="20971520"
                 receiveTimeout="00:20:00"
                 sendTimeout="00:20:00"
                 openTimeout="00:01:00"
                 closeTimeout="00:00:30">

          <readerQuotas maxDepth="32"
                        maxStringContentLength="20971520"
                        maxArrayLength="20971520"
                        maxBytesPerRead="20971520"
                        maxNameTableCharCount="16384"/>

          <!-- SecurityMode.None for development -->
          <security mode="None"/>

          <!--
            IMPORTANT: reliableSession MUST be false for duplex callbacks.
            When enabled=true the channel requires WS-ReliableMessaging which
            conflicts with the duplex session contract and causes
            "CreateSequence" errors on connect.
          -->
          <reliableSession enabled="false"/>
        </binding>
      </netTcpBinding>
    </bindings>

    <behaviors>
      <endpointBehaviors>
        <behavior name="ClientBehavior">
          <dataContractSerializer maxItemsInObjectGraph="2147483647"/>
        </behavior>
      </endpointBehaviors>
    </behaviors>

  </system.serviceModel>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
  </startup>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- Assembly redirects added automatically by NuGet restore -->
    </assemblyBinding>
  </runtime>

</configuration>
