<Window x:Class="SessionClient.FloatingTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="app.ico"
        Title="Session Timer"
        Height="90" Width="230"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="16"
            Margin="4"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A2035" Offset="0"/>
                <GradientStop Color="#0F1117" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>

        <Grid Margin="12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top row: status + restore button -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#34D399"
                             VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#34D399" BlurRadius="6"
                                              ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="Session Active" FontSize="9" FontWeight="SemiBold"
                               Foreground="#475569" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="btnRestore" Content="⤢" Width="22" Height="22"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#475569" FontSize="12" Cursor="Hand"
                        ToolTip="Restore timer window"
                        Click="BtnRestore_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="r" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Width="22" Height="22">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="r" Property="Background" Value="#1E2433"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Timer display -->
            <Grid Grid.Row="1" VerticalAlignment="Center">
                <TextBlock x:Name="txtTime" Text="00:00:00"
                           FontSize="30" FontWeight="Bold"
                           FontFamily="Segoe UI Mono"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#4F8EF7" Offset="0"/>
                            <GradientStop Color="#6366F1" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#4F8EF7" BlurRadius="8"
                                          ShadowDepth="0" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</Window>
