<Window x:Class="SessionClient.FloatingTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Timer" Height="80" Width="220"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" Background="#FF23272E" AllowsTransparency="True" 
        Opacity="0.95">
    <Border CornerRadius="12" Background="#FF2D3A4A" Padding="10">
        <Grid>
            <TextBlock x:Name="txtTime" Text="00:00:00" FontSize="28" FontWeight="Bold" Foreground="#FF00FF99" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button x:Name="btnRestore" Content="⤢" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0" ToolTip="Restore Timer Window"/>
        </Grid>
    </Border>
</Window>
