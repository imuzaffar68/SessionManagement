<Application x:Class="SessionAdmin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SessionAdmin"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ═══════════════════════════════════════════════════════════════
                 DESIGN TOKENS — Final Hybrid (V3 dark palette)
                 These are the ONLY place colors are defined. All windows
                 reference these keys; nothing is hardcoded inline.
            ═══════════════════════════════════════════════════════════════════ -->

            <!-- Background layers (darkest → lightest) -->
            <SolidColorBrush x:Key="BgDeep"      Color="#0F1117"/>
            <SolidColorBrush x:Key="BgSidebar"   Color="#13161F"/>
            <SolidColorBrush x:Key="BgCard"      Color="#171B26"/>
            <SolidColorBrush x:Key="BgElevated"  Color="#1E2433"/>
            <SolidColorBrush x:Key="BgHover"     Color="#252D42"/>

            <!-- Borders -->
            <SolidColorBrush x:Key="BorderColor" Color="#2D3748"/>
            <SolidColorBrush x:Key="BorderSoft"  Color="#1E2433"/>

            <!-- Accent palette -->
            <SolidColorBrush x:Key="AccentBlue"   Color="#4F8EF7"/>
            <SolidColorBrush x:Key="AccentHot"    Color="#6EA6FF"/>
            <SolidColorBrush x:Key="AccentGreen"  Color="#34D399"/>
            <SolidColorBrush x:Key="AccentAmber"  Color="#FBBF24"/>
            <SolidColorBrush x:Key="AccentRed"    Color="#F87171"/>
            <SolidColorBrush x:Key="AccentPurple" Color="#A78BFA"/>

            <!-- Typography -->
            <SolidColorBrush x:Key="TextPrimary"   Color="#F1F5F9"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
            <SolidColorBrush x:Key="TextMuted"     Color="#475569"/>

            <!-- ═══════════════════════════════════════════════════════════════
                 GLOBAL FONT DEFAULT
            ═══════════════════════════════════════════════════════════════════ -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 SCROLLBAR — thin, unobtrusive
            ═══════════════════════════════════════════════════════════════════ -->
            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width"      Value="6"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 CARD BORDERS
            ═══════════════════════════════════════════════════════════════════ -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background"       Value="{StaticResource BgCard}"/>
                <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="CornerRadius"     Value="12"/>
                <Setter Property="Padding"          Value="20"/>
            </Style>

            <Style x:Key="CardElevated" TargetType="Border" BasedOn="{StaticResource Card}">
                <Setter Property="Background" Value="{StaticResource BgElevated}"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 BADGE STYLES  (for status chips inside cards / DataGrid)
            ═══════════════════════════════════════════════════════════════════ -->
            <Style x:Key="BadgeGreen" TargetType="Border">
                <Setter Property="Background"      Value="#064E3B"/>
                <Setter Property="BorderBrush"     Value="#065F46"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="6"/>
                <Setter Property="Padding"         Value="8,3"/>
            </Style>
            <Style x:Key="BadgeRed" TargetType="Border">
                <Setter Property="Background"      Value="#450A0A"/>
                <Setter Property="BorderBrush"     Value="#7F1D1D"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="6"/>
                <Setter Property="Padding"         Value="8,3"/>
            </Style>
            <Style x:Key="BadgeAmber" TargetType="Border">
                <Setter Property="Background"      Value="#451A03"/>
                <Setter Property="BorderBrush"     Value="#78350F"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="6"/>
                <Setter Property="Padding"         Value="8,3"/>
            </Style>
            <Style x:Key="BadgeBlue" TargetType="Border">
                <Setter Property="Background"      Value="#1E3A5F"/>
                <Setter Property="BorderBrush"     Value="#1D4ED8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="6"/>
                <Setter Property="Padding"         Value="8,3"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 SECTION LABEL  (uppercase group headers inside sidebar)
            ═══════════════════════════════════════════════════════════════════ -->
            <Style x:Key="SectionLabel" TargetType="TextBlock">
                <Setter Property="FontSize"     Value="10"/>
                <Setter Property="FontWeight"   Value="SemiBold"/>
                <Setter Property="Foreground"   Value="{StaticResource TextMuted}"/>
                <Setter Property="Margin"       Value="0,0,0,6"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 SIDEBAR NAV BUTTONS
                 NavBtn        = default (inactive) state
                 NavBtnActive  = currently selected page
            ═══════════════════════════════════════════════════════════════════ -->
            <Style x:Key="NavBtn" TargetType="Button">
                <Setter Property="Background"              Value="Transparent"/>
                <Setter Property="BorderThickness"         Value="0"/>
                <Setter Property="Foreground"              Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontFamily"              Value="Segoe UI"/>
                <Setter Property="FontSize"                Value="13.5"/>
                <Setter Property="Height"                  Value="46"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding"                 Value="16,0"/>
                <Setter Property="Cursor"                  Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" Background="Transparent"
                                    CornerRadius="10" Margin="6,2"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#1E293B"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#253048"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
                <Setter Property="Foreground"  Value="{StaticResource AccentBlue}"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" CornerRadius="10" Margin="6,2"
                                    Padding="{TemplateBinding Padding}"
                                    BorderThickness="2,0,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1A2E4A" Offset="0"/>
                                        <GradientStop Color="#0F1117" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#4F8EF7" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 ACTION BUTTONS
            ═══════════════════════════════════════════════════════════════════ -->

            <!-- Primary (blue) -->
            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background"    Value="#4F8EF7"/>
                <Setter Property="Foreground"    Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily"    Value="Segoe UI"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="FontWeight"    Value="SemiBold"/>
                <Setter Property="Padding"       Value="20,9"/>
                <Setter Property="Cursor"        Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#6EA6FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#3A7AE0"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Danger (red) -->
            <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                <Setter Property="Background" Value="#DC2626"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#EF4444"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Success (green) -->
            <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                <Setter Property="Background" Value="#059669"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#10B981"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Ghost (dark neutral) -->
            <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                <Setter Property="Background" Value="#1E2433"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#252D42"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Amber (warning) -->
            <Style x:Key="BtnAmber" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                <Setter Property="Background" Value="#B45309"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#D97706"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Purple -->
            <Style x:Key="BtnPurple" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                <Setter Property="Background" Value="#7C3AED"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#8B5CF6"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 FORM INPUTS  (Redesign quality: rounded, dark, blue focus ring)
            ═══════════════════════════════════════════════════════════════════ -->
            <Style x:Key="ModernInput" TargetType="TextBox">
                <Setter Property="Background"    Value="#1E2433"/>
                <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
                <Setter Property="BorderBrush"   Value="#2D3748"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily"    Value="Segoe UI"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="Padding"       Value="12,8"/>
                <Setter Property="CaretBrush"    Value="#4F8EF7"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#4F8EF7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernPassword" TargetType="PasswordBox">
                <Setter Property="Background"    Value="#1E2433"/>
                <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
                <Setter Property="BorderBrush"   Value="#2D3748"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily"    Value="Segoe UI"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="Padding"       Value="12,8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#4F8EF7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernCombo" TargetType="ComboBox">
                <Setter Property="Background"    Value="#1E2433"/>
                <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
                <Setter Property="BorderBrush"   Value="#2D3748"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily"    Value="Segoe UI"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="Padding"       Value="10,7"/>
                <Setter Property="Height"        Value="38"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 SHOW-PASSWORD BUTTON  (Redesign style: styled, not bare emoji)
            ═══════════════════════════════════════════════════════════════════ -->
            <Style x:Key="ShowPasswordBtn" TargetType="Button">
                <Setter Property="Background"    Value="#1E2433"/>
                <Setter Property="Foreground"    Value="{StaticResource TextMuted}"/>
                <Setter Property="BorderBrush"   Value="#2D3748"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize"      Value="15"/>
                <Setter Property="Cursor"        Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#252D42"/>
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#4F8EF7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 DATAGRID  (implicit styles — apply to all DataGrid controls)
            ═══════════════════════════════════════════════════════════════════ -->
            <Style TargetType="DataGrid">
                <Setter Property="Background"             Value="Transparent"/>
                <Setter Property="BorderThickness"        Value="0"/>
                <Setter Property="RowBackground"          Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="#0D1420"/>
                <Setter Property="GridLinesVisibility"    Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#1E2433"/>
                <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
                <Setter Property="FontFamily"             Value="Segoe UI"/>
                <Setter Property="FontSize"               Value="12.5"/>
                <Setter Property="Foreground"             Value="{StaticResource TextPrimary}"/>
                <Setter Property="RowHeight"              Value="44"/>
                <Setter Property="SelectionMode"          Value="Single"/>
                <Setter Property="CanUserResizeRows"      Value="False"/>
                <Setter Property="HeadersVisibility"      Value="Column"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"      Value="#1E2433"/>
                <Setter Property="Foreground"      Value="#94A3B8"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="FontSize"        Value="11"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Padding"         Value="14,10"/>
                <Setter Property="BorderBrush"     Value="#2D3748"/>
                <Setter Property="BorderThickness" Value="0,0,0,2"/>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1A2030"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#1D3461"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="14,0"/>
                <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 MISC CONTROLS
            ═══════════════════════════════════════════════════════════════════ -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground"            Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontFamily"            Value="Segoe UI"/>
                <Setter Property="FontSize"              Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style TargetType="DatePicker">
                <Setter Property="Background"    Value="#1E2433"/>
                <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
                <Setter Property="BorderBrush"   Value="#2D3748"/>
                <Setter Property="FontFamily"    Value="Segoe UI"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="Height"        Value="38"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
