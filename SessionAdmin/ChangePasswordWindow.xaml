<Window x:Class="SessionAdmin.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="app.ico"
        WindowStyle="None" AllowsTransparency="False"
        Height="Auto" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117">

    <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ── -->
            <Border Grid.Row="0" Background="#0D0F17"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/SessionAdmin;component/app.ico"
                               Width="14" Height="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="🔐" FontSize="13" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Change Admin Password"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#94A3B8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="btnWindowClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Content ── -->
            <Border Grid.Row="1" Background="#171B26">
                <StackPanel Margin="28,22,28,28">

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0C4A6E" Offset="0"/>
                                    <GradientStop Color="#0284C7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🔐" FontSize="18" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="lblAdminName" Text="Admin"
                                       FontSize="16" FontWeight="Bold" Foreground="#F1F5F9"/>
                            <TextBlock Text="Change your admin password"
                                       FontSize="11" Foreground="#475569"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Current Password -->
                    <TextBlock Text="CURRENT PASSWORD" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="txtCurrentPassword" Grid.Column="0"
                                     Style="{StaticResource ModernPassword}" Height="40"
                                     Tag="Current password"/>
                        <TextBox x:Name="txtCurrentPasswordPlain" Grid.Column="0"
                                 Style="{StaticResource ModernInput}" Height="40"
                                 Visibility="Collapsed" Tag="Current password"/>
                        <Button x:Name="btnShowCurrent" Grid.Column="1"
                                Content="👁" Style="{StaticResource ShowPasswordBtn}"
                                Height="40" Margin="4,0,0,0"
                                Click="btnShowCurrent_Click"/>
                    </Grid>
                    <TextBlock x:Name="errCurrent" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- New Password -->
                    <TextBlock Text="NEW PASSWORD" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="txtNewPassword" Grid.Column="0"
                                     Style="{StaticResource ModernPassword}" Height="40"
                                     Tag="New password"/>
                        <TextBox x:Name="txtNewPasswordPlain" Grid.Column="0"
                                 Style="{StaticResource ModernInput}" Height="40"
                                 Visibility="Collapsed" Tag="New password"/>
                        <Button x:Name="btnShowNew" Grid.Column="1"
                                Content="👁" Style="{StaticResource ShowPasswordBtn}"
                                Height="40" Margin="4,0,0,0"
                                Click="btnShowNew_Click"/>
                    </Grid>
                    <TextBlock x:Name="errNew" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Confirm Password -->
                    <TextBlock Text="CONFIRM NEW PASSWORD" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="txtConfirmPassword" Grid.Column="0"
                                     Style="{StaticResource ModernPassword}" Height="40"
                                     Tag="Confirm new password"/>
                        <TextBox x:Name="txtConfirmPasswordPlain" Grid.Column="0"
                                 Style="{StaticResource ModernInput}" Height="40"
                                 Visibility="Collapsed" Tag="Confirm new password"/>
                        <Button x:Name="btnShowConfirm" Grid.Column="1"
                                Content="👁" Style="{StaticResource ShowPasswordBtn}"
                                Height="40" Margin="4,0,0,0"
                                Click="btnShowConfirm_Click"/>
                    </Grid>
                    <TextBlock x:Name="errConfirm" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <TextBlock Text="Min 8 chars · uppercase · lowercase · digit"
                               FontSize="10" Foreground="#475569"
                               Margin="0,8,0,10"/>

                    <!-- Error -->
                    <Border x:Name="lblErrorBorder" Background="#2D0A0A" CornerRadius="8"
                            BorderBrush="#7F1D1D" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,14" Visibility="Collapsed">
                        <TextBlock x:Name="lblError" Foreground="#FCA5A5"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnCancel" Content="Cancel"
                                Style="{StaticResource BtnGhost}"
                                Height="38" Width="100" Margin="0,0,8,0"
                                Click="btnCancel_Click"/>
                        <Button x:Name="btnChange" Content="Change Password"
                                Style="{StaticResource BtnPrimary}"
                                Height="38" Width="150"
                                Click="btnChange_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
