<Window x:Class="SessionAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Management - Admin Dashboard" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#34495E" Padding="20">
            <Grid>
                <TextBlock Text="Admin Dashboard - Session Management System" 
                          Foreground="White" 
                          FontSize="24" 
                          FontWeight="Bold"
                          VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="lblAdminUser" 
                              Text="Admin: " 
                              Foreground="White" 
                              FontSize="14" 
                              VerticalAlignment="Center"
                              Margin="0,0,20,0"/>
                    <Button x:Name="btnLogout" 
                           Content="Logout" 
                           Height="30" 
                           Width="80" 
                           Background="#E74C3C" 
                           Foreground="White"
                           Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Login Panel -->
        <Grid x:Name="LoginPanel" Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <TextBlock Text="Admin Login" FontSize="28" FontWeight="Bold" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <TextBlock Text="Username:" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="txtAdminUsername" Height="35" FontSize="14" Padding="10,5"/>

                <TextBlock Text="Password:" FontSize="14" Margin="0,20,0,5"/>
                <PasswordBox x:Name="txtAdminPassword" Height="35" FontSize="14" Padding="10,5"/>

                <TextBlock x:Name="lblAdminLoginError" 
                          Foreground="Red" 
                          FontSize="12" 
                          Margin="0,10,0,0" 
                          Visibility="Collapsed"/>

                <Button x:Name="btnAdminLogin" 
                       Content="Login" 
                       Height="40" 
                       Margin="0,30,0,0" 
                       Background="#3498DB" 
                       Foreground="White" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Click="btnAdminLogin_Click"/>
            </StackPanel>
        </Grid>

        <!-- Dashboard Panel -->
        <Grid x:Name="DashboardPanel" Grid.Row="1" Margin="20" Visibility="Collapsed">
            <TabControl>
                <!-- Active Sessions Tab -->
                <TabItem Header="Active Sessions">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,10,0,20">
                            <TextBlock Text="Active Sessions Monitor" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total Active Sessions: " FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock x:Name="lblActiveCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="#27AE60"/>
                                <Button x:Name="btnRefreshSessions" 
                                       Content="Refresh" 
                                       Height="30" 
                                       Width="100" 
                                       Margin="20,0,0,0"
                                       Click="btnRefreshSessions_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <DataGrid Grid.Row="1" 
                                 x:Name="dgActiveSessions" 
                                 AutoGenerateColumns="False" 
                                 IsReadOnly="True"
                                 SelectionMode="Single"
                                 CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Client ID" Binding="{Binding ClientId}" Width="100"/>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime}" Width="150"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="100"/>
                                <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingTime}" Width="100"/>
                                <DataGridTextColumn Header="Billing ($)" Binding="{Binding CurrentBilling}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                <DataGridTemplateColumn Header="Actions" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Terminate" 
                                                   Background="#E74C3C" 
                                                   Foreground="White"
                                                   Click="btnTerminateSession_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Background="#ECF0F1" Padding="15" Margin="0,10,0,0">
                            <TextBlock x:Name="lblLastUpdate" 
                                      Text="Last updated: --" 
                                      FontSize="12" 
                                      Foreground="#7F8C8D"/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Client List Tab -->
                <TabItem Header="Client Status">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                  Text="All Clients Status" 
                                  FontSize="20" 
                                  FontWeight="Bold" 
                                  Margin="0,10,0,20"/>

                        <DataGrid Grid.Row="1" 
                                 x:Name="dgClients" 
                                 AutoGenerateColumns="False" 
                                 IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Client ID" Binding="{Binding ClientId}" Width="120"/>
                                <DataGridTextColumn Header="Machine Name" Binding="{Binding MachineName}" Width="200"/>
                                <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="150"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                <DataGridTextColumn Header="Current User" Binding="{Binding CurrentUser}" Width="150"/>
                                <DataGridTextColumn Header="Last Active" Binding="{Binding LastActive}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Alerts Tab -->
                <TabItem Header="Security Alerts">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,10,0,20">
                            <TextBlock Text="Security Alerts" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Unresolved Alerts: " FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock x:Name="lblAlertCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="#E74C3C"/>
                            </StackPanel>
                        </StackPanel>

                        <DataGrid Grid.Row="1" 
                                 x:Name="dgAlerts" 
                                 AutoGenerateColumns="False" 
                                 IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150"/>
                                <DataGridTextColumn Header="Client ID" Binding="{Binding ClientId}" Width="100"/>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                                <DataGridTextColumn Header="Alert Type" Binding="{Binding AlertType}" Width="200"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTemplateColumn Header="Actions" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Acknowledge" 
                                                   Background="#3498DB" 
                                                   Foreground="White"
                                                   Click="btnAcknowledgeAlert_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Reports Tab -->
                <TabItem Header="Reports">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,10,0,20">
                            <TextBlock Text="Generate Reports" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Report Type:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Grid.Column="1" x:Name="cboReportType" SelectedIndex="0" Height="30">
                                    <ComboBoxItem Content="Session Usage"/>
                                    <ComboBoxItem Content="Billing Summary"/>
                                    <ComboBoxItem Content="Security Alerts"/>
                                </ComboBox>

                                <TextBlock Grid.Column="2" Text="From:" VerticalAlignment="Center" Margin="20,0,10,0"/>
                                <DatePicker Grid.Column="3" x:Name="dpFromDate" Height="30"/>

                                <TextBlock Grid.Column="4" Text="To:" VerticalAlignment="Center" Margin="20,0,10,0"/>
                                <DatePicker Grid.Column="5" x:Name="dpToDate" Height="30"/>

                                <Button Grid.Column="6" 
                                       x:Name="btnGenerateReport" 
                                       Content="Generate Report" 
                                       Height="35" 
                                       Width="150"
                                       Margin="20,0,0,0"
                                       Background="#27AE60" 
                                       Foreground="White"
                                       Click="btnGenerateReport_Click"/>
                            </Grid>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="20">
                            <ScrollViewer>
                                <TextBlock x:Name="txtReportOutput" 
                                          FontFamily="Consolas" 
                                          FontSize="12"
                                          Text="Report output will appear here..."/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>