<Window x:Class="SessionAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Management - Admin Dashboard"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#34495E" Padding="16">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Admin Dashboard — Session Management System"
                               Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <!-- Connection Status Indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0">
                    <Ellipse x:Name="ellipseConnectionStatus" Width="14" Height="14" Fill="Red" Stroke="Black" StrokeThickness="1" Margin="0,0,8,0"/>
                    <TextBlock x:Name="lblConnectionStatus" Text="Disconnected" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    <Button x:Name="btnConnect" Content="Connect" Height="20" Width="60" Margin="8,0,0,0" Visibility="Collapsed" Click="btnConnect_Click"/>
                </StackPanel>
                <StackPanel x:Name="AdminHeaderPanel" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="lblAdminUser" Text="Admin: —"
                               Foreground="#BDC3C7" FontSize="13" Margin="0,0,20,0"/>
                    <Button x:Name="btnLogout" Content="Logout"
                            Height="28" Width="76"
                            Background="#E74C3C" Foreground="White"
                            Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LOGIN PANEL (UC-09) -->
        <Grid x:Name="LoginPanel" Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="Admin Login" FontSize="26" FontWeight="Bold"
                           Margin="0,0,0,24" HorizontalAlignment="Center"/>

                <TextBlock Text="Username:" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="txtAdminUsername" Height="34" FontSize="13" Padding="8,4"/>

                <TextBlock Text="Password:" FontSize="13" Margin="0,14,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="txtAdminPassword" Grid.Column="0"
                                 Height="34" FontSize="13" Padding="8,4"/>
                    <TextBox    x:Name="txtAdminPasswordPlain" Grid.Column="0"
                                Height="34" FontSize="13" Padding="8,4"
                                Visibility="Collapsed"/>
                    <Button x:Name="btnShowAdminPassword" Grid.Column="1"
                            Content="👁" FontSize="15"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#3498DB" Margin="4,0,0,0"
                            Click="btnShowAdminPassword_Click"/>
                </Grid>

                <TextBlock x:Name="lblAdminLoginError" Foreground="Red" FontSize="11"
                           Margin="0,8,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                <Button x:Name="btnAdminLogin" Content="Login" Height="38"
                        Margin="0,22,0,0" Background="#3498DB" Foreground="White"
                        FontSize="15" FontWeight="Bold" Click="btnAdminLogin_Click"/>
            </StackPanel>
        </Grid>

        <!-- DASHBOARD PANEL -->
        <Grid x:Name="DashboardPanel" Grid.Row="1" Margin="12" Visibility="Collapsed">
            <TabControl>

                <!-- TAB 1: Active Sessions (UC-10 / UC-14) -->
                <TabItem Header="Active Sessions">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8,0,10">
                            <TextBlock Text="Active Sessions" FontSize="18" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="Total:" FontSize="13" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock x:Name="lblActiveCount" Text="0" FontSize="13"
                                       FontWeight="Bold" Foreground="#27AE60"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <Button x:Name="btnRefreshSessions" Content="Refresh"
                                    Height="28" Width="90" Click="btnRefreshSessions_Click"/>
                            <Button x:Name="btnViewImage" Content="View Image"
                                    Height="28" Width="100" Margin="8,0,0,0"
                                    Background="#8E44AD" Foreground="White"
                                    Click="btnViewImage_Click"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" x:Name="dgActiveSessions"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Session ID" Binding="{Binding SessionId}"     Width="80"/>
                                <DataGridTextColumn Header="Client"     Binding="{Binding ClientId}"      Width="90"/>
                                <DataGridTextColumn Header="Username"   Binding="{Binding Username}"      Width="130"/>
                                <DataGridTextColumn Header="Start"      Binding="{Binding StartTime}"     Width="120"/>
                                <DataGridTextColumn Header="Duration"   Binding="{Binding Duration}"      Width="80"/>
                                <DataGridTextColumn Header="Remaining"  Binding="{Binding RemainingTime}" Width="90"/>
                                <DataGridTextColumn Header="Billing"    Binding="{Binding CurrentBilling}" Width="90"/>
                                <DataGridTextColumn Header="Status"     Binding="{Binding Status}"        Width="90"/>
                                <DataGridTemplateColumn Header="Actions" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Terminate"
                                                    Background="#E74C3C" Foreground="White"
                                                    Margin="2" Padding="6,2"
                                                    Click="btnTerminateSession_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Background="#ECF0F1" Padding="10" Margin="0,6,0,0">
                            <TextBlock x:Name="lblLastUpdate" Text="Last updated: —"
                                       FontSize="11" Foreground="#7F8C8D"/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 2: Client Status (UC-11) -->
                <TabItem Header="Client Status">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="All Client Machines" FontSize="18"
                                   FontWeight="Bold" Margin="0,8,0,10"/>
                        <DataGrid Grid.Row="1" x:Name="dgClients"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code"         Binding="{Binding ClientId}"    Width="90"/>
                                <DataGridTextColumn Header="Machine"      Binding="{Binding MachineName}" Width="160"/>
                                <DataGridTextColumn Header="IP Address"   Binding="{Binding IpAddress}"   Width="130"/>
                                <DataGridTextColumn Header="MAC Address"  Binding="{Binding MacAddress}"  Width="130"/>
                                <DataGridTextColumn Header="Location"     Binding="{Binding Location}"    Width="130"/>
                                <DataGridTextColumn Header="Session Status"       Binding="{Binding Status}"      Width="90"/>
                                <DataGridTextColumn Header="Machine Status" Binding="{Binding ClientMachineStatus}" Width="90"/>
                                <DataGridTextColumn Header="Current User" Binding="{Binding CurrentUser}" Width="140"/>
                                <DataGridTextColumn Header="Last Seen"    Binding="{Binding LastActive}"  Width="*"/>
                                <DataGridTemplateColumn Header="Actions" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="2">
                                                <!-- Enable Button -->
                                                <Button Content="Enable"
                                                    Background="#27AE60" Foreground="White"
                                                    Padding="6,2" Margin="2"
                                                    Click="btnEnableClient_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <!-- If Active → Hide Enable -->
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Disable Button -->
                                                <Button Content="Disable"
                                                    Background="#E74C3C" Foreground="White"
                                                    Padding="6,2" Margin="2"
                                                    Click="btnDisableClient_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <!-- If NOT Active → Hide Disable -->
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- TAB 3: User Management (UC-03) -->
                <TabItem Header="User Management">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Registration Form -->
                        <Border Grid.Row="0" Background="#ECF0F1" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Register New Client User" FontSize="16" 
                                           FontWeight="Bold" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: Username and Full Name -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <TextBox x:Name="txtUsername" Grid.Row="0" Grid.Column="1"
                                             Height="28" Margin="0,0,16,8" Padding="6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Full Name:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <TextBox x:Name="txtFullName" Grid.Row="0" Grid.Column="3"
                                             Height="28" Margin="0,0,0,8" Padding="6"/>

                                    <!-- Row 2: Password and Phone -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Password:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <PasswordBox x:Name="txtPassword" Grid.Row="1" Grid.Column="1"
                                                 Height="28" Margin="0,0,16,8" Padding="6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Phone:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <TextBox x:Name="txtPhone" Grid.Row="1" Grid.Column="3"
                                             Height="28" Margin="0,0,0,8" Padding="6"/>

                                    <!-- Row 3: Address and Buttons -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Address:" 
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="txtAddress" Grid.Row="2" Grid.Column="1"
                                             Grid.ColumnSpan="3" Height="28" Padding="6"/>
                                </Grid>

                                <TextBlock x:Name="lblRegError" Foreground="Red" FontSize="11"
                                           Margin="0,12,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                                <TextBlock x:Name="lblRegSuccess" Foreground="Green" FontSize="11"
                                           Margin="0,12,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="btnRegisterUser" Content="Register User"
                                            Height="32" Width="140" Background="#27AE60" 
                                            Foreground="White" Click="btnRegisterUser_Click"/>
                                    <Button x:Name="btnClearForm" Content="Clear" 
                                            Height="32" Width="80" Margin="8,0,0,0"
                                            Click="btnClearForm_Click"/>
                                    <Button x:Name="btnGeneratePassword" Content="Generate Pwd (User@123456)"
                                            Height="32" Width="180" Margin="8,0,0,0"
                                            Background="#9B59B6" Foreground="White"
                                            Click="btnGeneratePassword_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- User List -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Registered Client Users" FontSize="16" 
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock Text="Total:" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="lblUserCount" Text="0" FontSize="12"
                                           FontWeight="Bold" Foreground="#27AE60" VerticalAlignment="Center"/>
                                <Button x:Name="btnRefreshUsers" Content="Refresh"
                                        Height="28" Width="90" Margin="16,0,0,0"
                                        Click="btnRefreshUsers_Click"/>
                            </StackPanel>
                            <DataGrid Grid.Row="1" x:Name="dgUsers"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="User ID"     Binding="{Binding UserId}"    Width="70"/>
                                    <DataGridTextColumn Header="Username"    Binding="{Binding Username}"  Width="130"/>
                                    <DataGridTextColumn Header="Full Name"   Binding="{Binding FullName}"  Width="160"/>
                                    <DataGridTextColumn Header="Phone"       Binding="{Binding Phone}"     Width="120"/>
                                    <DataGridTextColumn Header="Address"     Binding="{Binding Address}"   Width="200"/>
                                    <DataGridTextColumn Header="Status"      Binding="{Binding Status}"    Width="80"/>
                                    <DataGridTextColumn Header="Created"     Binding="{Binding CreatedAt}" Width="150"/>
                                    <DataGridTextColumn Header="Last Login"  Binding="{Binding LastLogin}" Width="150"/>
                                    <DataGridTemplateColumn Header="Actions" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                                    <!-- Edit Button -->
                                                    <Button Content="✎" Height="28" Width="28"
                                                            Background="#3498DB" Foreground="White"
                                                            Click="btnEditUserInline_Click"
                                                            ToolTip="Edit User Details"/>
                                                    <!-- Reset Password Button -->
                                                    <Button Content="🔑" Height="28" Width="28" Margin="4,0,0,0"
                                                            Background="#9B59B6" Foreground="White"
                                                            Click="btnResetPasswordInline_Click"
                                                            ToolTip="Reset Password"/>
                                                    <!-- Toggle Status Button -->
                                                    <Button Content="⊕" Height="28" Width="28" Margin="4,0,0,0"
                                                            Background="#27AE60" Foreground="White"
                                                            Click="btnToggleStatusInline_Click"
                                                            ToolTip="Toggle User Status (Active/Disabled)"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- User Actions Status Panel -->
                            <Border Grid.Row="2" Background="#ECF0F1" Padding="16" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="lblUserActionError" Foreground="Red" FontSize="11"
                                               Margin="0,0,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="lblUserActionSuccess" Foreground="Green" FontSize="11"
                                               Margin="0,0,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 4: Security Alerts (UC-17) -->
                <TabItem Header="Security Alerts">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8,0,10">
                            <TextBlock Text="Security Alerts" FontSize="18" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="Unresolved:" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="lblAlertCount" Text="0" FontSize="13"
                                       FontWeight="Bold" Foreground="#E74C3C"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1" x:Name="dgAlerts"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time"        Binding="{Binding Timestamp}"   Width="150"/>
                                <DataGridTextColumn Header="Severity"    Binding="{Binding Severity}"    Width="80"/>
                                <DataGridTextColumn Header="Client"      Binding="{Binding ClientId}"    Width="90"/>
                                <DataGridTextColumn Header="Username"    Binding="{Binding Username}"    Width="120"/>
                                <DataGridTextColumn Header="Type"        Binding="{Binding AlertType}"   Width="180"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTemplateColumn Header="Action"  Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Acknowledge"
                                                    Background="#3498DB" Foreground="White"
                                                    Margin="2" Padding="6,2"
                                                    Click="btnAcknowledgeAlert_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- TAB 5: Session Logs (UC-15) -->
                <TabItem Header="Session Logs">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,8,0,10">
                            <TextBlock Text="Session &amp; System Logs" FontSize="18"
                                       FontWeight="Bold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="From:" VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <DatePicker x:Name="dpLogFrom" Height="28" Width="130"/>
                                <TextBlock Text="To:" VerticalAlignment="Center"
                                           Margin="12,0,6,0"/>
                                <DatePicker x:Name="dpLogTo" Height="28" Width="130"/>
                                <ComboBox x:Name="cboLogCategory" Height="28" Width="130"
                                          Margin="12,0,0,0" SelectedIndex="0">
                                    <ComboBoxItem Content="All"/>
                                    <ComboBoxItem Content="Auth"/>
                                    <ComboBoxItem Content="Session"/>
                                    <ComboBoxItem Content="Billing"/>
                                    <ComboBoxItem Content="Security"/>
                                    <ComboBoxItem Content="System"/>
                                </ComboBox>
                                <Button x:Name="btnLoadLogs" Content="Load Logs"
                                        Height="28" Width="90" Margin="8,0,0,0"
                                        Background="#27AE60" Foreground="White"
                                        Click="btnLoadLogs_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <DataGrid Grid.Row="1" x:Name="dgLogs"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time"     Binding="{Binding LogTime}"    Width="150"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}"   Width="90"/>
                                <DataGridTextColumn Header="Type"     Binding="{Binding LogType}"    Width="160"/>
                                <DataGridTextColumn Header="Source"   Binding="{Binding Source}"     Width="60"/>
                                <DataGridTextColumn Header="Client"   Binding="{Binding ClientCode}" Width="80"/>
                                <DataGridTextColumn Header="User"     Binding="{Binding Username}"   Width="110"/>
                                <DataGridTextColumn Header="Message"  Binding="{Binding Message}"    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- TAB 6: Reports (UC-18) -->
                <TabItem Header="Reports">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,8,0,12">
                            <TextBlock Text="Generate Reports" FontSize="18"
                                       FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Type:" VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <ComboBox x:Name="cboReportType" Height="28" Width="160"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Session Usage"/>
                                    <ComboBoxItem Content="Billing Summary"/>
                                    <ComboBoxItem Content="Security Alerts"/>
                                </ComboBox>
                                <TextBlock Text="From:" VerticalAlignment="Center"
                                           Margin="14,0,6,0"/>
                                <DatePicker x:Name="dpFromDate" Height="28" Width="130"/>
                                <TextBlock Text="To:" VerticalAlignment="Center"
                                           Margin="12,0,6,0"/>
                                <DatePicker x:Name="dpToDate" Height="28" Width="130"/>
                                <Button x:Name="btnGenerateReport" Content="Generate"
                                        Height="28" Width="90" Margin="12,0,0,0"
                                        Background="#27AE60" Foreground="White"
                                        Click="btnGenerateReport_Click"/>
                                <Button x:Name="btnExportReport" Content="Export .txt"
                                        Height="28" Width="90" Margin="6,0,0,0"
                                        Click="btnExportReport_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="1"
                                Padding="16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="txtReportOutput"
                                           FontFamily="Consolas" FontSize="12"
                                           Text="Report output will appear here…"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 7: Billing Rates Management -->
                <TabItem Header="Billing Rates">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Add/Edit Billing Rate Form -->
                        <Border Grid.Row="0" Background="#ECF0F1" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Add / Edit Billing Rate" FontSize="16" 
                                           FontWeight="Bold" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: Name and Rate -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rate Name:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <TextBox x:Name="txtRateName" Grid.Row="0" Grid.Column="1"
                                             Height="28" Margin="0,0,16,8" Padding="6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Rate/Min:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <TextBox x:Name="txtRatePerMinute" Grid.Row="0" Grid.Column="3"
                                             Height="28" Margin="0,0,16,8" Padding="6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Currency:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <ComboBox x:Name="cboCurrency" Grid.Row="0" Grid.Column="5"
                                              Height="28" Margin="0,0,0,8" SelectedIndex="0">
                                        <ComboBoxItem Content="USD"/>
                                        <ComboBoxItem Content="EUR"/>
                                        <ComboBoxItem Content="GBP"/>
                                        <ComboBoxItem Content="INR"/>
                                        <ComboBoxItem Content="PKR"/>
                                    </ComboBox>

                                    <!-- Row 2: Effective Dates -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Effective From:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <DatePicker x:Name="dpEffectiveFrom" Grid.Row="1" Grid.Column="1"
                                                Height="28" Margin="0,0,16,8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="To:" 
                                               VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <DatePicker x:Name="dpEffectiveTo" Grid.Row="1" Grid.Column="3"
                                                Height="28" Margin="0,0,16,8"/>
                                    <CheckBox x:Name="chkIsActive" Grid.Row="1" Grid.Column="4"
                                              VerticalAlignment="Center" Content="Active" Margin="0,0,8,8"
                                              IsChecked="True"/>

                                    <!-- Row 3: Notes and Buttons -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Notes:" 
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="txtNotes" Grid.Row="2" Grid.Column="1"
                                             Grid.ColumnSpan="3" Height="28" Padding="6" Margin="0,0,16,0"/>
                                    <CheckBox x:Name="chkIsDefault" Grid.Row="2" Grid.Column="4"
                                              VerticalAlignment="Center" Content="Set as Default" Margin="0,0,8,0"/>
                                </Grid>

                                <TextBlock x:Name="lblBillingRateError" Foreground="Red" FontSize="11"
                                           Margin="0,12,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                                <TextBlock x:Name="lblBillingRateSuccess" Foreground="Green" FontSize="11"
                                           Margin="0,12,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="btnAddBillingRate" Content="Add Rate"
                                            Height="32" Width="100" Background="#27AE60" 
                                            Foreground="White" Click="btnAddBillingRate_Click"/>
                                    <Button x:Name="btnUpdateBillingRate" Content="Update Rate"
                                            Height="32" Width="110" Margin="8,0,0,0"
                                            Background="#3498DB" Foreground="White"
                                            Click="btnUpdateBillingRate_Click"
                                            Visibility="Collapsed"/>
                                    <Button x:Name="btnClearBillingRateForm" Content="Clear" 
                                            Height="32" Width="80" Margin="8,0,0,0"
                                            Click="btnClearBillingRateForm_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Billing Rates List -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Billing Rates" FontSize="16" 
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock Text="Total:" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="lblBillingRateCount" Text="0" FontSize="12"
                                           FontWeight="Bold" Foreground="#27AE60" VerticalAlignment="Center"/>
                                <Button x:Name="btnRefreshBillingRates" Content="Refresh"
                                        Height="28" Width="90" Margin="16,0,0,0"
                                        Click="btnRefreshBillingRates_Click"/>
                            </StackPanel>
                            <DataGrid Grid.Row="1" x:Name="dgBillingRates"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"         Binding="{Binding BillingRateId}"   Width="50"/>
                                    <DataGridTextColumn Header="Name"       Binding="{Binding Name}"            Width="140"/>
                                    <DataGridTextColumn Header="Rate/Min"   Binding="{Binding RatePerMinute}"   Width="90"/>
                                    <DataGridTextColumn Header="Currency"   Binding="{Binding Currency}"        Width="80"/>
                                    <DataGridTextColumn Header="Effective From" Binding="{Binding EffectiveFrom}" Width="120"/>
                                    <DataGridTextColumn Header="Effective To"   Binding="{Binding EffectiveTo}"   Width="120"/>
                                    <DataGridTextColumn Header="Active"     Binding="{Binding IsActive}"        Width="70"/>
                                    <DataGridTextColumn Header="Default"    Binding="{Binding IsDefault}"       Width="70"/>
                                    <DataGridTextColumn Header="Created"    Binding="{Binding CreatedAt}"       Width="150"/>
                                    <DataGridTextColumn Header="Notes"      Binding="{Binding Notes}"           Width="*"/>
                                    <DataGridTemplateColumn Header="Actions" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                                    <!-- Edit Button -->
                                                    <Button Content="✎ Edit" Height="28" Width="60"
                                                            Background="#3498DB" Foreground="White"
                                                            Click="btnEditBillingRate_Click"
                                                            Padding="4,2" Margin="2"/>
                                                    <!-- Set Default Button (hidden if already default) -->
                                                    <Button Content="★ Default" Height="28" Width="85" Margin="4,2,0,2"
                                                            Background="#F39C12" Foreground="White"
                                                            Click="btnSetDefaultBillingRate_Click"
                                                            Padding="4,2">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDefault}" Value="1">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <!-- Delete Button -->
                                                    <Button Content="🗑 Delete" Height="28" Width="70" Margin="4,2,0,2"
                                                            Background="#E74C3C" Foreground="White"
                                                            Click="btnDeleteBillingRate_Click"
                                                            Padding="4,2"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- IMAGE VIEWER OVERLAY (UC-12) -->
        <Border x:Name="ImageViewerPanel" Grid.Row="1"
                Background="#AA000000" Visibility="Collapsed">
            <Border Background="White" CornerRadius="8" Padding="20"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="680" Height="530">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="lblImageTitle"
                               Text="Login Image" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,12"/>
                    <Border Grid.Row="1" Background="#ECF0F1" CornerRadius="4">
                        <Image x:Name="imgSessionPhoto" Stretch="Uniform" MaxHeight="420"/>
                    </Border>
                    <Button Grid.Row="2" Content="Close" Height="32" Width="100"
                            Margin="0,12,0,0" HorizontalAlignment="Right"
                            Click="btnCloseImage_Click"/>
                </Grid>
            </Border>
        </Border>

    </Grid>
</Window>
