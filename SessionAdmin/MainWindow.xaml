                                                                FontFamily="Segoe UI" FontSize="13"
                                                                ToolTip="Reset Password" Margin="4,0"
                                                                Click="btnResetPasswordInline_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#4C1D95"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="⊕" Height="28" Width="32"
                                                                Background="#064E3B" Foreground="#34D399"
                                                                BorderThickness="0" Cursor="Hand"
                                                                FontFamily="Segoe UI" FontSize="13"
                                                                ToolTip="Toggle Status"
                                                                Click="btnToggleStatusInline_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#065F46"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="🗑" Height="28" Width="32"
                                                                Background="#4C0519" Foreground="#FCA5A5"
                                                                BorderThickness="0" Cursor="Hand"
                                                                FontFamily="Segoe UI" FontSize="13"
                                                                ToolTip="Delete User" Margin="4,0,0,0"
                                                                Click="btnDeleteUserInline_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,20,20" Panel.ZIndex="1" Visibility="Collapsed">
                                    <Button Content="◀" Style="{StaticResource BtnHScroll}"
                                            Click="BtnScrollLeft_Click"/>
                                    <Button Content="▶" Style="{StaticResource BtnHScroll}"
                                            Margin="4,0,0,0" Click="BtnScrollRight_Click"/>
                                </StackPanel>
                                </Grid>
                            </Border>

                            <!-- User Action Messages -->
                            <Border Grid.Row="2" Background="#1E2433" CornerRadius="8"
                                    Padding="14,10" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="lblUserActionError" Foreground="#FCA5A5"
                                               FontSize="12" Visibility="Collapsed"/>
                                    <TextBlock x:Name="lblUserActionSuccess" Foreground="#6EE7B7"
                                               FontSize="12" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ═══ BILLING RATES PAGE ═══ -->
                        <Grid x:Name="PageBilling" Margin="24" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="220"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Rates List Header -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Billing Rates" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Border CornerRadius="10" Background="#1E2433" Padding="8,2" Margin="10,0">
                                        <TextBlock x:Name="lblBillingRateCount" Text="0"
                                                   FontSize="11" Foreground="#4F8EF7" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="btnAddNewRate" Content="+ Add New Rate"
                                            Style="{StaticResource BtnSuccess}"
                                            Height="34" Padding="14,0" FontSize="12"
                                            Click="btnAddNewRate_Click"/>
                                    <Button x:Name="btnRefreshBillingRates" Content="↺ Refresh"
                                            Style="{StaticResource BtnGhost}"
                                            Height="34" Padding="12,0" FontSize="11"
                                            Margin="8,0,0,0" Click="btnRefreshBillingRates_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- Rates Table -->
                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,0">
                                <Grid>
                                <DataGrid x:Name="dgBillingRates" AutoGenerateColumns="False"
                                          ScrollViewer.ScrollChanged="DgScrollChanged"
                                          ui:ScrollBehavior.EnableHorizontalScroll="True"
                                          IsReadOnly="True" CanUserAddRows="False"
                                          SelectionMode="Single"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding BillingRateId}" Width="50" MinWidth="50"/>
                                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="140" MinWidth="140"/>
                                        <DataGridTextColumn Header="RATE/MIN" Binding="{Binding RatePerMinute}" Width="90" MinWidth="90"/>
                                        <DataGridTextColumn Header="CURRENCY" Binding="{Binding Currency}" Width="80" MinWidth="80"/>
                                        <DataGridTextColumn Header="EFF. FROM" Binding="{Binding EffectiveFrom, StringFormat='MM/dd/yyyy'}" Width="100" MinWidth="100"/>
                                        <DataGridTextColumn Header="EFF. TO"   Binding="{Binding EffectiveTo,   StringFormat='MM/dd/yyyy'}" Width="100" MinWidth="100"/>
                                        <DataGridTextColumn Header="ACTIVE" Binding="{Binding IsActive}" Width="70" MinWidth="70"/>
                                        <DataGridTextColumn Header="DEFAULT" Binding="{Binding IsDefault}" Width="75" MinWidth="75"/>
                                        <DataGridTextColumn Header="CREATED" Binding="{Binding CreatedAt}" Width="155" MinWidth="155"/>
                                        <DataGridTemplateColumn Header="NOTES" Width="200" MinWidth="200">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Notes}"
                                                               TextWrapping="Wrap" Padding="6,4"
                                                               VerticalAlignment="Top"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="ACTIONS" Width="130" MinWidth="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="8,4">
                                                        <Button Content="✎"
                                                                Background="#1D3461" Foreground="#60A5FA"
                                                                BorderThickness="0"
                                                                Width="32" Height="28"
                                                                FontSize="13" FontFamily="Segoe UI"
                                                                Cursor="Hand" Margin="0,0,4,0"
                                                                ToolTip="Edit Rate"
                                                                Click="btnEditBillingRate_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#1E40AF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="★"
                                                                Background="#451A03" Foreground="#FBBF24"
                                                                BorderThickness="0"
                                                                Width="32" Height="28"
                                                                FontSize="13" FontFamily="Segoe UI"
                                                                Cursor="Hand" Margin="0,0,4,0"
                                                                ToolTip="Set as Default"
                                                                Click="btnSetDefaultBillingRate_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="r" Property="Background" Value="#78350F"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDefault}" Value="1">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Content="🗑"
                                                                Background="#450A0A" Foreground="#F87171"
                                                                BorderThickness="0"
                                                                Width="32" Height="28"
                                                                FontSize="13" FontFamily="Segoe UI"
                                                                Cursor="Hand"
                                                                ToolTip="Delete Rate"
                                                                Click="btnDeleteBillingRate_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,20,20" Panel.ZIndex="1" Visibility="Collapsed">
                                    <Button Content="◀" Style="{StaticResource BtnHScroll}"
                                            Click="BtnScrollLeft_Click"/>
                                    <Button Content="▶" Style="{StaticResource BtnHScroll}"
                                            Margin="4,0,0,0" Click="BtnScrollRight_Click"/>
                                </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Payments Section Header -->
                            <Grid Grid.Row="2" Margin="0,16,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Payment Collection" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Border CornerRadius="10" Background="#1E2433" Padding="8,2" Margin="10,0">
                                        <TextBlock x:Name="lblUnpaidCount" Text="0"
                                                   FontSize="11" Foreground="#FBBF24" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="unpaid" FontSize="11" Foreground="#475569"
                                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <CheckBox x:Name="chkUnpaidOnly" Content="Unpaid only"
                                              Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"
                                              IsChecked="True" Margin="0,0,10,0"
                                              Checked="chkUnpaidOnly_Changed" Unchecked="chkUnpaidOnly_Changed"/>
                                    <Button x:Name="btnRefreshPayments" Content="↺ Refresh"
                                            Style="{StaticResource BtnGhost}"
                                            Height="34" Padding="12,0" FontSize="11"
                                            Click="btnRefreshPayments_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- Payments Table -->
                            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
                                <Grid>
                                <DataGrid x:Name="dgBillingRecords" AutoGenerateColumns="False"
                                          ScrollViewer.ScrollChanged="DgScrollChanged"
                                          ui:ScrollBehavior.EnableHorizontalScroll="True"
                                          IsReadOnly="True" CanUserAddRows="False"
                                          SelectionMode="Single"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"       Binding="{Binding BillingRecordId}" Width="45"  MinWidth="45"/>
                                        <DataGridTextColumn Header="SESSION"  Binding="{Binding SessionId}"       Width="70"  MinWidth="70"/>
                                        <DataGridTextColumn Header="USER"     Binding="{Binding Username}"        Width="110" MinWidth="110"/>
                                        <DataGridTextColumn Header="MACHINE"  Binding="{Binding MachineCode}"     Width="90"  MinWidth="90"/>
                                        <DataGridTextColumn Header="MINS"     Binding="{Binding BillableMinutes}" Width="55"  MinWidth="55"/>
                                        <DataGridTextColumn Header="AMOUNT"   Binding="{Binding AmountDisplay}"   Width="90"  MinWidth="90"/>
                                        <DataGridTextColumn Header="DATE"     Binding="{Binding CalculatedAt}"    Width="140" MinWidth="140"/>
                                        <DataGridTemplateColumn Header="STATUS" Width="90" MinWidth="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="4" Padding="6,3" Margin="4,3"
                                                            Background="{Binding StatusBackground}">
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                   FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusForeground}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="PAID AT"  Binding="{Binding PaidAtDisplay}"  Width="130" MinWidth="130"/>
                                        <DataGridTemplateColumn Header="ACTIONS" Width="60" MinWidth="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✔"
                                                            Visibility="{Binding MarkPaidVisibility}"
                                                            Background="#14532D" Foreground="#6EE7B7"
                                                            BorderThickness="0"
                                                            Width="32" Height="28"
                                                            FontSize="13" FontFamily="Segoe UI"
                                                            Cursor="Hand" Margin="4,3"
                                                            ToolTip="Mark as Paid"
                                                            Click="btnMarkPaidInline_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="r" Property="Background" Value="#166534"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,20,20" Panel.ZIndex="1" Visibility="Collapsed">
                                    <Button Content="◀" Style="{StaticResource BtnHScroll}"
                                            Click="BtnScrollLeft_Click"/>
                                    <Button Content="▶" Style="{StaticResource BtnHScroll}"
                                            Margin="4,0,0,0" Click="BtnScrollRight_Click"/>
                                </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Billing Action Messages -->
                            <Border Grid.Row="4" Background="#1E2433" CornerRadius="8"
                                    Padding="14,10" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="lblBillingActionError" Foreground="#FCA5A5"
                                               FontSize="12" Visibility="Collapsed"/>
                                    <TextBlock x:Name="lblBillingActionSuccess" Foreground="#6EE7B7"
                                               FontSize="12" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ═══ SECURITY ALERTS PAGE ═══ -->
                        <Grid x:Name="PageAlerts" Margin="24" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource BadgeRed}" Padding="10,4" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠ " Foreground="#F87171" FontSize="12"/>
                                        <TextBlock x:Name="lblAlertCount" Text="0 unresolved"
                                                   Foreground="#F87171" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Button Content="↺ Refresh" Style="{StaticResource BtnGhost}"
                                        Height="34" Padding="14,0" FontSize="11"
                                        Click="btnRefreshSessions_Click"/>
                            </StackPanel>
                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                                <Grid>
                                <DataGrid x:Name="dgAlerts" AutoGenerateColumns="False" IsReadOnly="True"
                                          ScrollViewer.ScrollChanged="DgScrollChanged"
                                          ui:ScrollBehavior.EnableHorizontalScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="TIME" Binding="{Binding Timestamp}" Width="155" MinWidth="155"/>
                                        <DataGridTextColumn Header="SEVERITY" Binding="{Binding Severity}" Width="80" MinWidth="80"/>
                                        <DataGridTextColumn Header="CLIENT" Binding="{Binding ClientId}" Width="90" MinWidth="90"/>
                                        <DataGridTextColumn Header="USER" Binding="{Binding Username}" Width="120" MinWidth="120"/>
                                        <DataGridTextColumn Header="TYPE" Binding="{Binding AlertType}" Width="200" MinWidth="200"/>
                                        <DataGridTemplateColumn Header="DESCRIPTION" Width="280" MinWidth="280">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Description}"
                                                               TextWrapping="Wrap" Padding="6,4"
                                                               VerticalAlignment="Top"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="ACTION" Width="60" MinWidth="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✓"
                                                            Background="#064E3B" Foreground="#34D399"
                                                            BorderThickness="0"
                                                            Width="32" Height="28"
                                                            FontSize="13" FontFamily="Segoe UI"
                                                            Cursor="Hand" Margin="8,4"
                                                            ToolTip="Acknowledge Alert"
                                                            Click="btnAcknowledgeAlert_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="r" Property="Background" Value="#065F46"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,20,20" Panel.ZIndex="1" Visibility="Collapsed">
                                    <Button Content="◀" Style="{StaticResource BtnHScroll}"
                                            Click="BtnScrollLeft_Click"/>
                                    <Button Content="▶" Style="{StaticResource BtnHScroll}"
                                            Margin="4,0,0,0" Click="BtnScrollRight_Click"/>
                                </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ═══ SESSION LOGS PAGE ═══ -->
                        <Grid x:Name="PageLogs" Margin="24" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="FROM" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#475569" Margin="0,0,0,6"/>
                                        <DatePicker x:Name="dpLogFrom" Width="256" Height="38"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="TO" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#475569" Margin="0,0,0,6"/>
                                        <DatePicker x:Name="dpLogTo" Width="256" Height="38"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="CATEGORY" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#475569" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="cboLogCategory" Width="140" Height="38"
                                                  Style="{StaticResource ModernCombo}" SelectedIndex="0">
                                            <ComboBoxItem Content="All"/>
                                            <ComboBoxItem Content="Auth"/>
                                            <ComboBoxItem Content="Session"/>
                                            <ComboBoxItem Content="Billing"/>
                                            <ComboBoxItem Content="Security"/>
                                            <ComboBoxItem Content="System"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom">
                                        <Button x:Name="btnLoadLogs" Content="⊳ Load Logs"
                                                Style="{StaticResource BtnPrimary}"
                                                Height="38" Padding="18,0" FontSize="12"
                                                Click="btnLoadLogs_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                                <Grid>
                                <DataGrid x:Name="dgLogs" AutoGenerateColumns="False" IsReadOnly="True"
                                          ScrollViewer.ScrollChanged="DgScrollChanged"
                                          ui:ScrollBehavior.EnableHorizontalScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Style>
                                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                            <Setter Property="RowHeight" Value="NaN"/>
                                        </Style>
                                    </DataGrid.Style>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="TIME"     Binding="{Binding LogTime}"   Width="155" MinWidth="155"/>
                                        <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}"  Width="100" MinWidth="100"/>
                                        <DataGridTextColumn Header="TYPE"     Binding="{Binding LogType}"   Width="180" MinWidth="180"/>
                                        <DataGridTextColumn Header="SOURCE"   Binding="{Binding Source}"    Width="80"  MinWidth="80"/>
                                        <DataGridTextColumn Header="CLIENT"   Binding="{Binding ClientCode}" Width="140" MinWidth="140"/>
                                        <DataGridTextColumn Header="USER"     Binding="{Binding Username}"  Width="110" MinWidth="110"/>
                                        <DataGridTemplateColumn Header="MESSAGE" Width="*" MinWidth="260">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Message}"
                                                               TextWrapping="Wrap" Padding="8,6"
                                                               VerticalAlignment="Top"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,20,20" Panel.ZIndex="1" Visibility="Collapsed">
                                    <Button Content="◀" Style="{StaticResource BtnHScroll}"
                                            Click="BtnScrollLeft_Click"/>
                                    <Button Content="▶" Style="{StaticResource BtnHScroll}"
                                            Margin="4,0,0,0" Click="BtnScrollRight_Click"/>
                                </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ═══ REPORTS PAGE ═══ -->
                        <Grid x:Name="PageReports" Margin="24" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="REPORT TYPE" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#475569" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="cboReportType" Width="160" Height="38"
                                                  Style="{StaticResource ModernCombo}" SelectedIndex="0">
                                            <ComboBoxItem Content="Session Usage"/>
                                            <ComboBoxItem Content="Billing Summary"/>
                                            <ComboBoxItem Content="Security Alerts"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="FROM" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#475569" Margin="0,0,0,6"/>
                                        <DatePicker x:Name="dpFromDate" Width="256" Height="38"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="TO" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#475569" Margin="0,0,0,6"/>
                                        <DatePicker x:Name="dpToDate" Width="256" Height="38"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
                                        <Button x:Name="btnGenerateReport" Content="⊳ Generate"
                                                Style="{StaticResource BtnSuccess}"
                                                Height="38" Padding="18,0" FontSize="12"
                                                Click="btnGenerateReport_Click"/>
                                        <Button x:Name="btnExportReport" Content="↓ Export .txt"
                                                Style="{StaticResource BtnGhost}"
                                                Height="38" Padding="16,0" FontSize="12"
                                                Margin="8,0,0,0" Click="btnExportReport_Click"/>
                                        <Button x:Name="btnPrintReport" Content="🖨 Print"
                                                Style="{StaticResource BtnGhost}"
                                                Height="38" Padding="16,0" FontSize="12"
                                                Margin="8,0,0,0" Click="btnPrintReport_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                                <Grid>
                                    <!-- ── Session Usage: stat cards + DataGrid ── -->
                                    <Grid x:Name="pnlSessionUsage" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,20,16">
                                            <Border Background="#1A2A3A" CornerRadius="10" Padding="20,14" Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="TOTAL SESSIONS" FontSize="10" FontWeight="SemiBold" Foreground="#475569"/>
                                                    <TextBlock x:Name="lblRptSessions" Text="—" FontSize="28" FontWeight="Bold" Foreground="#60A5FA" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#0F2A1E" CornerRadius="10" Padding="20,14" Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="TOTAL HOURS" FontSize="10" FontWeight="SemiBold" Foreground="#475569"/>
                                                    <TextBlock x:Name="lblRptHours" Text="—" FontSize="28" FontWeight="Bold" Foreground="#34D399" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#2A1A0A" CornerRadius="10" Padding="20,14">
                                                <StackPanel>
                                                    <TextBlock Text="TOTAL REVENUE" FontSize="10" FontWeight="SemiBold" Foreground="#475569"/>
                                                    <TextBlock x:Name="lblRptRevenue" Text="—" FontSize="28" FontWeight="Bold" Foreground="#FBBF24" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <DataGrid x:Name="dgReportSessions" Grid.Row="1"
                                                  AutoGenerateColumns="False" IsReadOnly="True"
                                                  ScrollViewer.ScrollChanged="DgScrollChanged"
                                                  ui:ScrollBehavior.EnableHorizontalScroll="True"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="USER"        Binding="{Binding Username}"   Width="150" MinWidth="150"/>
                                                <DataGridTextColumn Header="FULL NAME"   Binding="{Binding FullName}"   Width="160" MinWidth="160"/>
                                                <DataGridTextColumn Header="CLIENT"      Binding="{Binding ClientCode}" Width="145" MinWidth="145"/>
                                                <DataGridTextColumn Header="MACHINE"     Binding="{Binding MachineName}" Width="130" MinWidth="130"/>
                                                <DataGridTextColumn Header="START TIME"  Binding="{Binding StartTime}"  Width="155" MinWidth="155"/>
                                                <DataGridTextColumn Header="ACTUAL (min)" Binding="{Binding ActualMin}" Width="110" MinWidth="110"/>
                                                <DataGridTextColumn Header="BILLING"     Binding="{Binding Billing}"    Width="100" MinWidth="100"/>
                                                <DataGridTextColumn Header="STATUS"      Binding="{Binding Status}"     Width="110" MinWidth="110"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Margin="0,0,20,20" Panel.ZIndex="1" Visibility="Collapsed">
                                            <Button Content="◀" Style="{StaticResource BtnHScroll}"
                                                    Click="BtnScrollLeft_Click"/>
                                            <Button Content="▶" Style="{StaticResource BtnHScroll}"
                                                    Margin="4,0,0,0" Click="BtnScrollRight_Click"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ── Billing Summary / Security Alerts: text output ── -->
                                    <ScrollViewer x:Name="pnlTextReport"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Padding="20">
                                        <TextBox x:Name="txtReportOutput"
                                                 FontFamily="Consolas" FontSize="12"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="#94A3B8" IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 Text="Generate a report to see results here…"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             IMAGE VIEWER OVERLAY
        ══════════════════════════════════════════════════════════ -->
        <Border x:Name="ImageViewerPanel" Grid.Column="1"
                Background="#CC000000" Visibility="Collapsed">
            <Border Background="#171B26" CornerRadius="16" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="700" Height="540"
                    BorderBrush="#2D3748" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock x:Name="lblImageTitle" Text="Session Image"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#F1F5F9" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Row="1" Background="#0F1117" CornerRadius="10">
                        <Image x:Name="imgSessionPhoto" Stretch="Uniform" Margin="8"/>
                    </Border>
                    <Button Grid.Row="2" Content="✕ Close" Style="{StaticResource BtnGhost}"
                            Height="36" Width="100" Margin="0,16,0,0"
                            HorizontalAlignment="Right" Click="btnCloseImage_Click"/>
                </Grid>
            </Border>
        </Border>
        <!-- ══════════════════════════════════════════════════════════
             IN-APP TOAST NOTIFICATION (anchored top-right)
        ══════════════════════════════════════════════════════════ -->
        <Border x:Name="ToastPanel" Grid.ColumnSpan="2"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,10,16,0" Width="300"
                Background="#1A1200" BorderBrush="#854D0E" BorderThickness="1"
                CornerRadius="10" Padding="14,10"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="12" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="lblToastIcon" Text="⚠" FontSize="16" Foreground="#FBBF24"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="lblToastMessage"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="#FDE68A" FontWeight="SemiBold"
                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#A16207" FontSize="12" Cursor="Hand"
                        VerticalAlignment="Center" Margin="8,0,0,0"
                        Click="btnDismissToast_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="lblToastDismiss" Text="✕" Foreground="#A16207"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        </Grid><!-- /main area Grid -->

        <!-- ══════════════════════════════════════════════════════════
             CONNECTING OVERLAY — shown while btnConnect async connect
             is in progress. Last child of root Grid so it renders above
             all panels including the sidebar and content area.
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="ConnectingOverlay" Visibility="Collapsed" Background="#B2000000">
            <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1"
                    CornerRadius="14" Width="300" Height="120"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="32" ShadowDepth="0" Opacity="0.8"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,16">
                    <TextBlock Text="Reconnecting to server…"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Foreground="#F1F5F9" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <ProgressBar IsIndeterminate="True" Height="4"
                                 Background="#1E2433" Foreground="#4F8EF7"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid><!-- /outer rows Grid -->
    </Border><!-- /outer border -->
</Window>
