<Window x:Class="SessionAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetCafe Admin — Session Management"
        Height="720" Width="1280"
        MinHeight="650" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F1F5F9">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  ROOT GRID — single full-window layer stack                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Grid>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!--  DASHBOARD PANEL  (col/row layout: sidebar | header+pages)      -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="DashboardPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── SIDEBAR ──────────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="#0F172A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Brand -->
                    <Border Grid.Row="0" Padding="20,0" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                        <TextBlock Text="⊞ NetCafe Admin"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Connection status pill below brand -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                Margin="20,10,20,10" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0"
                                 x:Name="sidebarConnectionDot"/>
                        <TextBlock x:Name="sidebarConnectionText"
                                   Text="Disconnected"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Nav items -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <Button x:Name="btnNavSessions"
                                    Style="{StaticResource SidebarNavBtn}"
                                    Tag="Active"
                                    Click="BtnNavSessions_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⏱" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sessions" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnNavClients"
                                    Style="{StaticResource SidebarNavBtn}"
                                    Click="BtnNavClients_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🖥" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clients" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnNavUsers"
                                    Style="{StaticResource SidebarNavBtn}"
                                    Click="BtnNavUsers_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="👥" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Users" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnNavAlerts"
                                    Style="{StaticResource SidebarNavBtn}"
                                    Click="BtnNavAlerts_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⚠" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Alerts" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnNavLogs"
                                    Style="{StaticResource SidebarNavBtn}"
                                    Click="BtnNavLogs_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="≡" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Logs" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnNavRates"
                                    Style="{StaticResource SidebarNavBtn}"
                                    Click="BtnNavRates_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="$" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Rates" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnNavReports"
                                    Style="{StaticResource SidebarNavBtn}"
                                    Click="BtnNavReports_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="↗" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Reports" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ─── CONTENT AREA ──────────────────────────────────────────── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="24,0">
                        <!-- Page title left -->
                        <TextBlock x:Name="lblPageTitle"
                                   Text="Active Sessions"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>

                        <!-- Right cluster -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <!-- Connection indicator -->
                            <Ellipse x:Name="ellipseConnectionStatus"
                                     Width="10" Height="10"
                                     Fill="#EF4444"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>
                            <TextBlock x:Name="lblConnectionStatus"
                                       Text="Disconnected"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Button x:Name="btnConnect"
                                    Content="Reconnect"
                                    Style="{StaticResource GhostBtn}"
                                    Height="30"
                                    FontSize="12"
                                    Visibility="Collapsed"
                                    Margin="0,0,16,0"
                                    Click="btnConnect_Click"/>

                            <!-- Separator -->
                            <Border Width="1" Background="#E2E8F0" Margin="0,12,16,12"/>

                            <!-- Admin user + logout -->
                            <StackPanel x:Name="AdminHeaderPanel"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="lblAdminUser"
                                           Text="Admin: —"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                <Button x:Name="btnLogout"
                                        Content="Logout"
                                        Style="{StaticResource DangerBtn}"
                                        Height="30"
                                        FontSize="12"
                                        Click="btnLogout_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- PAGES CONTAINER -->
                <Grid Grid.Row="1" Background="#F1F5F9">

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!--  PAGE: ACTIVE SESSIONS                                 -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <Grid x:Name="PageSessions" Visibility="Visible">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel>

                                <!-- Stats row -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="White"
                                            CornerRadius="8"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            Padding="20,14"
                                            Margin="0,0,12,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="Active Sessions"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="lblActiveCount"
                                                       Text="0"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="White"
                                            CornerRadius="8"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            Padding="20,14">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="Last Updated"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="lblLastUpdate"
                                                       Text="—"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Toolbar -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Button x:Name="btnRefreshSessions"
                                            Content="↺ Refresh"
                                            Style="{StaticResource PrimaryBtn}"
                                            Margin="0,0,8,0"
                                            Click="btnRefreshSessions_Click"/>
                                    <Button x:Name="btnViewImage"
                                            Content="🖼 View Image"
                                            Style="{StaticResource GhostBtn}"
                                            Click="btnViewImage_Click"/>
                                </StackPanel>

                                <!-- Kanban cards -->
                                <ItemsControl x:Name="icKanbanSessions"
                                              ItemsSource="{Binding ItemsSource, ElementName=dgActiveSessions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"
                                                       ItemWidth="256"
                                                       ItemHeight="Auto"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White"
                                                    CornerRadius="8"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    Width="240"
                                                    Margin="0,0,8,8"
                                                    Padding="0">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <!-- Card header: username + status badge -->
                                                    <Grid Margin="16,14,16,10">
                                                        <TextBlock Text="{Binding Username}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   VerticalAlignment="Center"/>
                                                        <Border HorizontalAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                Background="#D1FAE5"
                                                                CornerRadius="10"
                                                                Padding="6,2">
                                                            <TextBlock Text="Active"
                                                                       FontSize="10"
                                                                       Foreground="#065F46"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- ClientId badge -->
                                                    <StackPanel Orientation="Horizontal" Margin="16,0,16,10">
                                                        <TextBlock Text="🖥 " FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                                        <Border Background="#EFF6FF"
                                                                CornerRadius="6"
                                                                Padding="8,3">
                                                            <TextBlock Text="{Binding ClientId}"
                                                                       FontSize="11"
                                                                       Foreground="#1D4ED8"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- Divider -->
                                                    <Border Height="1" Background="#F1F5F9" Margin="0,0,0,10"/>

                                                    <!-- Remaining time large -->
                                                    <TextBlock Text="{Binding RemainingTime}"
                                                               FontSize="28"
                                                               FontWeight="Bold"
                                                               Foreground="#F59E0B"
                                                               HorizontalAlignment="Center"
                                                               Margin="16,0,16,4"/>
                                                    <TextBlock Text="remaining"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextMuted}"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,0,0,10"/>

                                                    <!-- Info rows -->
                                                    <StackPanel Margin="16,0,16,10">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="⏱ " FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                            <TextBlock Text="{Binding Duration}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextSecondary}"/>
                                                            <TextBlock Text=" session"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextMuted}"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="▷ Started " FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                            <TextBlock Text="{Binding StartTime}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextSecondary}"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="💰 " FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                            <TextBlock Text="{Binding CurrentBilling}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimary}"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Divider -->
                                                    <Border Height="1" Background="#F1F5F9" Margin="0,0,0,10"/>

                                                    <!-- Terminate button -->
                                                    <Button Content="Terminate"
                                                            Style="{StaticResource DangerBtn}"
                                                            Height="32"
                                                            Margin="16,0,16,14"
                                                            Tag="{Binding SessionId}"
                                                            Click="btnTerminateSession_Click"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Hidden DataGrid (data source for kanban) -->
                                <DataGrid x:Name="dgActiveSessions"
                                          Visibility="Collapsed"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Session ID"       Binding="{Binding SessionId}"/>
                                        <DataGridTextColumn Header="Client ID"        Binding="{Binding ClientId}"/>
                                        <DataGridTextColumn Header="Username"         Binding="{Binding Username}"/>
                                        <DataGridTextColumn Header="Start Time"       Binding="{Binding StartTime}"/>
                                        <DataGridTextColumn Header="Duration"         Binding="{Binding Duration}"/>
                                        <DataGridTextColumn Header="Remaining Time"   Binding="{Binding RemainingTime}"/>
                                        <DataGridTextColumn Header="Current Billing"  Binding="{Binding CurrentBilling}"/>
                                        <DataGridTextColumn Header="Status"           Binding="{Binding Status}"/>
                                        <DataGridTemplateColumn Header="Action">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Terminate"
                                                            Style="{StaticResource DangerBtn}"
                                                            Height="28"
                                                            Tag="{Binding SessionId}"
                                                            Click="btnTerminateSession_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!--  PAGE: CLIENT MACHINES                                 -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <Grid x:Name="PageClients" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel>

                                <!-- Stats header -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Padding="20,14"
                                        Margin="0,0,0,16">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <TextBlock Text="Client Machines"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </Border>

                                <!-- DataGrid card -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <DataGrid x:Name="dgClients"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              GridLinesVisibility="None"
                                              AlternatingRowBackground="#F8FAFC"
                                              RowBackground="White"
                                              HeadersVisibility="Column"
                                              BorderThickness="0"
                                              Margin="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Client ID"        Binding="{Binding ClientId}"            Width="80"/>
                                            <DataGridTextColumn Header="Machine Name"     Binding="{Binding MachineName}"         Width="130"/>
                                            <DataGridTextColumn Header="IP Address"       Binding="{Binding IpAddress}"           Width="120"/>
                                            <DataGridTextColumn Header="MAC Address"      Binding="{Binding MacAddress}"          Width="140"/>
                                            <DataGridTextColumn Header="Location"         Binding="{Binding Location}"            Width="100"/>
                                            <DataGridTextColumn Header="Status"           Binding="{Binding Status}"              Width="80"/>
                                            <DataGridTextColumn Header="Machine Status"   Binding="{Binding ClientMachineStatus}" Width="110"/>
                                            <DataGridTextColumn Header="Current User"     Binding="{Binding CurrentUser}"         Width="110"/>
                                            <DataGridTextColumn Header="Last Active"      Binding="{Binding LastActive}"          Width="*"/>
                                            <DataGridTemplateColumn Header="Actions" Width="160">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="Enable"
                                                                    Height="28"
                                                                    Margin="0,0,4,0"
                                                                    Tag="{Binding ClientId}"
                                                                    Click="btnEnableClient_Click">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource SuccessBtn}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Content="Disable"
                                                                    Height="28"
                                                                    Tag="{Binding ClientId}"
                                                                    Click="btnDisableClient_Click">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource DangerBtn}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!--  PAGE: USER MANAGEMENT                                 -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <Grid x:Name="PageUsers" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel>

                                <!-- Register form card -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Padding="24"
                                        Margin="0,0,0,16">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Register New User"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   Margin="0,0,0,16"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Username -->
                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="Username" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtUsername"/>
                                            </StackPanel>

                                            <!-- Full Name -->
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="Full Name" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtFullName"/>
                                            </StackPanel>

                                            <!-- Password row -->
                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="Password" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <PasswordBox x:Name="txtPassword" Grid.Column="0"/>
                                                    <Button x:Name="btnGeneratePassword"
                                                            Grid.Column="2"
                                                            Content="Generate Pwd"
                                                            Style="{StaticResource GhostBtn}"
                                                            Click="btnGeneratePassword_Click"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Phone -->
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="Phone" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtPhone"/>
                                            </StackPanel>

                                            <!-- Address spans both -->
                                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                                <TextBlock Text="Address" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtAddress"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Feedback -->
                                        <TextBlock x:Name="lblRegError"
                                                   Foreground="#EF4444"
                                                   FontSize="12"
                                                   Margin="0,10,0,0"
                                                   Visibility="Collapsed"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="lblRegSuccess"
                                                   Foreground="#22C55E"
                                                   FontSize="12"
                                                   Margin="0,10,0,0"
                                                   Visibility="Collapsed"
                                                   TextWrapping="Wrap"/>

                                        <!-- Actions -->
                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button x:Name="btnRegisterUser"
                                                    Content="Register User"
                                                    Style="{StaticResource PrimaryBtn}"
                                                    Margin="0,0,8,0"
                                                    Click="btnRegisterUser_Click"/>
                                            <Button x:Name="btnClearForm"
                                                    Content="Clear"
                                                    Style="{StaticResource GhostBtn}"
                                                    Click="btnClearForm_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Users DataGrid card -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Padding="0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- Card header -->
                                        <Grid Margin="20,16">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Registered Users"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                                <Border Background="#EFF6FF" CornerRadius="10" Padding="8,2">
                                                    <TextBlock x:Name="lblUserCount"
                                                               Text="0"
                                                               FontSize="12"
                                                               Foreground="#1D4ED8"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="lblUserActionError"
                                                           Foreground="#EF4444"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"
                                                           Visibility="Collapsed"/>
                                                <TextBlock x:Name="lblUserActionSuccess"
                                                           Foreground="#22C55E"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"
                                                           Visibility="Collapsed"/>
                                                <Button x:Name="btnRefreshUsers"
                                                        Content="↺ Refresh"
                                                        Style="{StaticResource GhostBtn}"
                                                        Click="btnRefreshUsers_Click"/>
                                            </StackPanel>
                                        </Grid>

                                        <DataGrid x:Name="dgUsers"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  GridLinesVisibility="None"
                                                  AlternatingRowBackground="#F8FAFC"
                                                  RowBackground="White"
                                                  HeadersVisibility="Column"
                                                  BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="User ID"      Binding="{Binding UserId}"    Width="70"/>
                                                <DataGridTextColumn Header="Username"     Binding="{Binding Username}"  Width="110"/>
                                                <DataGridTextColumn Header="Full Name"    Binding="{Binding FullName}"  Width="130"/>
                                                <DataGridTextColumn Header="Phone"        Binding="{Binding Phone}"     Width="110"/>
                                                <DataGridTextColumn Header="Address"      Binding="{Binding Address}"   Width="140"/>
                                                <DataGridTextColumn Header="Status"       Binding="{Binding Status}"    Width="80"/>
                                                <DataGridTextColumn Header="Created At"   Binding="{Binding CreatedAt}" Width="130"/>
                                                <DataGridTextColumn Header="Last Login"   Binding="{Binding LastLogin}" Width="*"/>
                                                <DataGridTemplateColumn Header="Actions" Width="140">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="✎"
                                                                        Style="{StaticResource GhostBtn}"
                                                                        Height="28"
                                                                        Width="30"
                                                                        Padding="0"
                                                                        Margin="0,0,4,0"
                                                                        Tag="{Binding UserId}"
                                                                        ToolTip="Edit User"
                                                                        Click="btnEditUserInline_Click"/>
                                                                <Button Content="🔑"
                                                                        Style="{StaticResource GhostBtn}"
                                                                        Height="28"
                                                                        Width="30"
                                                                        Padding="0"
                                                                        Margin="0,0,4,0"
                                                                        Tag="{Binding UserId}"
                                                                        ToolTip="Reset Password"
                                                                        Click="btnResetPasswordInline_Click"/>
                                                                <Button Content="⊕"
                                                                        Style="{StaticResource GhostBtn}"
                                                                        Height="28"
                                                                        Width="30"
                                                                        Padding="0"
                                                                        Tag="{Binding UserId}"
                                                                        ToolTip="Toggle Status"
                                                                        Click="btnToggleStatusInline_Click"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!--  PAGE: SECURITY ALERTS                                 -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <Grid x:Name="PageAlerts" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel>

                                <!-- Stats header -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Padding="20,14"
                                        Margin="0,0,0,16">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Security Alerts"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <Border Background="#FEE2E2" CornerRadius="10" Padding="10,3">
                                            <TextBlock x:Name="lblAlertCount"
                                                       Text="0"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="#EF4444"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Alerts DataGrid -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <DataGrid x:Name="dgAlerts"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              GridLinesVisibility="None"
                                              AlternatingRowBackground="#F8FAFC"
                                              RowBackground="White"
                                              HeadersVisibility="Column"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Timestamp"   Binding="{Binding Timestamp}"  Width="140"/>
                                            <DataGridTextColumn Header="Severity"    Binding="{Binding Severity}"   Width="90"/>
                                            <DataGridTextColumn Header="Client ID"   Binding="{Binding ClientId}"   Width="90"/>
                                            <DataGridTextColumn Header="Username"    Binding="{Binding Username}"   Width="110"/>
                                            <DataGridTextColumn Header="Alert Type"  Binding="{Binding AlertType}"  Width="130"/>
                                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                            <DataGridTemplateColumn Header="Action" Width="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Acknowledge"
                                                                Style="{StaticResource GhostBtn}"
                                                                Height="28"
                                                                Tag="{Binding AlertId}"
                                                                Click="btnAcknowledgeAlert_Click"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!--  PAGE: SYSTEM LOGS                                     -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <Grid x:Name="PageLogs" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel>

                                <!-- Filter bar card -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Padding="20,16"
                                        Margin="0,0,0,16">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Filter Logs"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="From" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpLogFrom" Width="140"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="To" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpLogTo" Width="140"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="Category" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="cboLogCategory" Width="140" SelectedIndex="0">
                                                    <ComboBoxItem Content="All"/>
                                                    <ComboBoxItem Content="Auth"/>
                                                    <ComboBoxItem Content="Session"/>
                                                    <ComboBoxItem Content="Billing"/>
                                                    <ComboBoxItem Content="Security"/>
                                                    <ComboBoxItem Content="System"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel VerticalAlignment="Bottom">
                                                <Button x:Name="btnLoadLogs"
                                                        Content="Load Logs"
                                                        Style="{StaticResource PrimaryBtn}"
                                                        Click="btnLoadLogs_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Logs DataGrid -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <DataGrid x:Name="dgLogs"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              GridLinesVisibility="None"
                                              AlternatingRowBackground="#F8FAFC"
                                              RowBackground="White"
                                              HeadersVisibility="Column"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Log Time"   Binding="{Binding LogTime}"    Width="140"/>
                                            <DataGridTextColumn Header="Category"   Binding="{Binding Category}"   Width="90"/>
                                            <DataGridTextColumn Header="Log Type"   Binding="{Binding LogType}"    Width="100"/>
                                            <DataGridTextColumn Header="Source"     Binding="{Binding Source}"     Width="100"/>
                                            <DataGridTextColumn Header="Client Code" Binding="{Binding ClientCode}" Width="100"/>
                                            <DataGridTextColumn Header="Username"   Binding="{Binding Username}"   Width="110"/>
                                            <DataGridTextColumn Header="Message"    Binding="{Binding Message}"    Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!--  PAGE: BILLING RATES                                   -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <Grid x:Name="PageRates" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel>

                                <!-- Add/Edit Rate form card -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Padding="24"
                                        Margin="0,0,0,16">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Add / Edit Billing Rate"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   Margin="0,0,0,16"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Rate Name -->
                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="Rate Name" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtRateName"/>
                                            </StackPanel>

                                            <!-- Rate Per Minute -->
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="Rate Per Minute" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtRatePerMinute"/>
                                            </StackPanel>

                                            <!-- Currency -->
                                            <StackPanel Grid.Row="0" Grid.Column="4">
                                                <TextBlock Text="Currency" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="cboCurrency">
                                                    <ComboBoxItem Content="USD"/>
                                                    <ComboBoxItem Content="EUR"/>
                                                    <ComboBoxItem Content="GBP"/>
                                                    <ComboBoxItem Content="INR"/>
                                                    <ComboBoxItem Content="PKR"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- Effective From -->
                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="Effective From" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpEffectiveFrom"/>
                                            </StackPanel>

                                            <!-- Effective To -->
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="Effective To" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpEffectiveTo"/>
                                            </StackPanel>

                                            <!-- Checkboxes -->
                                            <StackPanel Grid.Row="2" Grid.Column="4" VerticalAlignment="Bottom">
                                                <CheckBox x:Name="chkIsActive"
                                                          Content="Active"
                                                          IsChecked="True"
                                                          Foreground="{StaticResource TextPrimary}"
                                                          FontSize="13"
                                                          Margin="0,0,0,8"/>
                                                <CheckBox x:Name="chkIsDefault"
                                                          Content="Set as Default"
                                                          Foreground="{StaticResource TextPrimary}"
                                                          FontSize="13"/>
                                            </StackPanel>

                                            <!-- Notes -->
                                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5">
                                                <TextBlock Text="Notes" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtNotes"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Feedback -->
                                        <TextBlock x:Name="lblBillingRateError"
                                                   Foreground="#EF4444"
                                                   FontSize="12"
                                                   Margin="0,10,0,0"
                                                   Visibility="Collapsed"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="lblBillingRateSuccess"
                                                   Foreground="#22C55E"
                                                   FontSize="12"
                                                   Margin="0,10,0,0"
                                                   Visibility="Collapsed"
                                                   TextWrapping="Wrap"/>

                                        <!-- Actions -->
                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button x:Name="btnAddBillingRate"
                                                    Content="Add Rate"
                                                    Style="{StaticResource PrimaryBtn}"
                                                    Margin="0,0,8,0"
                                                    Click="btnAddBillingRate_Click"/>
                                            <Button x:Name="btnUpdateBillingRate"
                                                    Content="Update Rate"
                                                    Style="{StaticResource SuccessBtn}"
                                                    Visibility="Collapsed"
                                                    Margin="0,0,8,0"
                                                    Click="btnUpdateBillingRate_Click"/>
                                            <Button x:Name="btnClearBillingRateForm"
                                                    Content="Clear"
                                                    Style="{StaticResource GhostBtn}"
                                                    Click="btnClearBillingRateForm_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Billing Rates DataGrid card -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <Grid Margin="20,16">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Billing Rates"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                                <Border Background="#EFF6FF" CornerRadius="10" Padding="8,2">
                                                    <TextBlock x:Name="lblBillingRateCount"
                                                               Text="0"
                                                               FontSize="12"
                                                               Foreground="#1D4ED8"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <Button x:Name="btnRefreshBillingRates"
                                                    Content="↺ Refresh"
                                                    Style="{StaticResource GhostBtn}"
                                                    HorizontalAlignment="Right"
                                                    Click="btnRefreshBillingRates_Click"/>
                                        </Grid>

                                        <DataGrid x:Name="dgBillingRates"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  GridLinesVisibility="None"
                                                  AlternatingRowBackground="#F8FAFC"
                                                  RowBackground="White"
                                                  HeadersVisibility="Column"
                                                  BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID"             Binding="{Binding BillingRateId}"  Width="50"/>
                                                <DataGridTextColumn Header="Name"           Binding="{Binding Name}"           Width="120"/>
                                                <DataGridTextColumn Header="Rate/Min"       Binding="{Binding RatePerMinute}"  Width="80"/>
                                                <DataGridTextColumn Header="Currency"       Binding="{Binding Currency}"       Width="75"/>
                                                <DataGridTextColumn Header="Effective From" Binding="{Binding EffectiveFrom}"  Width="110"/>
                                                <DataGridTextColumn Header="Effective To"   Binding="{Binding EffectiveTo}"    Width="110"/>
                                                <DataGridTextColumn Header="Active"         Binding="{Binding IsActive}"       Width="60"/>
                                                <DataGridTextColumn Header="Default"        Binding="{Binding IsDefault}"      Width="65"/>
                                                <DataGridTextColumn Header="Created At"     Binding="{Binding CreatedAt}"      Width="110"/>
                                                <DataGridTextColumn Header="Notes"          Binding="{Binding Notes}"          Width="*"/>
                                                <DataGridTemplateColumn Header="Actions" Width="200">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="Edit"
                                                                        Style="{StaticResource GhostBtn}"
                                                                        Height="28"
                                                                        Margin="0,0,4,0"
                                                                        Tag="{Binding BillingRateId}"
                                                                        Click="btnEditBillingRate_Click"/>
                                                                <Button Content="Set Default"
                                                                        Height="28"
                                                                        Margin="0,0,4,0"
                                                                        Tag="{Binding BillingRateId}"
                                                                        Click="btnSetDefaultBillingRate_Click">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsDefault}" Value="1">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Content="Delete"
                                                                        Style="{StaticResource DangerBtn}"
                                                                        Height="28"
                                                                        Tag="{Binding BillingRateId}"
                                                                        Click="btnDeleteBillingRate_Click"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!--  PAGE: REPORTS                                         -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <Grid x:Name="PageReports" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel>

                                <!-- Filter bar -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Padding="20,16"
                                        Margin="0,0,0,16">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Report Filters"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="Report Type" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="cboReportType" Width="180">
                                                    <ComboBoxItem Content="Session Usage"/>
                                                    <ComboBoxItem Content="Billing Summary"/>
                                                    <ComboBoxItem Content="Security Alerts"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="From Date" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpFromDate" Width="140"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="To Date" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <DatePicker x:Name="dpToDate" Width="140"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <Button x:Name="btnGenerateReport"
                                                        Content="Generate Report"
                                                        Style="{StaticResource PrimaryBtn}"
                                                        Margin="0,0,8,0"
                                                        Click="btnGenerateReport_Click"/>
                                                <Button x:Name="btnExportReport"
                                                        Content="Export .txt"
                                                        Style="{StaticResource GhostBtn}"
                                                        Click="btnExportReport_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Report output -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        MinHeight="400">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                                        <TextBlock x:Name="txtReportOutput"
                                                   Text="Report output will appear here..."
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!--  LOGIN PANEL — full-window overlay, ZIndex 10                   -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="LoginPanel"
              Background="#0F172A"
              Panel.ZIndex="10">

            <!-- Centered card -->
            <Border Background="White"
                    Width="420"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="48">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="40" ShadowDepth="8"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Icon + title -->
                    <TextBlock Text="🔐"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Admin Login"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,28"/>

                    <!-- Username -->
                    <TextBlock Text="Username"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="txtAdminUsername"
                             Margin="0,0,0,16"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="txtAdminPassword" Grid.Column="0"/>
                        <TextBox    x:Name="txtAdminPasswordPlain"
                                    Grid.Column="0"
                                    Visibility="Collapsed"/>
                        <Button x:Name="btnShowAdminPassword"
                                Grid.Column="2"
                                Content="👁"
                                FontSize="16"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource TextSecondary}"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Click="btnShowAdminPassword_Click"/>
                    </Grid>

                    <!-- Error message -->
                    <TextBlock x:Name="lblAdminLoginError"
                               Foreground="#EF4444"
                               FontSize="12"
                               Margin="0,8,0,0"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"/>

                    <!-- Login button -->
                    <Button x:Name="btnAdminLogin"
                            Content="Login"
                            Style="{StaticResource PrimaryBtn}"
                            Height="44"
                            FontSize="15"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Stretch"
                            Click="btnAdminLogin_Click"/>

                    <!-- Connection status indicator -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">
                        <Ellipse Width="8" Height="8"
                                 Fill="#EF4444"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock Text="Not connected to server"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!--  IMAGE VIEWER OVERLAY — full-window, ZIndex 20, Collapsed       -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <Border x:Name="ImageViewerPanel"
                Background="#BB000000"
                Panel.ZIndex="20"
                Visibility="Collapsed">
            <Grid>
                <!-- Close button top-right -->
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,24,0"
                        Width="36" Height="36"
                        FontSize="16"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Cursor="Hand"
                        Click="btnCloseImage_Click"/>

                <!-- Image card -->
                <Border Background="White"
                        CornerRadius="8"
                        Width="700"
                        MaxHeight="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.4" BlurRadius="30" ShadowDepth="10"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Title bar -->
                        <Grid Background="#F8FAFC"
                              Height="48">
                            <Border CornerRadius="8,8,0,0" Background="#F8FAFC"/>
                            <TextBlock x:Name="lblImageTitle"
                                       Text="Login Image"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="#E2E8F0"/>
                        <!-- Image -->
                        <Border Padding="16">
                            <Image x:Name="imgSessionPhoto"
                                   Stretch="Uniform"
                                   MaxHeight="440"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
