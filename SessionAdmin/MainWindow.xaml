                                                               VerticalAlignment="Top"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="80" MinWidth="80"/>
                                        <DataGridTextColumn Header="CREATED" Binding="{Binding CreatedAt}" Width="155" MinWidth="155"/>
                                        <DataGridTextColumn Header="LAST LOGIN" Binding="{Binding LastLogin}" Width="155" MinWidth="155"/>
                                        <DataGridTemplateColumn Header="ACTIONS" Width="220" MinWidth="220">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="8,4">
                                                        <Button Content="✎" Height="28" Width="32"
                                                                Background="#1D3461" Foreground="#60A5FA"
                                                                BorderThickness="0" Cursor="Hand"
                                                                FontFamily="Segoe UI" FontSize="13"
                                                                ToolTip="Edit User"
                                                                Click="btnEditUserInline_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#1E40AF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="🔑" Height="28" Width="32"
                                                                Background="#3B0764" Foreground="#C4B5FD"
