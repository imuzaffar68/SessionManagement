<Window x:Class="SessionAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SessionManagement.UI;assembly=SessionManagement.Shared"
        Icon="app.ico"
        Title="NetCafé Admin — Session Management"
        Height="820" Width="1380"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ShowInTaskbar="True"
        Background="#0F1117">

    <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             CUSTOM TITLE BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0D0F17"
                MouseLeftButtonDown="TitleBar_MouseDown"
                Cursor="SizeAll">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/SessionAdmin;component/app.ico"
                           Width="16" Height="16" Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="NetCafé Admin — Session Management"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#94A3B8" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Minimize -->
                    <Button Content="─" Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="btnMinimize_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#1E2433"/>
                                        <Setter Property="Foreground" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Maximize / Restore -->
                    <Button x:Name="btnMaximize" Content="□" Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="btnMaximize_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#1E2433"/>
                                        <Setter Property="Foreground" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Close -->
                    <Button Content="✕" Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="btnWindowClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             MAIN AREA (sidebar + content)
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" x:Name="MainLayoutGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             SIDEBAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#13161F"
                BorderBrush="#1E2433" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo / Brand -->
                <Border Grid.Row="0" Padding="20,24,20,20"
                        BorderBrush="#1E2433" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4F8EF7" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="NetCafé" FontSize="15" FontWeight="Bold"
                                           Foreground="#F1F5F9"/>
                                <TextBlock Text="Admin Console" FontSize="10"
                                           Foreground="#475569"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Connection indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Ellipse x:Name="ellipseSidebarConnection" Width="8" Height="8"
                                     Fill="#F87171" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblSidebarConnection" Text="Disconnected"
                                       FontSize="11" Foreground="#64748B" VerticalAlignment="Center"/>
                            <Button x:Name="btnSidebarConnect" Content="↺ Connect" Height="22" Width="70"
                                    Margin="8,0,0,0" FontSize="10" Visibility="Collapsed"
                                    Style="{StaticResource BtnGhost}"
                                    Click="btnConnect_Click" Padding="6,2"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <ScrollViewer x:Name="SidebarNav" Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                              Visibility="Collapsed">
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="MAIN" Style="{StaticResource SectionLabel}" Margin="22,8,0,6"/>

                        <!-- Dashboard -->
                        <RadioButton x:Name="btnNavDashboard" GroupName="Nav"
                                     IsChecked="True"
                                     Style="{StaticResource NavRadioBtn}"
                                     Click="btnNavDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏠" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Active Sessions -->
                        <RadioButton x:Name="btnNavSessions" GroupName="Nav"
                                     Style="{StaticResource NavRadioBtn}"
                                     Click="btnNavSessions_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏱" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Active Sessions" VerticalAlignment="Center"/>
                                <Border CornerRadius="10" Background="#1D3461" Margin="5,5,5,5"
                                        Padding="5,1">
                                    <TextBlock x:Name="sidebarSessionCount" Text="0"
                                               FontSize="10" Foreground="#4F8EF7" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </RadioButton>

                        <!-- Client Machines -->
                        <RadioButton x:Name="btnNavClients" GroupName="Nav"
                                     Style="{StaticResource NavRadioBtn}"
                                     Click="btnNavClients_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖥" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Client Machines" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <TextBlock Text="USERS" Style="{StaticResource SectionLabel}" Margin="22,16,0,6"/>

                        <!-- User Management -->
                        <RadioButton x:Name="btnNavUsers" GroupName="Nav"
                                     Style="{StaticResource NavRadioBtn}"
                                     Click="btnNavUsers_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="User Management" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <TextBlock Text="BILLING" Style="{StaticResource SectionLabel}" Margin="22,16,0,6"/>

                        <!-- Billing Rates -->
                        <RadioButton x:Name="btnNavBilling" GroupName="Nav"
                                     Style="{StaticResource NavRadioBtn}"
                                     Click="btnNavBilling_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💰" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Billing Rates" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <TextBlock Text="MONITORING" Style="{StaticResource SectionLabel}" Margin="22,16,0,6"/>

                        <!-- Security Alerts -->
                        <RadioButton x:Name="btnNavAlerts" GroupName="Nav"
                                     Style="{StaticResource NavRadioBtn}"
                                     Click="btnNavAlerts_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Security Alerts" VerticalAlignment="Center"/>
                                <Border x:Name="alertBadge" CornerRadius="10" Background="#450A0A"
                                        Margin="8,0,0,0" Padding="6,1" Visibility="Collapsed">
                                    <TextBlock x:Name="sidebarAlertCount" Text="0"
                                               FontSize="10" Foreground="#F87171" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </RadioButton>

                        <!-- Session Logs -->
                        <RadioButton x:Name="btnNavLogs" GroupName="Nav"
                                     Style="{StaticResource NavRadioBtn}"
                                     Click="btnNavLogs_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Session Logs" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Reports -->
                        <RadioButton x:Name="btnNavReports" GroupName="Nav"
                                     Style="{StaticResource NavRadioBtn}"
                                     Click="btnNavReports_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Reports" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: Admin Info + Logout -->
                <Border Grid.Row="2" Padding="12,14"
                        BorderBrush="#1E2433" BorderThickness="0,1,0,0">
                    <StackPanel x:Name="AdminHeaderPanel" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="32" Height="32" CornerRadius="16" Margin="0,0,10,0"
                                    ClipToBounds="True">
                                <Grid>
                                    <Border>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#4F8EF7" Offset="0"/>
                                                <GradientStop Color="#A78BFA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Image x:Name="imgAdminAvatar" Stretch="UniformToFill"
                                           Visibility="Collapsed"/>
                                    <TextBlock x:Name="lblAdminInitial" Text="A"
                                               FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White"/>
                                </Grid>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="lblAdminUser" Text="Admin" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#F1F5F9"/>
                                <TextBlock Text="Administrator" FontSize="10" Foreground="#475569"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="btnChangePassword" Content="🔐  Change Password"
                                Style="{StaticResource BtnGhost}"
                                Height="34" FontSize="11" Padding="14,0"
                                Margin="0,0,8,0"
                                Click="btnChangePassword_Click"/>
                        <Button x:Name="btnLogout" Content="⎋  Sign Out"
                                Style="{StaticResource BtnDanger}"
                                Height="34" FontSize="12" Padding="0,0"
                                Click="btnLogout_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             MAIN CONTENT AREA
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">

            <!-- ─── LOGIN PANEL ─── -->
            <Grid x:Name="LoginPanel">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F1117" Offset="0"/>
                        <GradientStop Color="#131A2E" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <Border Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Header -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                            <Border Width="56" Height="56" CornerRadius="16"
                                    HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4F8EF7" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="⚡" FontSize="26" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Admin Sign In" FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="#F1F5F9"/>
                            <TextBlock Text="NetCafé Session Management Console"
                                       FontSize="12" Foreground="#475569"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Username -->
                        <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtAdminUsername" Style="{StaticResource ModernInput}"
                                 Tag="Username" Height="42" Margin="0,0,0,16"/>

                        <!-- Password -->
                        <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#475569" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="txtAdminPassword" Grid.Column="0"
                                         Style="{StaticResource ModernPassword}" Tag="Password"
                                         Height="42"/>
                            <TextBox x:Name="txtAdminPasswordPlain" Grid.Column="0"
                                     Style="{StaticResource ModernInput}" Tag="Password"
                                     Height="42" Visibility="Collapsed"/>
                            <Button x:Name="btnShowAdminPassword" Grid.Column="1"
                                    Content="👁" Style="{StaticResource ShowPasswordBtn}"
                                    Height="42" Margin="4,0,0,0"
                                    Click="btnShowAdminPassword_Click"/>
                        </Grid>

                        <!-- Error -->
                        <Border x:Name="loginErrorBorder" Background="#2D0A0A" CornerRadius="8"
                                BorderBrush="#7F1D1D" BorderThickness="1"
                                Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠ " Foreground="#F87171" FontSize="13"/>
                                <TextBlock x:Name="lblAdminLoginError" Foreground="#FCA5A5"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Connection indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Ellipse x:Name="ellipseConnectionStatus" Width="8" Height="8"
                                     Fill="#F87171" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblConnectionStatus" Text="Disconnected"
                                       FontSize="11" Foreground="#64748B" VerticalAlignment="Center"/>
                            <Button x:Name="btnConnect" Content="↺ Connect" Height="22" Width="70"
                                    Margin="8,0,0,0" FontSize="10" Visibility="Collapsed"
                                    Style="{StaticResource BtnGhost}"
                                    Click="btnConnect_Click" Padding="6,2"/>
                        </StackPanel>

                        <!-- Login Button -->
                        <Button x:Name="btnAdminLogin" Content="Sign In →"
                                Style="{StaticResource BtnPrimary}"
                                Height="44" FontSize="14" Margin="0,20,0,0"
                                Click="btnAdminLogin_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ─── DASHBOARD PANEL ─── -->
            <Grid x:Name="DashboardPanel" Visibility="Collapsed">

                <!-- Page Header -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0" Background="#13161F"
                        BorderBrush="#1E2433" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="lblPageTitle" Text="Dashboard"
                                       FontSize="18" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                            <TextBlock x:Name="lblPageSubtitle" Text=" — Live Overview"
                                       FontSize="13" Foreground="#475569" VerticalAlignment="Bottom"
                                       Margin="0,0,0,2"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="lblLastUpdate" Text="Updated just now"
                                       FontSize="11" Foreground="#475569" VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content -->
                <Grid Grid.Row="1">
                    <Grid>
                        <!-- All pages stacked, visibility toggled -->

                        <!-- ═══ OVERVIEW / KANBAN PAGE ═══ -->
                        <ScrollViewer x:Name="PageDashboard" Margin="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- KPI Cards Row -->
                            <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,20">

                                <!-- Active Sessions -->
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="ACTIVE SESSIONS" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#475569"
                                                       Margin="0,0,0,12"/>
                                            <TextBlock x:Name="kpiActiveSessions" Text="0"
                                                       FontSize="36" FontWeight="Bold"
                                                       Foreground="#4F8EF7"/>
                                            <TextBlock Text="Live right now"
                                                       FontSize="11" Foreground="#475569"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="⏱" FontSize="28" Foreground="#1D3461"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>

                                <!-- Today Revenue -->
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="TODAY'S REVENUE" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#475569"
                                                       Margin="0,0,0,12"/>
                                            <TextBlock x:Name="kpiRevenue" Text="$0.00"
                                                       FontSize="36" FontWeight="Bold"
                                                       Foreground="#34D399"/>
                                            <TextBlock Text="Billing accumulated"
                                                       FontSize="11" Foreground="#475569"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="💰" FontSize="28" Foreground="#064E3B"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>

                                <!-- Security Alerts -->
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="ACTIVE ALERTS" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#475569"
                                                       Margin="0,0,0,12"/>
                                            <TextBlock x:Name="kpiAlerts" Text="0"
                                                       FontSize="36" FontWeight="Bold"
                                                       Foreground="#F87171"/>
                                            <TextBlock Text="Unacknowledged"
                                                       FontSize="11" Foreground="#475569"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="⚠" FontSize="28" Foreground="#450A0A"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>

                                <!-- Total Clients -->
                                <Border Style="{StaticResource Card}">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="REGISTERED CLIENTS" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#475569"
                                                       Margin="0,0,0,12"/>
                                            <TextBlock x:Name="kpiClients" Text="0"
                                                       FontSize="36" FontWeight="Bold"
                                                       Foreground="#FBBF24"/>
                                            <TextBlock Text="Machines"
                                                       FontSize="11" Foreground="#475569"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="🖥" FontSize="28" Foreground="#451A03"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>
                            </UniformGrid>

                            <!-- Kanban: Session Status Columns -->
                            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <TextBlock Text="Session Board" FontSize="15"
                                                   FontWeight="SemiBold" Foreground="#F1F5F9"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" — Kanban View" FontSize="12"
                                                   Foreground="#475569" VerticalAlignment="Bottom"
                                                   Margin="0,0,0,1"/>
                                        <Button Content="↺ Refresh" Style="{StaticResource BtnGhost}"
                                                Height="30" Padding="12,0" FontSize="11"
                                                HorizontalAlignment="Right" Margin="16,0,0,0"
                                                Click="btnRefreshSessions_Click"/>
                                    </StackPanel>
                                    <UniformGrid Columns="3">
                                        <!-- Active -->
                                        <Border Background="#0A1628" CornerRadius="10"
                                                Padding="14" Margin="0,0,8,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Ellipse Width="8" Height="8" Fill="#34D399"
                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="ACTIVE" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="#34D399"/>
                                                    <Border CornerRadius="8" Background="#064E3B"
                                                            Padding="6,1" Margin="8,0,0,0">
                                                        <TextBlock x:Name="kanbanActiveCount" Text="0"
                                                                   FontSize="10" Foreground="#34D399"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <ItemsControl x:Name="kanbanActiveSessions">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#171C2B" CornerRadius="10"
                                                                    Margin="0,0,0,10"
                                                                    BorderBrush="#2D3748" BorderThickness="1">
                                                                <StackPanel>

                                                                    <!-- ── Photo + Info ── -->
                                                                    <Grid Margin="14,14,14,12">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="72"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Session photo -->
                                                                        <Border Grid.Column="0"
                                                                                Width="68" Height="68"
                                                                                CornerRadius="8"
                                                                                Background="#0F1117"
                                                                                BorderBrush="#374151" BorderThickness="1"
                                                                                Margin="0,0,12,0"
                                                                                VerticalAlignment="Top">
                                                                            <Grid>
                                                                                <TextBlock Text="👤" FontSize="26"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Opacity="0.25"/>
                                                                                <Image Source="{Binding PhotoSource}"
                                                                                       Stretch="UniformToFill"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                            </Grid>
                                                                        </Border>

                                                                        <!-- Details -->
                                                                        <StackPanel Grid.Column="1"
                                                                                    VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding FullName}"
                                                                                       FontSize="13" FontWeight="Bold"
                                                                                       Foreground="#F1F5F9"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <Border CornerRadius="10"
                                                                                    Background="#064E3B"
                                                                                    Padding="8,2"
                                                                                    HorizontalAlignment="Left"
                                                                                    Margin="0,5,0,6">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <Ellipse Width="6" Height="6"
                                                                                             Fill="#34D399"
                                                                                             VerticalAlignment="Center"
                                                                                             Margin="0,0,5,0"/>
                                                                                    <TextBlock Text="ACTIVE"
                                                                                               FontSize="10"
                                                                                               Foreground="#34D399"
                                                                                               FontWeight="SemiBold"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                            <TextBlock Text="{Binding Username}"
                                                                                       FontSize="11"
                                                                                       Foreground="#94A3B8"/>
                                                                            <TextBlock Text="{Binding ClientId}"
                                                                                       FontSize="10"
                                                                                       Foreground="#64748B"
                                                                                       Margin="0,2,0,0"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding StartTime}"
                                                                                       FontSize="10"
                                                                                       Foreground="#64748B"
                                                                                       Margin="0,2,0,0"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding Duration}"
                                                                                       FontSize="11"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="#CBD5E1"
                                                                                       Margin="0,3,0,0"/>
                                                                        </StackPanel>
                                                                    </Grid>

                                                                    <!-- ── Separator ── -->
                                                                    <Border Height="1" Background="#1E2D3D"
                                                                            Margin="14,0"/>

                                                                    <!-- ── Footer: remaining / billing / terminate ── -->
                                                                    <Grid Margin="14,10,14,12">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0"
                                                                                    VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding RemainingTime}"
                                                                                       FontSize="13" FontWeight="Bold"
                                                                                       Foreground="#34D399"/>
                                                                            <TextBlock Text="{Binding CurrentBilling}"
                                                                                       FontSize="11"
                                                                                       Foreground="#FBBF24"
                                                                                       Margin="0,2,0,0"/>
                                                                        </StackPanel>
                                                                        <Button Grid.Column="1"
                                                                                Content="⬛"
                                                                                Background="#7F1D1D"
                                                                                Foreground="#FCA5A5"
                                                                                BorderThickness="0"
                                                                                Width="32" Height="28"
                                                                                FontSize="13"
                                                                                FontFamily="Segoe UI"
                                                                                Cursor="Hand"
                                                                                VerticalAlignment="Center"
                                                                                ToolTip="Terminate Session"
                                                                                Click="btnTerminateSession_Click">
                                                                            <Button.Template>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="r"
                                                                                            Background="{TemplateBinding Background}"
                                                                                            CornerRadius="6">
                                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                                          VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="r" Property="Background" Value="#991B1B"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Button.Template>
                                                                        </Button>
                                                                    </Grid>

                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <!-- Idle Clients -->
                                        <Border Background="#0A1210" CornerRadius="10"
                                                Padding="14" Margin="0,0,8,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Ellipse Width="8" Height="8" Fill="#FBBF24"
                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="IDLE CLIENTS" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="#FBBF24"/>
                                                    <Border CornerRadius="8" Background="#451A03"
                                                            Padding="6,1" Margin="8,0,0,0">
                                                        <TextBlock x:Name="kanbanIdleCount" Text="0"
                                                                   FontSize="10" Foreground="#FBBF24"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <ItemsControl x:Name="kanbanIdleClients">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#1E2433" CornerRadius="8"
                                                                    Padding="12,10" Margin="0,0,0,8">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding MachineName}"
                                                                               FontSize="13" FontWeight="SemiBold"
                                                                               Foreground="#F1F5F9"/>
                                                                    <TextBlock Text="{Binding ClientId}"
                                                                               FontSize="11" Foreground="#64748B"
                                                                               Margin="0,2,0,0"/>
                                                                    <Border Style="{StaticResource BadgeAmber}"
                                                                            Padding="6,2" Margin="0,6,0,0"
                                                                            HorizontalAlignment="Left">
                                                                        <TextBlock Text="Available"
                                                                                   FontSize="10" Foreground="#FBBF24"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <!-- Recent Alerts -->
                                        <Border Background="#1A0A0A" CornerRadius="10" Padding="14">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Ellipse Width="8" Height="8" Fill="#F87171"
                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="RECENT ALERTS" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="#F87171"/>
                                                </StackPanel>
                                                <ItemsControl x:Name="kanbanAlerts">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#1E2433" CornerRadius="8"
                                                                    Padding="12,10" Margin="0,0,0,8">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding AlertType}"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               Foreground="#FCA5A5"/>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               FontSize="10" Foreground="#64748B"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Margin="0,2,0,0"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                        <Border Style="{StaticResource BadgeRed}" Padding="6,2">
                                                                            <TextBlock Text="{Binding Severity}"
                                                                                       FontSize="10" Foreground="#F87171"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </Grid>
                        </ScrollViewer>

                        <!-- ═══ ACTIVE SESSIONS PAGE ═══ -->
                        <Grid x:Name="PageSessions" Margin="24" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Content="↺ Refresh" Style="{StaticResource BtnGhost}"
                                        Height="36" Padding="16,0" Click="btnRefreshSessions_Click"/>
                                <TextBlock x:Name="lblActiveCount" Text="0 sessions"
                                           FontSize="12" Foreground="#475569"
                                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </StackPanel>

                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                                <Grid>
                                <DataGrid x:Name="dgActiveSessions" AutoGenerateColumns="False"
                                          ScrollViewer.ScrollChanged="DgScrollChanged"
                                          ui:ScrollBehavior.EnableHorizontalScroll="True"
                                          IsReadOnly="True" CanUserAddRows="False"
                                          SelectionMode="Single" Margin="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="SESSION ID" Binding="{Binding SessionId}" Width="90" MinWidth="90"/>
                                        <DataGridTextColumn Header="CLIENT" Binding="{Binding ClientId}" Width="90" MinWidth="90"/>
                                        <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="140" MinWidth="140"/>
                                        <DataGridTextColumn Header="STARTED" Binding="{Binding StartTime}" Width="155" MinWidth="155"/>
                                        <DataGridTextColumn Header="DURATION" Binding="{Binding Duration}" Width="90" MinWidth="90"/>
                                        <DataGridTextColumn Header="REMAINING" Binding="{Binding RemainingTime}" Width="100" MinWidth="100"/>
                                        <DataGridTextColumn Header="BILLING" Binding="{Binding CurrentBilling}" Width="90" MinWidth="90"/>
                                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="90" MinWidth="90"/>
                                        <DataGridTemplateColumn Header="PHOTO" Width="60" MinWidth="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Image Source="{Binding PhotoSource}"
                                                           Width="40" Height="40"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="ACTIONS" Width="100" MinWidth="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="6,4">
                                                        <Button Content="🖼"
                                                                Background="#4C1D95" Foreground="#C4B5FD"
                                                                BorderThickness="0"
                                                                Width="32" Height="28"
                                                                FontSize="13" FontFamily="Segoe UI"
                                                                Cursor="Hand" Margin="0,0,6,0"
                                                                ToolTip="View Photo"
                                                                Click="btnViewImage_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                                                            CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#5B21B6"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="⬛"
                                                                Background="#7F1D1D" Foreground="#FCA5A5"
                                                                BorderThickness="0"
                                                                Width="32" Height="28"
                                                                FontSize="13" FontFamily="Segoe UI"
                                                                Cursor="Hand"
                                                                ToolTip="Terminate Session"
                                                                Click="btnTerminateSession_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                                                            CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#991B1B"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,20,20" Panel.ZIndex="1" Visibility="Collapsed">
                                    <Button Content="◀" Style="{StaticResource BtnHScroll}"
                                            Click="BtnScrollLeft_Click"/>
                                    <Button Content="▶" Style="{StaticResource BtnHScroll}"
                                            Margin="4,0,0,0" Click="BtnScrollRight_Click"/>
                                </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ═══ CLIENT MACHINES PAGE ═══ -->
                        <Grid x:Name="PageClients" Margin="24" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Content="↺ Refresh" Style="{StaticResource BtnGhost}"
                                        Height="36" Padding="16,0" Click="btnRefreshSessions_Click"/>
                            </StackPanel>

                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                                <Grid>
                                <DataGrid x:Name="dgClients" AutoGenerateColumns="False"
                                          ScrollViewer.ScrollChanged="DgScrollChanged"
                                          ui:ScrollBehavior.EnableHorizontalScroll="True"
                                          IsReadOnly="True" CanUserAddRows="False"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="CODE" Binding="{Binding ClientId}" Width="80" MinWidth="80"/>
                                        <DataGridTextColumn Header="MACHINE" Binding="{Binding MachineName}" Width="160" MinWidth="160"/>
                                        <DataGridTextColumn Header="IP ADDRESS" Binding="{Binding IpAddress}" Width="130" MinWidth="130"/>
                                        <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="150" MinWidth="150"/>
                                        <DataGridTextColumn Header="LOCATION" Binding="{Binding Location}" Width="110" MinWidth="110"/>
                                        <DataGridTextColumn Header="SESSION" Binding="{Binding Status}" Width="90" MinWidth="90"/>
                                        <DataGridTextColumn Header="MACHINE STATUS" Binding="{Binding ClientMachineStatus}" Width="120" MinWidth="120"/>
                                        <DataGridTextColumn Header="CURRENT USER" Binding="{Binding CurrentUser}" Width="140" MinWidth="140"/>
                                        <DataGridTextColumn Header="LAST SEEN" Binding="{Binding LastActive}" Width="160" MinWidth="160"/>
                                        <DataGridTextColumn Header="MISSED HB" Binding="{Binding MissedHeartbeats}" Width="90" MinWidth="90"/>
                                        <DataGridTemplateColumn Header="ACTIONS" Width="130" MinWidth="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="8,4">
                                                        <Button Content="✎"
                                                                Background="#1E3A5F" Foreground="#93C5FD"
                                                                BorderThickness="0"
                                                                Width="32" Height="28"
                                                                FontSize="13" FontFamily="Segoe UI"
                                                                Cursor="Hand" Margin="0,0,4,0"
                                                                ToolTip="Edit Machine"
                                                                Click="btnEditMachine_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                                                            CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="r" Property="Background" Value="#1D4ED8"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="✓"
                                                                Background="#064E3B" Foreground="#34D399"
                                                                BorderThickness="0"
                                                                Width="32" Height="28"
                                                                FontSize="13" FontFamily="Segoe UI"
                                                                Cursor="Hand" Margin="0,0,4,0"
                                                                ToolTip="Enable Machine"
                                                                Click="btnEnableClient_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="r" Property="Background" Value="#065F46"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Content="✕"
                                                                Background="#450A0A" Foreground="#F87171"
                                                                BorderThickness="0"
                                                                Width="32" Height="28"
                                                                FontSize="13" FontFamily="Segoe UI"
                                                                Cursor="Hand"
                                                                ToolTip="Disable Machine"
                                                                Click="btnDisableClient_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="r" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,20,20" Panel.ZIndex="1" Visibility="Collapsed">
                                    <Button Content="◀" Style="{StaticResource BtnHScroll}"
                                            Click="BtnScrollLeft_Click"/>
                                    <Button Content="▶" Style="{StaticResource BtnHScroll}"
                                            Margin="4,0,0,0" Click="BtnScrollRight_Click"/>
                                </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ═══ USER MANAGEMENT PAGE ═══ -->
                        <Grid x:Name="PageUsers" Margin="24" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

