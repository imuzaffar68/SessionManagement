<Window x:Class="SessionAdmin.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="app.ico"
        WindowStyle="None" AllowsTransparency="False"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117">

    <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ── -->
            <Border Grid.Row="0" Background="#0D0F17"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/SessionAdmin;component/app.ico"
                               Width="16" Height="16" Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock x:Name="lblWindowTitle" Text="Dialog"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#94A3B8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="btnWindowClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Content ── -->
            <Border Grid.Row="1" Background="#171B26">
                <StackPanel Margin="24,20,24,24">

                    <!-- Icon + Heading/Message row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border x:Name="iconBorder"
                                Width="44" Height="44" CornerRadius="12"
                                Margin="0,0,16,0" VerticalAlignment="Top">
                            <TextBlock x:Name="lblIcon" Text="ℹ"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="lblHeading" Text="Heading"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#F1F5F9"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="lblMessage" Text=""
                                       FontSize="12" Foreground="#94A3B8"
                                       TextWrapping="Wrap" MaxWidth="290"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Buttons row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnNo" Content="No"
                                Style="{StaticResource BtnGhost}"
                                Height="36" Width="90"
                                Margin="0,0,8,0"
                                Visibility="Collapsed"
                                Click="btnNo_Click"/>
                        <Button x:Name="btnYes" Content="OK"
                                Style="{StaticResource BtnPrimary}"
                                Height="36" Width="90"
                                Click="btnYes_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
