<Window x:Class="SessionAdmin.UserFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="False"
        Height="Auto" Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117">

    <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ── -->
            <Border Grid.Row="0" Background="#0D0F17"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/SessionAdmin;component/web-apps.ico"
                               Width="14" Height="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="👤" FontSize="13" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblWindowTitle" Text="User"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#94A3B8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="btnWindowClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Content ── -->
            <Border Grid.Row="1" Background="#171B26">
                <StackPanel Margin="28,22,28,28">

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                        <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#065F46" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="👤" FontSize="19" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="lblFormTitle" Text="Add Client User"
                                       FontSize="16" FontWeight="Bold" Foreground="#F1F5F9"/>
                            <TextBlock x:Name="lblFormSubtitle" Text="Register a new client account"
                                       FontSize="11" Foreground="#475569"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- PROFILE PHOTO -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            HorizontalAlignment="Center" Margin="0,0,0,8"
                            Background="#1E2433" BorderBrush="#2D3748" BorderThickness="2"
                            ClipToBounds="True">
                        <Grid>
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#065F46" Offset="0"/>
                                        <GradientStop Color="#1D3461" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="imgPhotoPlaceholder" Text="👤" FontSize="32"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#475569"/>
                            <Image x:Name="imgPhotoPreview" Stretch="UniformToFill"/>
                        </Grid>
                    </Border>
                    <Button x:Name="btnUploadPhoto" Content="📷  Upload Photo"
                            Height="30" FontSize="11" HorizontalAlignment="Center"
                            Style="{StaticResource BtnGhost}" Margin="0,0,0,20"
                            Click="btnUploadPhoto_Click"/>

                    <!-- USERNAME -->
                    <TextBlock Text="USERNAME *" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <!-- Add mode: editable TextBox -->
                    <TextBox x:Name="txtUsername" Style="{StaticResource ModernInput}"
                             Height="40" Margin="0,0,0,4" Tag="e.g. john_doe"/>
                    <TextBlock x:Name="errUsername" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>
                    <!-- Edit mode: read-only label styled like input -->
                    <Border x:Name="pnlUsernameReadonly" Background="#13161F" CornerRadius="8"
                            BorderBrush="#1E2433" BorderThickness="1"
                            Height="40" Margin="0,0,0,14" Visibility="Collapsed"
                            Padding="12,0">
                        <TextBlock x:Name="lblUsernameReadonly" Foreground="#475569"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Border>

                    <!-- FULL NAME -->
                    <TextBlock Text="FULL NAME *" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtFullName" Style="{StaticResource ModernInput}"
                             Height="40" Margin="0,0,0,4" Tag="e.g. John Doe"/>
                    <TextBlock x:Name="errFullName" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- PASSWORD — hidden in edit mode -->
                    <StackPanel x:Name="pnlPasswordSection">
                        <TextBlock Text="PASSWORD *" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#475569" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="76"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="txtPassword" Grid.Column="0"
                                         Style="{StaticResource ModernPassword}" Height="40"
                                         Tag="Enter password"/>
                            <TextBox x:Name="txtPasswordPlain" Grid.Column="0"
                                     Style="{StaticResource ModernInput}" Height="40"
                                     Visibility="Collapsed" Tag="Enter password"/>
                            <Button x:Name="btnShowPassword" Grid.Column="1"
                                    Content="👁" Style="{StaticResource ShowPasswordBtn}"
                                    Height="40" Click="btnShowPassword_Click"/>
                            <Button x:Name="btnGenerate" Grid.Column="3"
                                    Content="⚡ Auto" Style="{StaticResource BtnPurple}"
                                    Height="40" FontSize="11" Padding="0"
                                    Click="btnGenerate_Click"/>
                        </Grid>
                        <TextBlock x:Name="errPassword" Foreground="#F87171" FontSize="11"
                                   Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- PHONE -->
                    <TextBlock Text="PHONE" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtPhone" Style="{StaticResource ModernInput}"
                             Height="40" Margin="0,0,0,14" Tag="e.g. +92 300 1234567"/>

                    <!-- ADDRESS -->
                    <TextBlock Text="ADDRESS" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtAddress" Style="{StaticResource ModernInput}"
                             Height="40" Margin="0,0,0,16" Tag="e.g. House 5, Street 10, City"/>

                    <!-- Error -->
                    <Border x:Name="lblErrorBorder" Background="#2D0A0A" CornerRadius="8"
                            BorderBrush="#7F1D1D" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                        <TextBlock x:Name="lblError" Foreground="#FCA5A5"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnCancel" Content="Cancel"
                                Style="{StaticResource BtnGhost}"
                                Height="38" Width="90" Margin="0,0,8,0"
                                Click="btnCancel_Click"/>
                        <Button x:Name="btnSubmit" Content="+ Add User"
                                Style="{StaticResource BtnSuccess}"
                                Height="38" MinWidth="120"
                                Click="btnSubmit_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
