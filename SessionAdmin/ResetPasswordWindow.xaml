<Window x:Class="SessionAdmin.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="app.ico"
        WindowStyle="None" AllowsTransparency="False"
        Height="Auto" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117">

    <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ── -->
            <Border Grid.Row="0" Background="#0D0F17"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/SessionAdmin;component/app.ico"
                               Width="14" Height="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="🔑" FontSize="13" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Reset Password"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#94A3B8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="btnWindowClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Content ── -->
            <Border Grid.Row="1" Background="#171B26">
                <StackPanel Margin="28,22,28,28">

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B0764" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🔑" FontSize="18" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Reset Password" FontSize="16" FontWeight="Bold"
                                       Foreground="#F1F5F9"/>
                            <TextBlock Text="Set a new secure password"
                                       FontSize="11" Foreground="#475569"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Username (read-only) -->
                    <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtUsername" Style="{StaticResource ModernInput}"
                             Height="40" IsReadOnly="True"
                             Background="#13161F" Foreground="#475569"
                             Margin="0,0,0,14"/>

                    <!-- New Password -->
                    <TextBlock Text="NEW PASSWORD" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="txtPassword" Grid.Column="0"
                                     Style="{StaticResource ModernPassword}" Height="40"
                                     Tag="New password"/>
                        <TextBox x:Name="txtPasswordPlain" Grid.Column="0"
                                 Style="{StaticResource ModernInput}" Height="40"
                                 Visibility="Collapsed" Tag="New password"/>
                        <Button x:Name="btnShowPassword" Grid.Column="1"
                                Content="👁" Style="{StaticResource ShowPasswordBtn}"
                                Height="40" Margin="4,0,0,0"
                                Click="btnShowPassword_Click"/>
                    </Grid>

                    <TextBlock x:Name="errPassword" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Confirm Password -->
                    <TextBlock Text="CONFIRM PASSWORD" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="txtConfirmPassword" Grid.Column="0"
                                     Style="{StaticResource ModernPassword}" Height="40"
                                     Tag="Confirm password"/>
                        <TextBox x:Name="txtConfirmPasswordPlain" Grid.Column="0"
                                 Style="{StaticResource ModernInput}" Height="40"
                                 Visibility="Collapsed" Tag="Confirm password"/>
                        <Button x:Name="btnShowConfirmPassword" Grid.Column="1"
                                Content="👁" Style="{StaticResource ShowPasswordBtn}"
                                Height="40" Margin="4,0,0,0"
                                Click="btnShowConfirmPassword_Click"/>
                    </Grid>

                    <TextBlock x:Name="errConfirmPassword" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Auto-generate -->
                    <Button x:Name="btnGenerate" Content="⚡ Generate Default (User@123456)"
                            Style="{StaticResource BtnPurple}"
                            Height="36" Margin="0,0,0,4"
                            Click="btnGenerate_Click"/>

                    <TextBlock Text="Min 8 chars · uppercase · lowercase · digit"
                               FontSize="10" Foreground="#475569"
                               Margin="0,6,0,10"/>

                    <!-- Error -->
                    <Border x:Name="lblErrorBorder" Background="#2D0A0A" CornerRadius="8"
                            BorderBrush="#7F1D1D" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,14" Visibility="Collapsed">
                        <TextBlock x:Name="lblError" Foreground="#FCA5A5"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnCancel" Content="Cancel"
                                Style="{StaticResource BtnGhost}"
                                Height="38" Width="100" Margin="0,0,8,0"
                                Click="btnCancel_Click"/>
                        <Button x:Name="btnReset" Content="Reset Password"
                                Style="{StaticResource BtnPurple}"
                                Height="38" Width="140"
                                Click="btnReset_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
