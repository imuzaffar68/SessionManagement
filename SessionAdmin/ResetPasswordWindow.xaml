<Window x:Class="SessionAdmin.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password"
        Height="480" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117">

    <!-- All styles come from SessionAdmin/App.xaml — no local resources needed -->

    <Border Background="#171B26">
        <StackPanel Margin="28">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B0764" Offset="0"/>
                            <GradientStop Color="#7C3AED" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🔑" FontSize="18" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Reset Password" FontSize="16" FontWeight="Bold"
                               Foreground="#F1F5F9"/>
                    <TextBlock Text="Set a new secure password"
                               FontSize="11" Foreground="#475569"/>
                </StackPanel>
            </StackPanel>

            <!-- Username (read-only) -->
            <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <TextBox x:Name="txtUsername" Style="{StaticResource ModernInput}"
                     Height="40" IsReadOnly="True"
                     Background="#13161F" Foreground="#475569"
                     Margin="0,0,0,14"/>

            <!-- New Password -->
            <TextBlock Text="NEW PASSWORD" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="txtPassword" Grid.Column="0"
                             Style="{StaticResource ModernPassword}" Height="40"/>
                <TextBox x:Name="txtPasswordPlain" Grid.Column="0"
                         Style="{StaticResource ModernInput}" Height="40"
                         Visibility="Collapsed"/>
                <Button x:Name="btnShowPassword" Grid.Column="1"
                        Content="👁" Style="{StaticResource ShowPasswordBtn}"
                        Height="40" Margin="4,0,0,0"
                        Click="btnShowPassword_Click"/>
            </Grid>

            <!-- Confirm Password -->
            <TextBlock Text="CONFIRM PASSWORD" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="txtConfirmPassword" Grid.Column="0"
                             Style="{StaticResource ModernPassword}" Height="40"/>
                <TextBox x:Name="txtConfirmPasswordPlain" Grid.Column="0"
                         Style="{StaticResource ModernInput}" Height="40"
                         Visibility="Collapsed"/>
                <Button x:Name="btnShowConfirmPassword" Grid.Column="1"
                        Content="👁" Style="{StaticResource ShowPasswordBtn}"
                        Height="40" Margin="4,0,0,0"
                        Click="btnShowConfirmPassword_Click"/>
            </Grid>

            <!-- Auto-generate -->
            <Button x:Name="btnGenerate" Content="⚡ Generate Default (User@123456)"
                    Style="{StaticResource BtnPurple}"
                    Height="36" Margin="0,0,0,4"
                    Click="btnGenerate_Click"/>

            <TextBlock Text="Min 8 chars · uppercase · lowercase · digit"
                       FontSize="10" Foreground="#475569"
                       Margin="0,6,0,10"/>

            <!-- Error -->
            <Border x:Name="lblErrorBorder" Background="#2D0A0A" CornerRadius="8"
                    BorderBrush="#7F1D1D" BorderThickness="1"
                    Padding="12,8" Margin="0,0,0,14" Visibility="Collapsed">
                <TextBlock x:Name="lblError" Foreground="#FCA5A5"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancel"
                        Style="{StaticResource BtnGhost}"
                        Height="38" Width="100" Margin="0,0,8,0"
                        Click="btnCancel_Click"/>
                <Button x:Name="btnReset" Content="Reset Password"
                        Style="{StaticResource BtnPurple}"
                        Height="38" Width="140"
                        Click="btnReset_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
