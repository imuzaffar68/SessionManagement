<Window x:Class="SessionAdmin.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password" Height="500" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <StackPanel Margin="24" VerticalAlignment="Top">
        <TextBlock Text="Reset Client User Password" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="Username:" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtUsername" Height="32" IsReadOnly="True" 
                 Background="#ECEFF1" Padding="8" Margin="0,0,0,20"/>

        <TextBlock Text="New Password:" FontSize="12" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="txtPassword" Grid.Column="0"
                         Height="32" Padding="8"/>
            <TextBox x:Name="txtPasswordPlain" Grid.Column="0"
                     Height="32" Padding="8" Visibility="Collapsed"/>
            <Button x:Name="btnShowPassword" Grid.Column="1"
                    Content="👁" FontSize="15"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#3498DB" Margin="4,0,0,0"
                    Click="btnShowPassword_Click"/>
        </Grid>

        <TextBlock Text="Confirm Password:" FontSize="12" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="txtConfirmPassword" Grid.Column="0"
                         Height="32" Padding="8"/>
            <TextBox x:Name="txtConfirmPasswordPlain" Grid.Column="0"
                     Height="32" Padding="8" Visibility="Collapsed"/>
            <Button x:Name="btnShowConfirmPassword" Grid.Column="1"
                    Content="👁" FontSize="15"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#3498DB" Margin="4,0,0,0"
                    Click="btnShowConfirmPassword_Click"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="btnGenerate" Content="Generate (User@123456)"
                    Height="32" Background="#9B59B6" Foreground="White"
                    Padding="12,0" Click="btnGenerate_Click"/>
        </StackPanel>

        <TextBlock Text="Password must be at least 8 characters long and contain uppercase, lowercase, and digits."
                   FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <TextBlock x:Name="lblError" Foreground="Red" FontSize="11"
                   Margin="0,0,0,12" Visibility="Collapsed" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnReset" Content="Reset Password" Height="36" Width="120"
                    Background="#27AE60" Foreground="White" Click="btnReset_Click"
                    FontWeight="Bold"/>
            <Button x:Name="btnCancel" Content="Cancel" Height="36" Width="90"
                    Margin="8,0,0,0" Background="#95A5A6" Foreground="White"
                    Click="btnCancel_Click" FontWeight="Bold"/>
        </StackPanel>
    </StackPanel>
</Window>
