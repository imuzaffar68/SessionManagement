<Window x:Class="SessionAdmin.AdminSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Configuration"
        Width="400" Height="300"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#1E2433"
        BorderBrush="#2D3748"
        BorderThickness="1">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#171B26" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="⚙" Foreground="#4F8EF7" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Network Configuration" Foreground="#F1F5F9"
                               FontSize="13" FontFamily="Segoe UI"/>
                </StackPanel>
                <Button Content="✕" Click="btnCancel_Click"
                        HorizontalAlignment="Right" Width="44" Height="44"
                        Foreground="#64748B" BorderThickness="0" FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#DC2626"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,18,24,20">
            <TextBlock Text="Server Address" Foreground="#94A3B8"
                       FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,5"/>
            <TextBox x:Name="txtServerAddress"
                     Background="#0F1117" Foreground="#F1F5F9"
                     BorderBrush="#2D3748" BorderThickness="1"
                     FontSize="13" FontFamily="Segoe UI"
                     Padding="10,7" Height="36" CaretBrush="#4F8EF7"/>

            <TextBlock Text="Server Port" Foreground="#94A3B8"
                       FontSize="11" FontFamily="Segoe UI" Margin="0,12,0,5"/>
            <TextBox x:Name="txtServerPort"
                     Background="#0F1117" Foreground="#F1F5F9"
                     BorderBrush="#2D3748" BorderThickness="1"
                     FontSize="13" FontFamily="Segoe UI"
                     Padding="10,7" Height="36" CaretBrush="#4F8EF7"/>

            <TextBlock x:Name="lblStatus" Foreground="#475569"
                       FontSize="11" FontFamily="Segoe UI"
                       Text="The app will restart automatically after saving."
                       TextWrapping="Wrap" Margin="0,10,0,0"/>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Save &amp; Restart" Click="btnSave_Click"
                        Height="34" FontSize="13" FontFamily="Segoe UI"
                        Foreground="White" Background="#4F8EF7" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#3B7DE8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="2" Content="Cancel" Click="btnCancel_Click"
                        Height="34" FontSize="13" FontFamily="Segoe UI"
                        Foreground="#94A3B8" Background="#252D42" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#2D3748"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
