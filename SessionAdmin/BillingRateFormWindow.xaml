<Window x:Class="SessionAdmin.BillingRateFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="False"
        Height="560" Width="590"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117">

    <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>   <!-- custom title bar -->
                <RowDefinition Height="*"/>    <!-- content -->
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ── -->
            <Border Grid.Row="0" Background="#0D0F17"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/SessionAdmin;component/web-apps.ico"
                               Width="14" Height="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="💰" FontSize="13" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblWindowTitle" Text="Billing Rate"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#94A3B8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="btnWindowClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Content ── -->
            <Border Grid.Row="1" Background="#171B26">
                <StackPanel Margin="28,22,28,28">

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A2E4A" Offset="0"/>
                                    <GradientStop Color="#4F8EF7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="💰" FontSize="18" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="lblFormTitle" Text="Add Billing Rate"
                                       FontSize="16" FontWeight="Bold" Foreground="#F1F5F9"/>
                            <TextBlock x:Name="lblFormSubtitle" Text="Configure a new billing rate"
                                       FontSize="11" Foreground="#475569"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Rate Name -->
                    <TextBlock Text="RATE NAME *" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtRateName" Style="{StaticResource ModernInput}"
                             Height="40" Margin="0,0,0,4" Tag="e.g. Standard Rate"/>
                    <TextBlock x:Name="errRateName" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Rate/Min + Currency -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="RATE / MINUTE *" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#475569" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtRatePerMinute" Style="{StaticResource ModernInput}" Height="40" Tag="e.g. 1.50"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CURRENCY" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#475569" Margin="0,0,0,6"/>
                            <ComboBox x:Name="cboCurrency" Style="{StaticResource ModernCombo}"
                                      Height="40" SelectedIndex="0">
                                <ComboBoxItem Content="USD"/>
                                <ComboBoxItem Content="EUR"/>
                                <ComboBoxItem Content="GBP"/>
                                <ComboBoxItem Content="INR"/>
                                <ComboBoxItem Content="PKR"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="errRatePerMinute" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Effective From + To -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="256"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="256"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="EFFECTIVE FROM *" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#475569" Margin="0,0,0,6"/>
                            <DatePicker x:Name="dpEffectiveFrom" Height="40"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="EFFECTIVE TO" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#475569" Margin="0,0,0,6"/>
                            <DatePicker x:Name="dpEffectiveTo" Height="40"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="errEffectiveFrom" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Notes -->
                    <TextBlock Text="NOTES" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtNotes" Style="{StaticResource ModernInput}"
                             Height="58" TextWrapping="Wrap" VerticalContentAlignment="Stretch"
                             Padding="12,8" Margin="0,0,0,14" Tag="Optional notes or terms..."/>

                    <!-- Checkboxes -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <CheckBox x:Name="chkIsActive" Content="Active" IsChecked="True"
                                  VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <CheckBox x:Name="chkIsDefault" Content="Set as Default"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Error -->
                    <Border x:Name="lblErrorBorder" Background="#2D0A0A" CornerRadius="8"
                            BorderBrush="#7F1D1D" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                        <TextBlock x:Name="lblError" Foreground="#FCA5A5"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnCancel" Content="Cancel"
                                Style="{StaticResource BtnGhost}"
                                Height="38" Width="90" Margin="0,0,8,0"
                                Click="btnCancel_Click"/>
                        <Button x:Name="btnSubmit" Content="+ Add Rate"
                                Style="{StaticResource BtnSuccess}"
                                Height="38" Width="120"
                                Click="btnSubmit_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
