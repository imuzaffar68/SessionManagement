<Window x:Class="SessionAdmin.EditMachineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="False"
        Height="Auto" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117">

    <Border Background="#0F1117" BorderBrush="#2D3748" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ── -->
            <Border Grid.Row="0" Background="#0D0F17"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/SessionAdmin;component/web-apps.ico"
                               Width="14" Height="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="✎" FontSize="13" Margin="0,0,8,0"
                                   VerticalAlignment="Center" Foreground="#94A3B8"/>
                        <TextBlock Text="Edit Machine"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#94A3B8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="32" Height="28"
                            Foreground="#475569" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="btnWindowClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="r" Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="r" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Content ── -->
            <Border Grid.Row="1" Background="#171B26">
                <StackPanel Margin="28,22,28,28">

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E3A5F" Offset="0"/>
                                    <GradientStop Color="#3B82F6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="✎" FontSize="18" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="lblTitle" FontSize="16" FontWeight="Bold"
                                       Foreground="#F1F5F9"/>
                            <TextBlock Text="Update machine name and location"
                                       FontSize="11" Foreground="#475569"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Machine Name -->
                    <TextBlock Text="MACHINE NAME" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtMachineName" Style="{StaticResource ModernInput}"
                             Tag="e.g. Computer 01" Height="40" Margin="0,0,0,4"/>
                    <TextBlock x:Name="errMachineName" Foreground="#F87171" FontSize="11"
                               Margin="2,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Location -->
                    <TextBlock Text="LOCATION" FontSize="10" FontWeight="SemiBold"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtLocation" Style="{StaticResource ModernInput}"
                             Tag="e.g. Row A – Seat 1" Height="40" Margin="0,0,0,16"/>

                    <!-- Error banner -->
                    <Border x:Name="lblErrorBorder" Background="#2D0A0A" CornerRadius="8"
                            BorderBrush="#7F1D1D" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                        <TextBlock x:Name="lblError" Foreground="#FCA5A5"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnCancel" Content="Cancel"
                                Style="{StaticResource BtnGhost}"
                                Height="38" Width="100" Margin="0,0,8,0"
                                Click="btnCancel_Click"/>
                        <Button x:Name="btnSave" Content="Save Changes"
                                Style="{StaticResource BtnPrimary}"
                                Height="38" Width="130"
                                Click="btnSave_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
