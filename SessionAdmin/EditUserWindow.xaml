<Window x:Class="SessionAdmin.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Client User"
        Height="420" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117"
        BorderBrush="#2D3748"
        BorderThickness="1">

	<Window.Resources>
		<Style x:Key="DlgInput" TargetType="TextBox">
			<Setter Property="Background" Value="#1E2433"/>
			<Setter Property="Foreground" Value="#F1F5F9"/>
			<Setter Property="BorderBrush" Value="#2D3748"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Padding" Value="12,9"/>
			<Setter Property="CaretBrush" Value="#4F8EF7"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter Property="BorderBrush" Value="#4F8EF7"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Border Background="#171B26" CornerRadius="0">
		<StackPanel Margin="28">

			<!-- Header -->
			<StackPanel Orientation="Horizontal" Margin="0,0,0,24">
				<Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
					<Border.Background>
						<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
							<GradientStop Color="#1D3461" Offset="0"/>
							<GradientStop Color="#4F8EF7" Offset="1"/>
						</LinearGradientBrush>
					</Border.Background>
					<TextBlock Text="✎" FontSize="18" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="White"/>
				</Border>
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Edit Client User" FontSize="16" FontWeight="Bold"
                               Foreground="#F1F5F9" FontFamily="Segoe UI"/>
					<TextBlock Text="Update user profile information"
                               FontSize="11" Foreground="#475569" FontFamily="Segoe UI"/>
				</StackPanel>
			</StackPanel>

			<!-- Username (read-only) -->
			<TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" FontFamily="Segoe UI" Margin="0,0,0,6"/>
			<TextBox x:Name="txtUsername" Style="{StaticResource DlgInput}"
                     Height="40" IsReadOnly="True"
                     Background="#13161F" Foreground="#475569"
                     Margin="0,0,0,14"/>

			<!-- Full Name -->
			<TextBlock Text="FULL NAME" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" FontFamily="Segoe UI" Margin="0,0,0,6"/>
			<TextBox x:Name="txtFullName" Style="{StaticResource DlgInput}"
                     Height="40" Margin="0,0,0,14"/>

			<!-- Phone -->
			<TextBlock Text="PHONE" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" FontFamily="Segoe UI" Margin="0,0,0,6"/>
			<TextBox x:Name="txtPhone" Style="{StaticResource DlgInput}"
                     Height="40" Margin="0,0,0,14"/>

			<!-- Address -->
			<TextBlock Text="ADDRESS" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" FontFamily="Segoe UI" Margin="0,0,0,6"/>
			<TextBox x:Name="txtAddress" Style="{StaticResource DlgInput}"
                     Height="40" Margin="0,0,0,16"/>

			<!-- Error -->
			<Border x:Name="lblErrorBorder" Background="#2D0A0A" CornerRadius="8"
                    BorderBrush="#7F1D1D" BorderThickness="1"
                    Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
				<TextBlock x:Name="lblError" Foreground="#FCA5A5"
                           FontSize="12" FontFamily="Segoe UI" TextWrapping="Wrap"/>
			</Border>

			<!-- Buttons -->
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
				<Button x:Name="btnCancel" Content="Cancel" Height="38" Width="100"
                        Background="#1E2433" Foreground="#94A3B8"
                        BorderBrush="#2D3748" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="13" Cursor="Hand"
                        Margin="0,0,8,0" Click="btnCancel_Click">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border x:Name="r" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" Padding="0">
								<ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="r" Property="Background" Value="#252D42"/>
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Button.Template>
				</Button>
				<Button x:Name="btnSave" Content="Save Changes" Height="38" Width="130"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Foreground="White" Cursor="Hand" Click="btnSave_Click">
					<Button.Background>
						<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
							<GradientStop Color="#4F8EF7" Offset="0"/>
							<GradientStop Color="#6366F1" Offset="1"/>
						</LinearGradientBrush>
					</Button.Background>
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border x:Name="r" Background="{TemplateBinding Background}"
                                    CornerRadius="8">
								<ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="r" Property="Opacity" Value="0.9"/>
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Button.Template>
				</Button>
			</StackPanel>
		</StackPanel>
	</Border>
</Window>
