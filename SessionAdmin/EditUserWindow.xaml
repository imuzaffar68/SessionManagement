<Window x:Class="SessionAdmin.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Client User" Height="500" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <StackPanel Margin="24" VerticalAlignment="Top">
        <TextBlock Text="Edit Client User Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="Username (Read-Only):" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtUsername" Height="32" IsReadOnly="True" 
                 Background="#ECEFF1" Padding="8" Margin="0,0,0,14"/>

        <TextBlock Text="Full Name:" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtFullName" Height="32" Padding="8" Margin="0,0,0,14"/>

        <TextBlock Text="Phone:" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtPhone" Height="32" Padding="8" Margin="0,0,0,14"/>

        <TextBlock Text="Address:" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtAddress" Height="32" Padding="8" Margin="0,0,0,20"/>

        <TextBlock x:Name="lblError" Foreground="Red" FontSize="11"
                   Margin="0,0,0,12" Visibility="Collapsed" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnSave" Content="Save" Height="36" Width="90"
                    Background="#27AE60" Foreground="White" Click="btnSave_Click"
                    FontWeight="Bold"/>
            <Button x:Name="btnCancel" Content="Cancel" Height="36" Width="90"
                    Margin="8,0,0,0" Background="#95A5A6" Foreground="White"
                    Click="btnCancel_Click" FontWeight="Bold"/>
        </StackPanel>
    </StackPanel>
</Window>
