<Window x:Class="SessionAdmin.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Client User"
        Height="420" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117">

    <!-- All styles come from SessionAdmin/App.xaml — no local resources needed -->

    <Border Background="#171B26">
        <StackPanel Margin="28">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1D3461" Offset="0"/>
                            <GradientStop Color="#4F8EF7" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="✎" FontSize="18" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="White"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Edit Client User" FontSize="16" FontWeight="Bold"
                               Foreground="#F1F5F9"/>
                    <TextBlock Text="Update user profile information"
                               FontSize="11" Foreground="#475569"/>
                </StackPanel>
            </StackPanel>

            <!-- Username (read-only) -->
            <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <TextBox x:Name="txtUsername" Style="{StaticResource ModernInput}"
                     Height="40" IsReadOnly="True"
                     Background="#13161F" Foreground="#475569"
                     Margin="0,0,0,14"/>

            <!-- Full Name -->
            <TextBlock Text="FULL NAME" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <TextBox x:Name="txtFullName" Style="{StaticResource ModernInput}"
                     Height="40" Margin="0,0,0,14"/>

            <!-- Phone -->
            <TextBlock Text="PHONE" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <TextBox x:Name="txtPhone" Style="{StaticResource ModernInput}"
                     Height="40" Margin="0,0,0,14"/>

            <!-- Address -->
            <TextBlock Text="ADDRESS" FontSize="10" FontWeight="SemiBold"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <TextBox x:Name="txtAddress" Style="{StaticResource ModernInput}"
                     Height="40" Margin="0,0,0,16"/>

            <!-- Error -->
            <Border x:Name="lblErrorBorder" Background="#2D0A0A" CornerRadius="8"
                    BorderBrush="#7F1D1D" BorderThickness="1"
                    Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                <TextBlock x:Name="lblError" Foreground="#FCA5A5"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancel"
                        Style="{StaticResource BtnGhost}"
                        Height="38" Width="100" Margin="0,0,8,0"
                        Click="btnCancel_Click"/>
                <Button x:Name="btnSave" Content="Save Changes"
                        Style="{StaticResource BtnPrimary}"
                        Height="38" Width="130"
                        Click="btnSave_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
